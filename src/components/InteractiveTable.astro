---
interface Specification {
  label: string;
  value: string;
  detail?: string;
}

interface Props {
  title: string;
  specs: Specification[];
}

const { title, specs } = Astro.props;
---

<div class="interactive-table-container my-12 border border-white/5 bg-bg-panel/50 rounded-2xl overflow-hidden shadow-2xl backdrop-blur-sm group hover:border-brand-primary/20 transition-all duration-500">
  <div class="p-6 border-b border-white/5 bg-gradient-to-r from-brand-primary/5 to-transparent">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 rounded-lg bg-brand-primary/10 flex items-center justify-center text-brand-primary">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3h18v18H3zM3 9h18M9 3v18"/></svg>
      </div>
      <h3 class="text-lg font-bold text-white m-0 tracking-tight">{title}</h3>
    </div>
  </div>
  
  <div class="overflow-x-auto">
    <table class="w-full text-left border-collapse m-0">
      <thead>
        <tr class="bg-white/5 uppercase tracking-widest text-[10px] font-bold text-slate-500">
          <th class="px-6 py-4 border-b border-white/5">Parameter</th>
          <th class="px-6 py-4 border-b border-white/5">Description</th>
          <th class="px-6 py-4 border-b border-white/5 text-right italic">Status</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-white/5">
        {specs.map((item) => (
          <tr class="hover:bg-white/5 transition-colors group/row">
            <td class="px-6 py-4">
              <div class="font-mono text-xs font-bold text-brand-primary group-hover/row:text-brand-accent transition-colors">
                {item.label}
              </div>
            </td>
            <td class="px-6 py-4">
              <div class="text-sm text-slate-400 group-hover/row:text-slate-200 transition-colors">
                <span class="font-semibold text-slate-300">{item.value}</span>
                {item.detail && <span class="block text-xs mt-1 opacity-60 leading-relaxed">{item.detail}</span>}
              </div>
            </td>
            <td class="px-6 py-4 text-right">
              <div class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full bg-emerald-500/10 text-emerald-500 text-[10px] uppercase font-bold tracking-tight">
                <span class="w-1 h-1 rounded-full bg-emerald-500 animate-pulse"></span>
                Standard
              </div>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
  
  <div class="p-4 bg-white/5 flex items-center justify-between">
    <p class="text-[10px] text-slate-500 m-0 italic">Ref: ANSI Y32.2-1975 Standard Electronic Symbols</p>
    <div class="flex gap-2">
      <div class="w-2 h-2 rounded-full bg-brand-primary/20"></div>
      <div class="w-2 h-2 rounded-full bg-brand-primary/40"></div>
      <div class="w-2 h-2 rounded-full bg-brand-primary/60"></div>
    </div>
  </div>
</div>
