---
import { toolPresets } from '../data/toolPresets';
import { useTranslations } from '../theme/i18n';
import DiagramCanvas from './DiagramCanvas.astro';

interface Props {
  presetId: string;
  locale: string;
  ctaHref: string;
  ctaLabel?: string;
}

const { presetId, locale, ctaHref, ctaLabel } = Astro.props;
const t = useTranslations(locale);
const defaultPreset = toolPresets.find((preset) => preset.id === presetId) || toolPresets[0];
const translatedPreset = t(`showcase.presets.${presetId}`);
const preset =
  translatedPreset && typeof translatedPreset === 'object'
    ? { ...defaultPreset, ...translatedPreset }
    : defaultPreset;
---

<div class="rounded-[1.5rem] border border-white/5 bg-[#080c14] p-4 shadow-2xl relative overflow-hidden group/canvas sm:rounded-[2rem] sm:p-6 lg:rounded-[2.5rem] lg:p-8">
  <!-- Subtle background glow -->
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_70%_30%,rgba(59,130,246,0.04),transparent_60%)] pointer-events-none"></div>
  
  <div class="relative grid gap-6 lg:grid-cols-[1fr_380px] lg:gap-10">
    <!-- Left: SVG Canvas -->
    <div class="flex flex-col gap-8">
      <div class="overflow-hidden rounded-[1.4rem] border border-white/5 bg-[#05080f] p-4 relative shadow-inner sm:rounded-[2rem] sm:p-6">
        <div class="mb-5 flex flex-col gap-4 border-b border-white/5 pb-4 sm:mb-6 sm:flex-row sm:items-center sm:justify-between">
          <div class="min-w-0">
            <p class="text-[10px] uppercase tracking-[0.4em] text-slate-600 font-black">{t('showcase.tool_preview.badge')}</p>
            <h3 class="mt-2 text-xl font-black text-white tracking-tight break-words sm:text-2xl">{preset.title}</h3>
          </div>
          <div class="w-fit rounded-full border border-emerald-400/20 bg-emerald-400/5 px-3 py-1 text-[10px] font-black uppercase tracking-[0.25em] text-emerald-400/90 shadow-[0_0_15px_rgba(52,211,153,0.1)]">
            {t('showcase.tool_preview.active')}
          </div>
        </div>

        <div class="relative aspect-[16/10] overflow-hidden rounded-2xl border border-white/5 bg-[radial-gradient(circle_at_top,rgba(59,130,246,0.15),transparent_45%),#020617]">
          <DiagramCanvas presetId={presetId} />
        </div>
      </div>

      <div class="grid gap-4 xl:grid-cols-2 xl:gap-6">
        <!-- Stages -->
        <div class="rounded-3xl border border-white/5 bg-white/[0.01] p-4 backdrop-blur-3xl sm:p-6">
          <div class="mb-5 flex items-center justify-between gap-4 border-b border-white/10 pb-4 sm:mb-6">
            <div>
              <p class="text-[10px] uppercase tracking-[0.4em] text-brand-accent font-black">{t('showcase.tool_preview.path.badge')}</p>
              <h4 class="mt-1 text-sm font-bold text-white">{t('showcase.tool_preview.path.title')}</h4>
            </div>
          </div>
          <div class="space-y-4">
            {preset.stages.map((stage) => (
              <div class="rounded-2xl border border-white/5 bg-white/[0.02] p-4 transition-all hover:bg-white/[0.05] hover:border-white/10">
                <div class="flex items-start justify-between gap-4">
                  <div class="min-w-0">
                    <p class="text-xs font-black text-white tracking-wide uppercase break-words">{stage.name}</p>
                    <p class="mt-1 text-[11px] text-slate-500 leading-relaxed">{stage.detail}</p>
                  </div>
                  <span class="text-xs font-mono text-brand-accent font-bold">{stage.load}%</span>
                </div>
                <div class="mt-3 h-1.5 overflow-hidden rounded-full bg-white/5">
                  <div class="h-full rounded-full bg-gradient-to-r from-brand-primary/80 to-cyan-400/80 shadow-[0_0_8px_rgba(59,130,246,0.5)]" style={`width: ${stage.load}%`}></div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="space-y-6">
          <!-- Metrics -->
          <div class="rounded-3xl border border-white/5 bg-white/[0.01] p-4 backdrop-blur-3xl sm:p-6">
            <p class="text-[10px] uppercase tracking-[0.4em] text-brand-accent font-black mb-6">{t('showcase.tool_preview.metrics.badge')}</p>
            <div class="space-y-5">
              {preset.metrics.map((metric) => (
                <div>
                  <div class="mb-2 flex items-center justify-between gap-3 text-[11px]">
                    <span class="min-w-0 text-slate-500 font-bold uppercase tracking-wider break-words">{metric.label}</span>
                    <span class="shrink-0 font-mono font-black text-white">{metric.value}</span>
                  </div>
                  <div class="h-2 overflow-hidden rounded-full bg-white/5">
                    <div class={`metric-bar h-full rounded-full metric-${metric.accent} shadow-lg`} style={`width: ${metric.strength}%`}></div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- Checkpoints -->
          <div class="rounded-3xl border border-white/5 bg-white/[0.01] p-4 backdrop-blur-3xl shadow-xl sm:p-6">
            <p class="text-[10px] uppercase tracking-[0.4em] text-brand-accent font-black mb-5">{t('showcase.tool_preview.review.badge')}</p>
            <div class="flex flex-wrap gap-2.5">
              {preset.checkpoints.map((item) => (
                <span class="rounded-xl border border-white/5 bg-white/[0.04] px-4 py-2.5 text-[11px] font-bold text-slate-400 transition-all hover:text-white hover:bg-white/10 hover:border-white/20 hover:scale-[1.02] cursor-default break-words">{item}</span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Right: Technical Profile -->
    <div class="flex flex-col gap-6">
      <div class="rounded-3xl border border-white/5 bg-white/[0.01] p-5 backdrop-blur-3xl shadow-2xl relative overflow-hidden flex-grow border-l-brand-primary/30 sm:p-8">
        <div class="absolute top-0 right-0 p-8 opacity-5 pointer-events-none">
          <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M9 12h6M12 9v6"/><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
        </div>
        
        <div class="space-y-10">
          <div>
            <p class="text-[10px] uppercase tracking-[0.4em] text-brand-accent font-black">{t('showcase.tool_preview.profile.badge')}</p>
            <p class="mt-5 text-base leading-relaxed text-slate-300 font-medium italic sm:mt-6 sm:text-lg">"{preset.summary}"</p>
          </div>

          <div class="pt-8 border-t border-white/10">
            <div class="mb-6 flex items-center justify-between">
              <h4 class="text-xs font-black text-white tracking-[0.2em] uppercase">{t('showcase.tool_preview.quick_specs.title')}</h4>
              <span class="rounded-full bg-brand-primary/10 px-2 py-0.5 text-[8px] font-black uppercase tracking-[0.2em] text-brand-primary border border-brand-primary/20">{t('showcase.tool_preview.quick_specs.status')}</span>
            </div>
            <div class="overflow-x-auto">
            <table class="w-full min-w-[260px] text-left">
              <tbody class="divide-y divide-white/5 border-t border-white/5">
                {preset.specs.map(([label, value]) => (
                  <tr class="group/spec transition-colors hover:bg-white/[0.02]">
                    <th class="py-4 pr-4 text-[10px] font-black uppercase tracking-[0.2em] text-slate-500 transition-colors group-hover/spec:text-brand-accent">{label}</th>
                    <td class="py-4 text-sm font-black text-white text-right break-words">{value}</td>
                  </tr>
                ))}
              </tbody>
            </table>
            </div>
          </div>

          <div class="rounded-2xl bg-gradient-to-br from-brand-primary/20 to-cyan-500/10 p-6 border border-brand-primary/20 shadow-xl overflow-hidden relative">
            <div class="relative z-10">
              <h4 class="text-sm font-black text-white tracking-wide uppercase">{t('showcase.tool_preview.cta.title')}</h4>
              <p class="mt-2 text-xs text-slate-400 font-medium leading-relaxed">
                {t('showcase.tool_preview.cta.body')}
              </p>
              <a href={ctaHref} class="mt-6 flex w-full items-center justify-center gap-2 rounded-xl bg-brand-primary py-3 text-xs font-black uppercase tracking-[0.15em] text-white transition hover:bg-blue-500 hover:scale-[1.02] shadow-[0_4px_20px_rgba(59,130,246,0.3)]">
                {ctaLabel || t('showcase.tool_preview.cta.button')}
                <svg class="h-3.5 w-3.5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .metric-bar {
    transition: width 1.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .metric-cyan { background-color: rgb(34 211 238); }
  .metric-blue { background-color: rgb(59 130 246); }
  .metric-emerald { background-color: rgb(52 211 153); }
  .metric-violet { background-color: rgb(139 92 246); }
  .metric-amber { background-color: rgb(251 191 36); }
  .metric-rose { background-color: rgb(244 63 94); }
  .metric-fuchsia { background-color: rgb(217 70 239); }
</style>
