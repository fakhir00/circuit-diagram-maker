---
// Abstract "Living Schematic" 3D Hero — Professional-grade spatial visualization of electronic symbols
---

<div class="hero-3d-container" id="hero-3d">
  <!-- Ambient depth gradients -->
  <div class="hero-ambient">
    <div class="ambient-orb ambient-orb-1"></div>
    <div class="ambient-orb ambient-orb-2"></div>
  </div>

  <!-- Perspective Scene -->
  <div class="hero-3d-scene">
    <div class="constellation-root" id="scene-root">
      
      <!-- Deep Background: Blueprint Grid -->
      <div class="layer blueprint-layer">
        <div class="blueprint-grid"></div>
      </div>

      <!-- Midground: Vector Connection Flow -->
      <svg class="layer connection-layer" viewBox="0 0 1000 600" preserveAspectRatio="xMidYMid slice">
        <defs>
          <filter id="neonGlow" x="-50%" y="-50%" width="200%" height="200%">
            <feGaussianBlur stdDeviation="3" result="blur"/>
            <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
          </filter>
        </defs>
        
        <!-- Abstract Signal Paths -->
        <g class="paths" id="signal-paths">
          <!-- Hand-crafted abstract paths -->
          <path d="M100,300 L250,300 L400,100 L600,100 L800,300" class="path-wire" />
          <path d="M100,450 L300,450 L500,250 L800,250" class="path-wire" />
          <path d="M150,150 L300,150 L450,350 L750,350 L900,150" class="path-wire" />
          
          <!-- Animated Signal Pulses -->
          <g filter="url(#neonGlow)">
             <circle r="3" class="pulse"><animateMotion dur="2.5s" repeatCount="indefinite" path="M100,300 L250,300 L400,100 L600,100 L800,300"/></circle>
             <circle r="4" class="pulse pulse-blue"><animateMotion dur="4s" repeatCount="indefinite" path="M100,450 L300,450 L500,250 L800,250"/></circle>
             <circle r="3" class="pulse pulse-cyan"><animateMotion dur="3s" repeatCount="indefinite" path="M150,150 L300,150 L450,350 L750,350 L900,150"/></circle>
          </g>
        </g>
      </svg>

      <!-- Foreground: Interactive Symbol Constellation -->
      <div class="layer symbol-layer">
        
        <!-- Symbol: Operational Amplifier -->
        <div class="symbol-node sym-opamp" style="--x:15%; --y:50%; --z:40px;">
          <svg viewBox="0 0 100 100" class="sym-svg">
             <path d="M20,20 L80,50 L20,80 Z" fill="none" stroke="currentColor" stroke-width="2"/>
             <path d="M25,35 L35,35 M30,30 L30,40" stroke="currentColor" stroke-width="2"/> <!-- + -->
             <path d="M25,65 L35,65" stroke="currentColor" stroke-width="2"/> <!-- - -->
             <circle cx="20" cy="35" r="4" fill="currentColor"/>
             <circle cx="20" cy="65" r="4" fill="currentColor"/>
             <circle cx="80" cy="50" r="4" fill="currentColor"/>
          </svg>
          <div class="sym-label text-blue-400">Signal Buffering</div>
        </div>

        <!-- Symbol: Resistor (IEC) -->
        <div class="symbol-node sym-resistor" style="--x:50%; --y:20%; --z:80px;">
          <svg viewBox="0 0 100 40" class="sym-svg">
            <rect x="25" y="10" width="50" height="20" rx="2" fill="none" stroke="currentColor" stroke-width="2"/>
            <path d="M0,20 L25,20 M75,20 L100,20" stroke="currentColor" stroke-width="2"/>
          </svg>
          <div class="sym-label text-cyan-400">Impedance Node</div>
        </div>

        <!-- Symbol: Logic Gate (AND) -->
        <div class="symbol-node sym-gate" style="--x:80%; --y:45%; --z:60px;">
           <svg viewBox="0 0 100 80" class="sym-svg">
             <path d="M20,10 L50,10 A30,30 0 0 1 50,70 L20,70 Z" fill="none" stroke="currentColor" stroke-width="2"/>
             <path d="M0,25 L20,25 M0,55 L20,55 M75,40 L100,40" stroke="currentColor" stroke-width="2"/>
           </svg>
           <div class="sym-label text-indigo-400">Logic Junction</div>
        </div>

        <!-- Symbol: Capacitor (Polarized) -->
        <div class="symbol-node sym-cap" style="--x:35%; --y:75%; --z:100px;">
           <svg viewBox="0 0 60 100" class="sym-svg">
             <path d="M10,40 L50,40 M10,60 L50,60" stroke="currentColor" stroke-width="3"/>
             <path d="M30,0 L30,40 M30,60 L30,100" stroke="currentColor" stroke-width="2"/>
             <path d="M40,25 L40,35 M35,30 L45,30" stroke="currentColor" stroke-width="1.5"/>
           </svg>
           <div class="sym-label text-emerald-400">Charge Storage</div>
        </div>

        <!-- Additional floating nodes -->
        <div class="abstract-node" style="--x:70%; --y:15%; --z:120px;"></div>
        <div class="abstract-node" style="--x:10%; --y:80%; --z:20px;"></div>
        <div class="abstract-node" style="--x:85%; --y:75%; --z:90px;"></div>

      </div>
    </div>
  </div>

  <!-- Enhanced UI Hint -->
  <div class="hero-hint">
    <div class="hint-dot"></div>
    <span>Interactive Galaxy • Drag to explore layers</span>
  </div>
</div>

<style>
  /* ========== SCENE CONTAINER ========== */
  .hero-3d-container {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 560px;
    background: radial-gradient(circle at 50% 50%, #0a1120 0%, #020617 100%);
    overflow: hidden;
    cursor: default;
    user-select: none;
  }

  .hero-ambient { position: absolute; inset: 0; pointer-events: none; z-index: 1; }
  .ambient-orb { position: absolute; filter: blur(120px); border-radius: 50%; opacity: 0.2; }
  .ambient-orb-1 { width: 400px; height: 400px; background: #3b82f6; top: -100px; left: -100px; }
  .ambient-orb-2 { width: 400px; height: 400px; background: #06b6d4; bottom: -100px; right: -100px; }

  /* ========== PERSPECTIVE ROOT ========== */
  .hero-3d-scene {
    position: absolute; inset: 0;
    perspective: 1200px;
    display: flex; align-items: center; justify-content: center;
    z-index: 2;
  }

  .constellation-root {
    width: 100%; height: 100%;
    position: relative;
    transform-style: preserve-3d;
    transition: transform 0.1s linear;
    will-change: transform;
  }

  .layer {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    transform-style: preserve-3d;
  }

  /* ========== BLUEPRINT LAYER ========== */
  .blueprint-layer { transform: translateZ(-150px); opacity: 0.15; }
  .blueprint-grid {
    width: 200%; height: 200%;
    background-image: radial-gradient(rgba(59,130,246,0.3) 1px, transparent 1px);
    background-size: 30px 30px;
    transform: rotateX(60deg);
  }

  /* ========== CONNECTION LAYER ========== */
  .connection-layer { transform: translateZ(20px); width: 100%; height: 100%; }
  .path-wire { 
    fill: none; stroke: rgba(59,130,246,0.3); stroke-width: 2.5; 
    stroke-dasharray: 4 6;
    filter: drop-shadow(0 0 4px rgba(59,130,246,0.2));
  }
  .pulse { fill: #fff; filter: drop-shadow(0 0 12px #fff); }
  .pulse-blue { fill: #60a5fa; filter: drop-shadow(0 0 12px #3b82f6); }
  .pulse-cyan { fill: #22d3ee; filter: drop-shadow(0 0 12px #06b6d4); }

  /* ========== SYMBOL NODES ========== */
  .symbol-layer { transform: translateZ(50px); }
  .symbol-node {
    position: absolute;
    left: var(--x); top: var(--y);
    transform: translate(-50%, -50%) translateZ(var(--z));
    display: flex; flex-direction: column; align-items: center;
    color: rgba(255,255,255,0.8);
    transition: all 0.4s cubic-bezier(0.34,1.56,0.64,1);
    filter: drop-shadow(0 0 4px rgba(59,130,246,0.1));
  }

  .symbol-node:hover {
    color: #fff;
    filter: drop-shadow(0 0 15px rgba(59,130,246,0.6));
    transform: translate(-50%, -50%) translateZ(calc(var(--z) + 30px)) scale(1.1);
  }

  .sym-svg { width: 64px; height: 64px; margin-bottom: 12px; transition: transform 0.3s; }
  .symbol-node:hover .sym-svg { transform: rotate(5deg); }
  
  .sym-label {
    font-size: 10px; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.15em; font-family: 'Inter', sans-serif;
    opacity: 0.4; transition: opacity 0.3s;
  }
  .symbol-node:hover .sym-label { opacity: 1; text-shadow: 0 0 8px currentColor; }

  /* Abstract floating nodes */
  .abstract-node {
    position: absolute; width: 6px; height: 6px;
    left: var(--x); top: var(--y);
    transform: translate(-50%, -50%) translateZ(var(--z));
    background: rgba(59,130,246,0.3); border-radius: 50%;
    box-shadow: 0 0 12px rgba(59,130,246,0.2);
    animation: nodFloating 6s ease-in-out infinite alternate;
  }
  @keyframes nodFloating { from { opacity: 0.2; } to { opacity: 0.6; } }

  /* ========== UI HINT ========== */
  .hero-hint {
    position: absolute; bottom: 32px; left: 50%; transform: translateX(-50%);
    display: flex; align-items: center; gap: 10px;
    padding: 8px 18px; background: rgba(0,0,0,0.4); backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.05); border-radius: 30px;
    z-index: 10;
  }
  .hint-dot { width: 6px; height: 6px; background: #3b82f6; border-radius: 50%; animation: pulse 2s infinite; }
  .hero-hint span { color: rgba(255,255,255,0.5); font-size: 11px; font-weight: 600; letter-spacing: 0.05em; }

  @keyframes pulse { 0% { transform: scale(1); opacity: 1; } 100% { transform: scale(3); opacity: 0; } }

  @media (max-width: 768px) {
    .sym-svg { width: 48px; height: 48px; }
    .hero-hint { display: none; }
    .blueprint-grid { display: none; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const container = document.getElementById('hero-3d');
    const root = document.getElementById('scene-root');
    if (!container || !root) return;

    let rotX = 10, rotY = 0;
    let tRotX = 10, tRotY = 0;

    container.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = container.getBoundingClientRect();
      const x = (e.clientX - rect.left) / rect.width - 0.5;
      const y = (e.clientY - rect.top) / rect.height - 0.5;

      tRotY = x * 20; // Max 10 deg either side
      tRotX = 10 - (y * 15); // Shift perspective
    });

    // Inertia loop
    const loop = () => {
      rotX += (tRotX - rotX) * 0.08;
      rotY += (tRotY - rotY) * 0.08;
      root.style.transform = `rotateX(${rotX}deg) rotateY(${rotY}deg)`;
      requestAnimationFrame(loop);
    };
    loop();

    // Reset rotation on mobile
    window.addEventListener('resize', () => {
      if (window.innerWidth < 768) { tRotX = 0; tRotY = 0; }
      else { tRotX = 10; tRotY = 0; }
    });
  });
</script>
