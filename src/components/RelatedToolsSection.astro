---
import { getLocalizedPath } from '../theme/i18n';

interface ToolCard {
  key: string;
  title: string;
  description: string;
  href: string;
}

interface Props {
  locale: string;
  excludeKeys?: string[];
  title?: string;
  description?: string;
}

const {
  locale,
  excludeKeys = [],
  title = 'Related Tools',
  description = 'Explore these dedicated tool pages to continue your workflow with logic, Arduino, PCB, and conversion-focused diagram setups.'
} = Astro.props;

const cards: ToolCard[] = [
  {
    key: 'logic-gate-diagram-tool',
    title: 'Logic Gate Diagram Tool',
    href: getLocalizedPath('/logic-gate-diagram-tool/', locale),
    description: 'Build clear gate-level logic diagrams and validate signal flow.'
  },
  {
    key: 'arduino-circuit-maker',
    title: 'Arduino Circuit Maker',
    href: getLocalizedPath('/arduino-circuit-maker/', locale),
    description: 'Document board pin connections, modules, and wiring paths quickly.'
  },
  {
    key: 'pcb-schematic-tool',
    title: 'PCB Schematic Tool',
    href: getLocalizedPath('/pcb-schematic-tool/', locale),
    description: 'Draft production-ready schematic structures before PCB layout.'
  },
  {
    key: 'schematic-to-breadboard',
    title: 'Schematic To Breadboard',
    href: getLocalizedPath('/schematic-to-breadboard/', locale),
    description: 'Convert schematic planning into clean breadboard placement and wiring guidance.'
  },
  {
    key: 'truth-table-to-logic-circuit',
    title: 'Truth Table To Logic Circuit',
    href: getLocalizedPath('/truth-table-to-logic-circuit/', locale),
    description: 'Generate gate-level logic from truth-table behavior for quick validation and learning.'
  }
].filter((card) => !excludeKeys.includes(card.key));
---

<section class="border-t border-white/5 bg-bg-panel py-14 sm:py-16">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <h2 class="text-2xl font-bold tracking-tight text-white sm:text-3xl">{title}</h2>
    <p class="mt-3 max-w-3xl text-slate-400">{description}</p>
    <div class="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {cards.map((card) => (
        <article class="rounded-2xl border border-white/10 bg-bg-surface/70 p-5 transition-colors hover:border-brand-primary/30 hover:bg-bg-surface">
          <h3 class="text-lg font-semibold text-white">{card.title}</h3>
          <p class="mt-2 text-sm leading-8 text-slate-400">{card.description}</p>
          <a href={card.href} class="mt-4 inline-flex rounded-xl bg-brand-primary px-5 py-3 text-sm font-semibold text-white transition hover:bg-blue-500">
            Open Tool
          </a>
        </article>
      ))}
    </div>
  </div>
</section>
