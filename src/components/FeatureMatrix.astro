---
interface Props {
  title: string;
  headers: string[];
  rows: string[][];
}

const { title, headers, rows } = Astro.props;
---

<section class="py-24 bg-bg-panel border-t border-white/5 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl font-bold text-white tracking-tight">{title}</h2>
    </div>

    <div class="overflow-x-auto rounded-2xl border border-white/10 shadow-2xl bg-bg-surface/50 backdrop-blur-sm">
      <table class="w-full text-left border-collapse">
        <thead class="bg-bg-panel/80 border-b border-white/10">
          <tr>
            {headers.map((header) => (
              <th class="px-6 py-4 text-sm font-semibold text-slate-300 uppercase tracking-wider">{header}</th>
            ))}
          </tr>
        </thead>
        <tbody class="divide-y divide-white/5">
          {rows.map((row, index) => (
            <tr class="hover:bg-white/5 transition-colors group">
              {row.map((cell, colIndex) => (
                <td class={`px-6 py-4 text-sm ${colIndex === 0 ? 'text-white font-medium' : 'text-slate-400'} group-hover:text-white transition-colors`}>
                  {cell.toLowerCase() === 'yes' ? (
                    <svg class="h-5 w-5 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  ) : cell.toLowerCase() === 'no' ? (
                    <svg class="h-5 w-5 text-red-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
                  ) : cell}
                </td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>
