---
import { getLocalizedPath, useTranslations } from '../theme/i18n';

interface Props {
  locale: string;
  config: any;
}

const { locale, config } = Astro.props;
const t = useTranslations(locale);
const year = new Date().getFullYear();
const currentPath = Astro.url.pathname;
---

<footer class="bg-bg-panel border-t border-white/5 mt-auto">
  <div class="max-w-7xl mx-auto py-16 px-4 sm:px-6 lg:px-8">
    
    <!-- Main Footer Grid -->
    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-4">

      <!-- Brand & Tagline -->
      <div class="lg:col-span-1">
        <a href={getLocalizedPath('/', locale)} class="flex items-center gap-2 mb-4">
          <svg class="text-brand-primary w-5 h-5 filter drop-shadow-[0_0_6px_rgba(59,130,246,0.4)]" viewBox="0 0 24 24" fill="none">
            <path d="M4 12h3l2-5 3 10 2-5h3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="4" cy="12" r="1.5" fill="currentColor"/>
            <circle cx="17" cy="12" r="1.5" fill="currentColor"/>
          </svg>
          <span class="font-bold text-base tracking-tight bg-gradient-to-br from-white to-slate-400 bg-clip-text text-transparent">
            {config.site.name}
          </span>
        </a>
        <p class="text-slate-500 text-sm leading-relaxed mb-4">
          The free circuit diagram maker for students, engineers, hobbyists, and educators. Create professional schematics in your browser — no downloads required.
        </p>
        <p class="text-slate-600 text-xs">
          &copy; {year} {config.site.name}. All rights reserved.
        </p>
      </div>

      <!-- Product Links -->
      <div>
        <h3 class="text-xs font-bold uppercase tracking-[0.3em] text-slate-400 mb-4">Product</h3>
        <ul class="space-y-2.5">
          <li><a href={getLocalizedPath('/editor/', locale)} class="text-sm text-slate-400 hover:text-brand-primary transition-colors">Open Circuit Diagram Editor</a></li>
          <li><a href={getLocalizedPath('/components/', locale)} class="text-sm text-slate-400 hover:text-brand-primary transition-colors">Component Library</a></li>
          <li><a href={getLocalizedPath('/docs/', locale)} class="text-sm text-slate-400 hover:text-brand-primary transition-colors">Documentation</a></li>
          <li><a href="/blog/" class="text-sm text-slate-400 hover:text-brand-primary transition-colors">Blog & Tutorials</a></li>
        </ul>
      </div>

      <!-- Popular Articles -->
      <div>
        <h3 class="text-xs font-bold uppercase tracking-[0.3em] text-slate-400 mb-4">Popular Guides</h3>
        <ul class="space-y-2.5">
          <li><a href="/blog/ultimate-guide-circuit-diagrams/" class="text-sm text-slate-400 hover:text-brand-primary transition-colors">Ultimate Guide to Circuit Diagrams</a></li>
          <li><a href="/blog/circuit-diagram-symbols-explained/" class="text-sm text-slate-400 hover:text-brand-primary transition-colors">Circuit Diagram Symbols Explained</a></li>
          <li><a href="/blog/how-to-make-circuit-diagram-online/" class="text-sm text-slate-400 hover:text-brand-primary transition-colors">How to Make a Circuit Diagram Online</a></li>
          <li><a href="/blog/circuit-diagram-for-beginners/" class="text-sm text-slate-400 hover:text-brand-primary transition-colors">Circuit Diagrams for Beginners</a></li>
        </ul>
      </div>

      <!-- Legal & Social -->
      <div>
        <h3 class="text-xs font-bold uppercase tracking-[0.3em] text-slate-400 mb-4">Company</h3>
        <ul class="space-y-2.5">
          <li><a href={getLocalizedPath('/about-us/', locale)} class="text-sm text-slate-400 hover:text-brand-primary transition-colors">About Us</a></li>
          <li><a href={getLocalizedPath('/contact-us/', locale)} class="text-sm text-slate-400 hover:text-brand-primary transition-colors">Contact Support</a></li>
          {config.footer.map((item: any) => (
            <li><a href={getLocalizedPath(item.path, locale)} class="text-sm text-slate-400 hover:text-brand-primary transition-colors">{t(item.labelKey)}</a></li>
          ))}
        </ul>

        <!-- Social Icons -->
        <div class="flex gap-3 mt-5">
          {config.social.twitter && (
            <a href={config.social.twitter} target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-full bg-white/5 flex items-center justify-center text-slate-400 hover:bg-brand-primary/10 hover:text-brand-primary transition-all border border-white/5" aria-label="Twitter">
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M8.29 20.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0022 5.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.072 4.072 0 012.8 9.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 012 18.407a11.616 11.616 0 006.29 1.84"/></svg>
            </a>
          )}
          {config.social.facebook && (
            <a href={config.social.facebook} target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-full bg-white/5 flex items-center justify-center text-slate-400 hover:bg-brand-primary/10 hover:text-brand-primary transition-all border border-white/5" aria-label="Facebook">
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd"/></svg>
            </a>
          )}
        </div>
      </div>
    </div>

    <!-- Locale Switcher -->
    <div class="mt-10 pt-6 border-t border-white/5 flex flex-wrap items-center justify-between gap-4">
      <div class="flex flex-wrap gap-2">
        {['en', 'es', 'hi', 'fr', 'de', 'ar'].map((l) => (
          <a 
            href={getLocalizedPath(currentPath, l)} 
            class={`text-[10px] uppercase font-bold px-2 py-1 rounded border transition-all ${locale === l ? 'bg-brand-primary/10 border-brand-primary/50 text-brand-primary' : 'bg-transparent border-white/5 text-slate-500 hover:border-white/20 hover:text-slate-300'}`}
          >
            {l}
          </a>
        ))}
        <a href="/sitemap/" class="text-[10px] uppercase font-bold px-2 py-1 rounded border bg-transparent border-white/5 text-slate-500 hover:border-white/20 hover:text-slate-300">More</a>
      </div>
      <div class="text-[10px] text-slate-600 uppercase font-bold tracking-widest leading-none">
        Status: <span class="text-green-500/80">Operational</span>
      </div>
    </div>
  </div>
</footer>
