---
import { getLocalizedPath, useTranslations } from '../theme/i18n';

interface Props {
  locale: string;
  config: any;
}

const { locale, config } = Astro.props;
const t = useTranslations(locale);
const year = new Date().getFullYear();

type ProductLink = {
  labelKey: string;
  path: string;
};

const navItems = Array.isArray(config?.nav) ? config.nav : [];
const moreToolsGroup = navItems.find(
  (item: any) => item?.labelKey === 'nav.more_tools' && Array.isArray(item?.children)
) ?? navItems.find((item: any) => Array.isArray(item?.children));

const toolLinks: ProductLink[] = Array.isArray(moreToolsGroup?.children)
  ? moreToolsGroup.children.filter(
      (item: any): item is ProductLink =>
        typeof item?.labelKey === 'string' && typeof item?.path === 'string'
    )
  : [];

const productLinks: ProductLink[] = [
  { labelKey: 'nav.editor', path: '/editor/' },
  ...toolLinks
];
---

<footer class="bg-bg-panel border-t border-white/5 mt-auto">
  <div class="max-w-7xl mx-auto py-16 px-4 sm:px-6 lg:px-8">
    
    <!-- Main Footer Grid -->
    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-4">

      <!-- Brand & Tagline -->
      <div class="lg:col-span-1">
        <a href={getLocalizedPath('/', locale)} class="flex items-center gap-3 mb-6 group">
          <div class="relative flex items-center justify-center">
            <svg class="w-7 h-7 transform transition-all duration-500 group-hover:rotate-12 group-hover:scale-110" viewBox="0 0 40 40" fill="none">
              <defs>
                <linearGradient id="logoGradFooter" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" style="stop-color:var(--color-brand-primary);stop-opacity:1" />
                  <stop offset="100%" style="stop-color:var(--color-brand-secondary);stop-opacity:1" />
                </linearGradient>
              </defs>
              <path d="M20,2 L36,11 L36,29 L20,38 L4,29 L4,11 Z" 
                    fill="none" stroke="url(#logoGradFooter)" stroke-width="2.5" stroke-linejoin="round"
                    class="opacity-40 group-hover:opacity-100 transition-opacity" />
              <circle cx="20" cy="20" r="5" fill="url(#logoGradFooter)" />
              <path d="M10,14 L20,20 L30,14 M20,20 L20,32" 
                    stroke="url(#logoGradFooter)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </div>
          <div class="flex flex-col leading-none">
            <span class="font-black text-sm tracking-tight text-white group-hover:text-brand-primary transition-colors uppercase">
              {t('brand.name').split(' ').map((word: string, i: number) => (
                <span class={i === 1 ? 'text-slate-500' : i === 2 ? 'ml-0.5 text-slate-600' : ''}>{word}</span>
              ))}
            </span>
          </div>
        </a>
        <p class="text-slate-500 text-sm leading-relaxed mb-4">
          {t('footer.tagline')}
        </p>

        <div class="mb-6 flex flex-col gap-2.5">
          <a href="mailto:support@circuitdiagrammaker.com" class="text-sm text-slate-400 hover:text-brand-primary transition-colors flex items-center gap-3 group/link">
            <div class="w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center border border-white/10 group-hover/link:border-brand-primary/30 group-hover/link:bg-brand-primary/5 transition-all">
              <svg class="w-4 h-4 text-slate-500 group-hover/link:text-brand-primary transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <span class="group-hover/link:translate-x-0.5 transition-transform">support@circuitdiagrammaker.com</span>
          </a>
          <a href="tel:+15550000000" class="text-sm text-slate-400 hover:text-brand-primary transition-colors flex items-center gap-3 group/link">
            <div class="w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center border border-white/10 group-hover/link:border-brand-primary/30 group-hover/link:bg-brand-primary/5 transition-all">
              <svg class="w-4 h-4 text-slate-500 group-hover/link:text-brand-primary transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
            </div>
            <span class="group-hover/link:translate-x-0.5 transition-transform">+1 (555) 000-0000</span>
          </a>
        </div>

        <p class="text-slate-600 text-xs">
          &copy; {year} {config.site.name}. All rights reserved.
        </p>
      </div>

      <!-- Product Links -->
      <div>
        <h3 class="text-xs font-bold uppercase tracking-[0.3em] text-slate-400 mb-4">{t('footer.product')}</h3>
        <ul class="space-y-2.5">
          {productLinks.map((link) => (
            <li>
              <a href={getLocalizedPath(link.path, locale)} class="text-sm text-slate-400 hover:text-brand-primary transition-colors">
                {t(link.labelKey)}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Popular Articles -->
      <div>
        <h3 class="text-xs font-bold uppercase tracking-[0.3em] text-slate-400 mb-4">{t('footer.guides')}</h3>
        <ul class="space-y-2.5">
          <li><a href={getLocalizedPath('/components/', locale)} class="text-sm text-slate-400 hover:text-brand-primary transition-colors">Components</a></li>
          <li><a href={getLocalizedPath('/docs/', locale)} class="text-sm text-slate-400 hover:text-brand-primary transition-colors">Documentation</a></li>
          <li><a href={getLocalizedPath('/blog/', locale)} class="text-sm text-slate-400 hover:text-brand-primary transition-colors">Blog & Tutorials</a></li>
          <li><a href={getLocalizedPath('/sitemap/', locale)} class="text-sm text-slate-400 hover:text-brand-primary transition-colors">Sitemap</a></li>
        </ul>
      </div>

      <!-- Legal & Social -->
      <div>
        <h3 class="text-xs font-bold uppercase tracking-[0.3em] text-slate-400 mb-4">{t('footer.company')}</h3>
        <ul class="space-y-2.5">
          <li><a href={getLocalizedPath('/about-us/', locale)} class="text-sm text-slate-400 hover:text-brand-primary transition-colors">About Us</a></li>
          <li><a href={getLocalizedPath('/contact-us/', locale)} class="text-sm text-slate-400 hover:text-brand-primary transition-colors">Contact Support</a></li>
          <li><a href={getLocalizedPath('/terms/', locale)} class="text-sm text-slate-400 hover:text-brand-primary transition-colors">Terms of Service</a></li>
          <li><a href={getLocalizedPath('/privacy/', locale)} class="text-sm text-slate-400 hover:text-brand-primary transition-colors">Privacy Policy</a></li>
        </ul>

        <!-- Social Icons -->
        <div class="flex gap-3 mt-5">
          {config.social.twitter && (
            <a href={config.social.twitter} target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-full bg-white/5 flex items-center justify-center text-slate-400 hover:bg-brand-primary/10 hover:text-brand-primary transition-all border border-white/5" aria-label="Twitter">
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M8.29 20.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0022 5.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.072 4.072 0 012.8 9.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 012 18.407a11.616 11.616 0 006.29 1.84"/></svg>
            </a>
          )}
          {config.social.facebook && (
            <a href={config.social.facebook} target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-full bg-white/5 flex items-center justify-center text-slate-400 hover:bg-brand-primary/10 hover:text-brand-primary transition-all border border-white/5" aria-label="Facebook">
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd"/></svg>
            </a>
          )}
          {config.social.linkedin && (
            <a href={config.social.linkedin} target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-full bg-white/5 flex items-center justify-center text-slate-400 hover:bg-brand-primary/10 hover:text-brand-primary transition-all border border-white/5" aria-label="LinkedIn">
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
          )}
        </div>
      </div>
    </div>

    <!-- Footer Meta -->
    <div class="mt-10 pt-6 border-t border-white/5 flex flex-wrap items-center justify-end gap-4">
      <div class="text-[10px] text-slate-600 uppercase font-bold tracking-widest leading-none flex items-center gap-2">
        {t('footer.status')}: <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
        </span> <span class="text-emerald-500/80">{t('footer.operational')}</span>
      </div>
    </div>
  </div>
</footer>
