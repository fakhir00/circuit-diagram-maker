---
interface Props {
  title: string;
  type: 'opamp' | 'logic' | 'transistor';
}

const { title, type } = Astro.props;
---

<div class="interactive-diagram-container my-12 border border-white/5 bg-bg-panel/50 rounded-2xl overflow-hidden shadow-2xl backdrop-blur-sm group hover:border-brand-primary/20 transition-all duration-500 relative">
  <div class="p-4 border-b border-white/5 bg-gradient-to-r from-brand-primary/5 to-transparent flex items-center justify-between">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 rounded-lg bg-brand-primary/10 flex items-center justify-center text-brand-primary">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M2 12h20M12 12l8-8M12 12l-8 8"/></svg>
      </div>
      <h3 class="text-sm font-bold text-white m-0 tracking-tight">{title}</h3>
    </div>
    <div class="flex gap-1.5">
      <div class="w-1.5 h-1.5 rounded-full bg-red-500/40"></div>
      <div class="w-1.5 h-1.5 rounded-full bg-amber-500/40"></div>
      <div class="w-1.5 h-1.5 rounded-full bg-emerald-500/40"></div>
    </div>
  </div>

  <div class="p-8 flex items-center justify-center min-h-[320px] bg-grid-pattern relative">
    <div class="absolute inset-0 bg-radial-gradient from-brand-primary/5 to-transparent opacity-50"></div>
    
    <div class="relative z-10 transition-transform duration-700 group-hover:scale-105">
      {type === 'opamp' && (
        <svg width="240" height="160" viewBox="0 0 240 160" class="drop-shadow-[0_0_15px_rgba(59,130,246,0.3)]">
          <!-- Main triangle -->
          <path d="M40,20 L40,140 L200,80 Z" 
                class="fill-brand-primary/10 stroke-brand-primary stroke-[3] transition-all duration-500 group-hover:fill-brand-primary/20" />
          
          <!-- Inputs -->
          <line x1="0" y1="50" x2="40" y2="50" class="stroke-slate-500 stroke-[2] dash-anim" />
          <line x1="0" y1="110" x2="40" y2="110" class="stroke-slate-500 stroke-[2] dash-anim" />
          
          <!-- Symbols -->
          <text x="50" y="55" class="fill-slate-400 font-bold text-xl select-none" text-anchor="middle">-</text>
          <text x="50" y="115" class="fill-slate-400 font-bold text-xl select-none" text-anchor="middle">+</text>
          
          <!-- Rails -->
          <line x1="100" y1="0" x2="100" y2="42" class="stroke-slate-500 stroke-[2] opacity-40" />
          <text x="100" y="-5" class="fill-slate-500 font-mono text-[10px] uppercase tracking-tighter" text-anchor="middle">VCC</text>
          <line x1="100" y1="118" x2="100" y2="160" class="stroke-slate-500 stroke-[2] opacity-40" />
          <text x="100" y="172" class="fill-slate-500 font-mono text-[10px] uppercase tracking-tighter" text-anchor="middle">VEE/GND</text>
          
          <!-- Output -->
          <line x1="200" y1="80" x2="240" y2="80" class="stroke-slate-500 stroke-[2] dash-anim" />
          
          <!-- Tooltip trigger points -->
          <circle cx="20" cy="50" r="4" class="fill-brand-accent animate-pulse cursor-pointer hover:r-6 transition-all" />
          <circle cx="20" cy="110" r="4" class="fill-brand-accent animate-pulse cursor-pointer hover:r-6 transition-all" />
          <circle cx="220" cy="80" r="4" class="fill-brand-primary animate-pulse cursor-pointer hover:r-6 transition-all" />
        </svg>
      )}

      {type === 'logic' && (
        <svg width="240" height="160" viewBox="0 0 240 160" class="drop-shadow-[0_0_15px_rgba(22,163,74,0.3)]">
          <!-- AND gate shape -->
          <path d="M40,30 L100,30 C140,30 180,50 180,80 C180,110 140,130 100,130 L40,130 Z" 
                class="fill-emerald-500/10 stroke-emerald-500 stroke-[3] transition-all duration-500 group-hover:fill-emerald-500/20" />
          
          <!-- Inputs -->
          <line x1="0" y1="55" x2="40" y2="55" class="stroke-slate-500 stroke-[2]" />
          <line x1="0" y1="105" x2="40" y2="105" class="stroke-slate-500 stroke-[2]" />
          
          <!-- Output -->
          <line x1="180" y1="80" x2="240" y2="80" class="stroke-slate-500 stroke-[2]" />
          
          <text x="110" y="88" class="fill-slate-400 font-black text-3xl select-none uppercase tracking-tighter" text-anchor="middle">AND</text>
        </svg>
      )}

      {type === 'transistor' && (
        <svg width="240" height="160" viewBox="0 0 240 160" class="drop-shadow-[0_0_15px_rgba(234,179,8,0.3)]">
          <!-- Vertical bar -->
          <line x1="100" y1="40" x2="100" y2="120" class="stroke-amber-500 stroke-[4]" />
          <!-- Base -->
          <line x1="60" y1="80" x2="100" y2="80" class="stroke-slate-500 stroke-[2]" />
          <!-- Collector -->
          <line x1="100" y1="50" x2="140" y2="20" class="stroke-slate-500 stroke-[2]" />
          <!-- Emitter -->
          <line x1="100" y1="110" x2="140" y2="140" class="stroke-slate-500 stroke-[2]" />
          <!-- Arrow -->
          <path d="M125,128 L140,140 L120,140" class="fill-amber-500 stroke-none" />
          
          <text x="60" y="72" class="fill-amber-500 font-bold text-xs uppercase" text-anchor="middle">B</text>
          <text x="145" y="25" class="fill-slate-400 font-bold text-xs uppercase" text-anchor="start">C</text>
          <text x="145" y="145" class="fill-slate-400 font-bold text-xs uppercase" text-anchor="start">E</text>
        </svg>
      )}
    </div>
  </div>

  <div class="px-6 py-4 bg-white/5 flex items-center justify-between border-t border-white/5">
    <div class="flex flex-col">
      <span class="text-[10px] font-bold text-slate-500 uppercase tracking-widest leading-none mb-1">Visualization Layer</span>
      <span class="text-xs text-slate-400 font-medium leading-none">Interactive Semantic Node Map</span>
    </div>
    <div class="h-8 w-[1px] bg-white/10 mx-4"></div>
    <button class="px-4 py-1.5 rounded-lg bg-brand-primary/10 border border-brand-primary/20 text-brand-primary text-[10px] font-bold uppercase transition-all hover:bg-brand-primary/20 hover:scale-105">
      Open in Editor
    </button>
  </div>
</div>

<style>
  .bg-grid-pattern {
    background-image: radial-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px);
    background-size: 20px 20px;
  }
  
  .dash-anim {
    stroke-dasharray: 8;
    animation: dashOffset 10s linear infinite;
  }
  
  @keyframes dashOffset {
    to { stroke-dashoffset: -100; }
  }
</style>
