                  <p class="text-[10px] uppercase tracking-[0.4em] text-brand-accent font-bold">Technical Profile</p>
                  <p id="showcase-summary" class="mt-4 text-sm leading-7 text-slate-400 font-medium italic">"{presets[0].summary}"</p>
                </div>

                <div class="pt-6 border-t border-white/5">
                  <div class="mb-4 flex items-center justify-between">
                    <h4 class="text-sm font-bold text-white tracking-wide">Quick Reference Specs</h4>
                    <span class="text-[9px] font-bold uppercase tracking-[0.2em] text-slate-600">Auto-updates</span>
                  </div>
