                    <path id="p5" d="M358 118V210H626V150" stroke="#fb7185" stroke-width="6" stroke-linecap="round" filter="url(#wireGlow)" />
                    <circle r="4" fill="#fb7185" filter="url(#currentGlow)"><animateMotion dur="2.5s" repeatCount="indefinite" path="M358 118V210H626V150" /></circle>

                    <path d="M430 210V256" stroke="#38bdf8" stroke-width="6" stroke-linecap="round" filter="url(#wireGlow)" />
                    <path d="M402 256H458" stroke="#38bdf8" stroke-width="4" stroke-linecap="round" />
                    <path d="M412 274H448" stroke="#38bdf8" stroke-width="4" stroke-linecap="round" />
                    <path d="M420 292H440" stroke="#38bdf8" stroke-width="4" stroke-linecap="round" />
                    <text x="86" y="96" fill="#cbd5e1" font-size="16" font-family="sans-serif" font-weight="bold">VIN</text>
                    <text x="596" y="70" fill="#cbd5e1" font-size="16" font-family="sans-serif" font-weight="bold">3.3V</text>
                  </g>

                  <g data-diagram="logic" class="hidden" transform="translate(30, 40)">
                  <rect x="118" y="94" width="124" height="80" rx="18" fill="#111827" stroke="#a78bfa" stroke-width="3" />
                  <text x="180" y="128" text-anchor="middle" fill="#f8fafc" font-size="18" font-family="sans-serif" font-weight="bold">SENSOR</text>
                  <path id="l1" d="M242 118H336" stroke="#c084fc" stroke-width="4" stroke-linecap="round" />
                  <circle r="4" fill="#a78bfa" filter="url(#currentGlow)"><animateMotion dur="1.2s" repeatCount="indefinite" path="M242 118H336" /></circle>

                  <rect x="336" y="72" width="132" height="132" rx="24" fill="#111827" stroke="#38bdf8" stroke-width="3" />
                  <text x="402" y="128" text-anchor="middle" fill="#f8fafc" font-size="18" font-family="sans-serif" font-weight="bold">MCU</text>
                  
                  <path id="l2" d="M468 104H570" stroke="#38bdf8" stroke-width="4" stroke-linecap="round" />
