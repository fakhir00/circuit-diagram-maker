---
import { toolPresets } from '../data/toolPresets';
import { getLocalizedPath, useTranslations } from '../theme/i18n';
import DiagramCanvas from './DiagramCanvas.astro';

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

// Filter for the tools the user decided to keep on the home showcase
const showcaseIds = ['logic', 'audio', 'gates', 'pcb_tool'];
const presets = toolPresets
  .filter((preset) => showcaseIds.includes(preset.id))
  .map((preset) => {
    const translatedPreset = t(`showcase.presets.${preset.id}`);
    return translatedPreset && typeof translatedPreset === 'object'
      ? { ...preset, ...translatedPreset }
      : preset;
  });
---

<section class="overflow-hidden border-t border-white/5 bg-bg-dark py-20 sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto mb-10 max-w-3xl text-center sm:mb-14">
      <p class="mb-4 break-words text-xs font-semibold uppercase tracking-[0.24em] text-brand-accent sm:text-sm sm:tracking-[0.35em]">{t('showcase.badge')}</p>
      <h2 class="break-words text-3xl font-bold tracking-tight text-white sm:text-4xl">{t('showcase.title')}</h2>
      <p class="mt-4 break-words text-base leading-relaxed text-slate-400 sm:text-lg">
        {t('showcase.description')}
      </p>
    </div>

    <div class="grid gap-8 lg:grid-cols-[280px_minmax(0,1fr)]" data-showcase-root>
      <aside class="rounded-3xl border border-white/10 bg-bg-panel p-3 lg:p-4">
        <div class="flex flex-col gap-2 pb-0 sm:flex-row sm:overflow-x-auto sm:pb-2 lg:flex-col lg:overflow-x-visible lg:pb-0 sm:scrollbar-hide sm:snap-x">
          {presets.map((preset, index) => (
              <button
                type="button"
                class={`showcase-tab w-full min-w-0 rounded-2xl border px-4 py-4 text-left transition sm:w-[240px] sm:shrink-0 sm:snap-start lg:w-full ${
                  index === 0
                    ? 'border-brand-primary bg-brand-primary/10 text-white shadow-[0_0_20px_rgba(59,130,246,0.16)]'
                    : 'border-white/10 bg-white/0 text-slate-300 hover:border-white/20 hover:bg-white/5'
                }`}
                data-preset-button
                data-preset={preset.id}
                aria-pressed={index === 0 ? 'true' : 'false'}
              >
              <span class="block break-words text-[11px] font-semibold uppercase tracking-[0.2em] text-brand-accent/90 sm:text-sm sm:tracking-[0.25em]">{preset.label}</span>
              <span class="mt-2 block break-words text-base font-semibold sm:text-lg">{preset.title}</span>
              <span class="mt-2 block break-words text-sm leading-6 text-slate-400">{preset.summary}</span>
            </button>
          ))}
        </div>
      </aside>

      <div class="relative overflow-hidden rounded-[2rem] border border-white/5 bg-[#080c14] p-3 shadow-2xl group/canvas sm:p-6">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_70%_30%,rgba(59,130,246,0.03),transparent_50%)] pointer-events-none"></div>
        <div class="relative grid gap-6 lg:grid-cols-[minmax(0,1fr)_360px] lg:gap-8">
          <div class="flex min-w-0 flex-col gap-6">
            <div class="relative overflow-hidden rounded-[1.25rem] border border-white/5 bg-[#05080f] p-3 sm:p-4">
              <div class="mb-4 flex flex-col gap-3 border-b border-white/5 pb-3 sm:flex-row sm:items-center sm:justify-between">
                <div class="min-w-0">
                  <p class="text-[10px] uppercase tracking-[0.4em] text-slate-600 font-bold">{t('showcase.canvas.label')}</p>
                  <h3 id="showcase-title" class="mt-1 break-words text-base font-bold tracking-tight text-white sm:text-lg">{presets[0].title}</h3>
                </div>
                <div class="max-w-full self-start rounded-full border border-emerald-400/20 bg-emerald-400/5 px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-[0.16em] text-emerald-400/90 sm:tracking-[0.2em]">
                  {t('showcase.live_preset')}
                </div>
              </div>

              <div class="relative aspect-[4/3] overflow-hidden rounded-xl border border-white/5 bg-[radial-gradient(circle_at_top,rgba(59,130,246,0.12),transparent_40%),#020617] sm:aspect-[16/10]">
                <div id="diagram-container">
                  <DiagramCanvas showAll showcaseIds={showcaseIds} />
                </div>
              </div>
            </div>

            <div class="grid gap-6 xl:grid-cols-2">
              <div class="rounded-2xl border border-white/5 bg-white/[0.01] p-5 backdrop-blur-3xl">
                <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                  <div class="min-w-0">
                    <p class="text-[10px] uppercase tracking-[0.4em] text-brand-accent font-bold">{t('showcase.breakdown.badge')}</p>
                    <h4 class="mt-1 break-words text-base font-semibold text-white">{t('showcase.breakdown.title')}</h4>
                  </div>
                  <div class="self-start rounded-full border border-white/5 bg-white/5 px-2 py-0.5 text-[9px] font-bold uppercase tracking-[0.2em] text-slate-500">
                    {t('showcase.breakdown.status')}
                  </div>
                </div>
                <div id="showcase-stages" class="mt-6 space-y-3">
                  {presets[0].stages.map((stage: any) => (
                    <div class="rounded-xl border border-white/5 bg-white/[0.02] p-3.5 transition-colors hover:bg-white/[0.04]">
                      <div class="flex items-start justify-between gap-4">
                        <div class="min-w-0">
                          <p class="break-words text-xs font-bold tracking-wide text-white">{stage.name}</p>
                          <p class="mt-0.5 break-words text-[11px] leading-relaxed text-slate-500">{stage.detail}</p>
                        </div>
                        <span class="shrink-0 text-[11px] font-mono text-brand-accent">{stage.load}%</span>
                      </div>
                      <div class="mt-2.5 h-1.5 overflow-hidden rounded-full bg-white/5">
                        <div class="h-full rounded-full bg-gradient-to-r from-brand-primary/80 to-cyan-400/80" style={`width: ${stage.load}%`}></div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>

              <div class="space-y-6">
                <div class="rounded-2xl border border-white/5 bg-white/[0.01] p-5 backdrop-blur-3xl">
                  <p class="text-[10px] uppercase tracking-[0.4em] text-brand-accent font-bold">{t('showcase.metrics.badge')}</p>
                  <div id="showcase-metrics" class="mt-5 space-y-4">
                    {presets[0].metrics.map((metric: any) => (
                      <div>
                        <div class="mb-1.5 flex items-start justify-between gap-3 text-[11px]">
                          <span class="min-w-0 break-words text-slate-400 font-medium">{metric.label}</span>
                          <span class="shrink-0 font-mono text-white">{metric.value}</span>
                        </div>
                        <div class="h-1.5 overflow-hidden rounded-full bg-white/5">
                          <div class={`metric-bar h-full rounded-full metric-${metric.accent}`} style={`width: ${metric.strength}%`}></div>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>

                <div class="rounded-2xl border border-white/5 bg-white/[0.01] p-5 backdrop-blur-3xl">
                  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                    <p class="text-[10px] uppercase tracking-[0.4em] text-brand-accent font-bold">{t('showcase.checkpoints.badge')}</p>
                    <span class="self-start text-[9px] font-bold uppercase tracking-[0.2em] text-slate-600">{t('showcase.checkpoints.status')}</span>
                  </div>
                  <div id="showcase-checkpoints" class="mt-5 flex flex-wrap gap-2">
                    {presets[0].checkpoints.map((item: string) => (
                      <span class="max-w-full break-words rounded-lg border border-white/5 bg-white/[0.03] px-2.5 py-1.5 text-[11px] font-medium text-slate-400 transition-colors hover:text-white hover:bg-white/5">{item}</span>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="flex min-w-0 flex-col gap-6">
            <div class="relative flex-grow overflow-hidden rounded-2xl border border-white/5 bg-white/[0.01] p-4 shadow-2xl backdrop-blur-3xl sm:p-6">
              <div class="absolute top-0 right-0 p-4 opacity-5 pointer-events-none">
                <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 12h6M12 9v6"/><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
              </div>
              
              <div class="space-y-8">
                <div class="min-w-0">
                  <p class="text-[10px] uppercase tracking-[0.4em] text-brand-accent font-bold">{t('showcase.profile.badge')}</p>
                  <p id="showcase-summary" class="mt-4 break-words text-sm font-medium italic leading-7 text-slate-400">"{presets[0].summary}"</p>
                </div>

                <div class="pt-6 border-t border-white/5">
                  <div class="mb-4 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                    <h4 class="break-words text-sm font-bold tracking-wide text-white">{t('showcase.quick_specs.title')}</h4>
                    <span class="self-start text-[9px] font-bold uppercase tracking-[0.2em] text-slate-600">{t('showcase.quick_specs.status')}</span>
                  </div>
                  <div class="overflow-x-auto">
                    <table class="w-full min-w-[220px] table-fixed text-left">
                      <tbody id="showcase-specs" class="divide-y divide-white/5 border-t border-white/5">
                        {presets[0].specs.map(([label, value]: any[]) => (
                          <tr>
                            <th class="w-[46%] break-words py-3.5 pr-4 text-[10px] font-extrabold uppercase tracking-[0.15em] text-slate-500">{label}</th>
                            <td class="break-words py-3.5 text-left font-mono text-[11px] font-bold text-brand-accent sm:text-right">{value}</td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                </div>

                <div class="pt-6">
                  <a href={getLocalizedPath('/editor/', locale)} class="group flex w-full items-center justify-center gap-2 rounded-xl border border-white/5 bg-white/[0.03] px-3 py-3 text-center text-[11px] font-bold text-white transition-all hover:bg-white/[0.08] hover:text-brand-accent sm:text-xs">
                    <span>{t('showcase.cta')}</span>
                    <svg class="h-3.5 w-3.5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ presets }}>
  const root = document.querySelector('[data-showcase-root]');

  if (root) {
    const buttons = root.querySelectorAll('[data-preset-button]');
    const title = document.getElementById('showcase-title');
    const summary = document.getElementById('showcase-summary');
    const specs = document.getElementById('showcase-specs');
    const metrics = document.getElementById('showcase-metrics');
    const stages = document.getElementById('showcase-stages');
    const checkpoints = document.getElementById('showcase-checkpoints');
    const diagrams = root.querySelectorAll('[data-diagram]');

    const renderSpecs = (rows) => {
      if (!specs) return;
      specs.innerHTML = rows.map(([label, value]) => `
        <tr>
          <th class="w-[46%] break-words py-3.5 pr-4 text-[10px] font-extrabold uppercase tracking-[0.15em] text-slate-500">${label}</th>
          <td class="break-words py-3.5 text-left font-mono text-[11px] font-bold text-brand-accent sm:text-right">${value}</td>
        </tr>
      `).join('');
    };

    const renderMetrics = (rows) => {
      if (!metrics) return;
      metrics.innerHTML = rows.map((metric) => `
        <div>
          <div class="mb-1.5 flex items-start justify-between gap-3 text-[11px]">
            <span class="min-w-0 break-words text-slate-400 font-medium">${metric.label}</span>
            <span class="shrink-0 font-mono text-white">${metric.value}</span>
          </div>
          <div class="h-1.5 overflow-hidden rounded-full bg-white/5">
            <div class="metric-bar h-full rounded-full metric-${metric.accent}" style="width: ${metric.strength}%"></div>
          </div>
        </div>
      `).join('');
    };

    const renderStages = (rows) => {
      if (!stages) return;
      stages.innerHTML = rows.map((stage) => `
        <div class="rounded-xl border border-white/5 bg-white/[0.02] p-3.5 transition-colors hover:bg-white/[0.04]">
          <div class="flex items-start justify-between gap-4">
            <div class="min-w-0">
              <p class="break-words text-xs font-bold tracking-wide text-white">${stage.name}</p>
              <p class="mt-0.5 break-words text-[11px] leading-relaxed text-slate-500">${stage.detail}</p>
            </div>
            <span class="shrink-0 text-[11px] font-mono text-brand-accent">${stage.load}%</span>
          </div>
          <div class="mt-2.5 h-1.5 overflow-hidden rounded-full bg-white/5">
            <div class="h-full rounded-full bg-gradient-to-r from-brand-primary/80 to-cyan-400/80" style="width: ${stage.load}%"></div>
          </div>
        </div>
      `).join('');
    };

    const renderCheckpoints = (rows) => {
      if (!checkpoints) return;
      checkpoints.innerHTML = rows.map((item) => `
        <span class="max-w-full break-words rounded-lg border border-white/5 bg-white/[0.03] px-2.5 py-1.5 text-[11px] font-medium text-slate-400 transition-colors hover:text-white hover:bg-white/5">${item}</span>
      `).join('');
    };

    const applyPreset = (presetId) => {
      const activePreset = presets.find((preset) => preset.id === presetId) || presets[0];

      buttons.forEach((button) => {
        const isActive = button.getAttribute('data-preset') === activePreset.id;
        button.setAttribute('aria-pressed', String(isActive));
        button.classList.toggle('border-brand-primary', isActive);
        button.classList.toggle('bg-brand-primary/10', isActive);
        button.classList.toggle('text-white', isActive);
        button.classList.toggle('shadow-[0_0_20px_rgba(59,130,246,0.16)]', isActive);
        button.classList.toggle('border-white/10', !isActive);
        button.classList.toggle('text-slate-300', !isActive);
      });

      diagrams.forEach((diagram) => {
        diagram.classList.toggle('hidden', diagram.getAttribute('data-diagram') !== activePreset.id);
      });

      if (title) title.textContent = activePreset.title;
      if (summary) summary.textContent = activePreset.summary;
      renderSpecs(activePreset.specs);
      renderMetrics(activePreset.metrics);
      renderStages(activePreset.stages);
      renderCheckpoints(activePreset.checkpoints);
    };

    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        applyPreset(button.getAttribute('data-preset'));
      });
    });
  }
</script>

<style>
  .metric-bar {
    box-shadow: 0 0 18px rgba(96, 165, 250, 0.22);
  }

  .metric-cyan {
    background: linear-gradient(90deg, rgba(34, 211, 238, 0.72), rgba(103, 232, 249, 1));
  }

  .metric-blue {
    background: linear-gradient(90deg, rgba(59, 130, 246, 0.72), rgba(96, 165, 250, 1));
  }

  .metric-emerald {
    background: linear-gradient(90deg, rgba(16, 185, 129, 0.72), rgba(52, 211, 153, 1));
  }

  .metric-amber {
    background: linear-gradient(90deg, rgba(245, 158, 11, 0.72), rgba(251, 191, 36, 1));
  }

  .metric-rose {
    background: linear-gradient(90deg, rgba(244, 63, 94, 0.72), rgba(251, 113, 133, 1));
  }

  .metric-violet {
    background: linear-gradient(90deg, rgba(139, 92, 246, 0.72), rgba(196, 181, 253, 1));
  }

  .metric-fuchsia {
    background: linear-gradient(90deg, rgba(217, 70, 239, 0.72), rgba(244, 114, 182, 1));
  }
</style>
