---
const presets = [
  {
    id: 'analog',
    label: 'Analog Filter',
    title: 'Two-stage active filter',
    summary: 'Preview how op-amps, passive parts, and measurement nodes fit together before you open the editor.',
    specs: [
      ['Primary parts', '8'],
      ['Estimated nets', '14'],
      ['Signal class', 'Low-noise analog']
    ]
  },
  {
    id: 'power',
    label: 'Power Supply',
    title: 'Buck regulator block',
    summary: 'Map the high-current path, feedback loop, and decoupling strategy in a layout-friendly structure.',
    specs: [
      ['Primary parts', '10'],
      ['Estimated nets', '18'],
      ['Signal class', 'Power conversion']
    ]
  },
  {
    id: 'logic',
    label: 'Logic Control',
    title: 'Sensor and MCU interface',
    summary: 'Plan input protection, pull resistors, and connector strategy for digital control systems.',
    specs: [
      ['Primary parts', '12'],
      ['Estimated nets', '16'],
      ['Signal class', 'Mixed signal']
    ]
  }
];
---

<section class="border-t border-white/5 bg-bg-dark py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto mb-14 max-w-3xl text-center">
      <p class="mb-4 text-sm font-semibold uppercase tracking-[0.35em] text-brand-accent">Interactive Preview</p>
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">Explore a live schematic breakdown before you draw</h2>
      <p class="mt-4 text-lg leading-relaxed text-slate-400">
        Switch between common circuit patterns to compare structure, complexity, and export readiness directly on the homepage.
      </p>
    </div>

    <div class="grid gap-8 lg:grid-cols-[280px_minmax(0,1fr)]" data-showcase-root>
      <aside class="rounded-3xl border border-white/10 bg-bg-panel p-4">
        <div class="space-y-3">
          {presets.map((preset, index) => (
            <button
              type="button"
              class={`showcase-tab w-full rounded-2xl border px-4 py-4 text-left transition ${
                index === 0
                  ? 'border-brand-primary bg-brand-primary/10 text-white shadow-[0_0_20px_rgba(59,130,246,0.16)]'
                  : 'border-white/10 bg-white/0 text-slate-300 hover:border-white/20 hover:bg-white/5'
              }`}
              data-preset-button
              data-preset={preset.id}
              aria-pressed={index === 0 ? 'true' : 'false'}
            >
              <span class="block text-sm font-semibold uppercase tracking-[0.25em] text-brand-accent/90">{preset.label}</span>
              <span class="mt-2 block text-lg font-semibold">{preset.title}</span>
              <span class="mt-2 block text-sm leading-6 text-slate-400">{preset.summary}</span>
            </button>
          ))}
        </div>
      </aside>

      <div class="rounded-[2rem] border border-white/10 bg-gradient-to-br from-bg-panel via-bg-panel to-bg-surface p-6 shadow-2xl">
        <div class="grid gap-8 lg:grid-cols-[minmax(0,1.2fr)_340px]">
          <div class="overflow-hidden rounded-[1.5rem] border border-white/10 bg-[#0b1220] p-4">
            <div class="mb-4 flex items-center justify-between border-b border-white/10 pb-3">
              <div>
                <p class="text-xs uppercase tracking-[0.3em] text-slate-500">Diagram Canvas</p>
                <h3 id="showcase-title" class="mt-2 text-xl font-semibold text-white">{presets[0].title}</h3>
              </div>
              <div class="rounded-full border border-emerald-400/30 bg-emerald-400/10 px-3 py-1 text-xs font-medium uppercase tracking-[0.24em] text-emerald-300">
                Live preset
              </div>
            </div>

            <div class="relative aspect-[16/10] overflow-hidden rounded-[1.25rem] border border-white/10 bg-[radial-gradient(circle_at_top,rgba(59,130,246,0.16),transparent_35%),linear-gradient(180deg,rgba(15,23,42,0.8),rgba(2,6,23,0.95))]">
              <svg class="h-full w-full text-brand-accent" viewBox="0 0 760 460" fill="none" xmlns="http://www.w3.org/2000/svg">
                <g data-diagram="analog">
                  <path d="M88 130H184" stroke="currentColor" stroke-width="4" stroke-linecap="round" />
                  <path d="M88 130V216H188" stroke="#38bdf8" stroke-width="4" stroke-linecap="round" />
                  <rect x="184" y="92" width="116" height="80" rx="16" fill="#111827" stroke="#60a5fa" stroke-width="3" />
                  <text x="242" y="138" text-anchor="middle" fill="#e2e8f0" font-size="20" font-family="sans-serif">OP-AMP</text>
                  <path d="M300 132H396" stroke="#67e8f9" stroke-width="4" stroke-linecap="round" />
                  <circle cx="430" cy="132" r="28" fill="#0f172a" stroke="#22d3ee" stroke-width="3" />
                  <path d="M430 104V160" stroke="#22d3ee" stroke-width="3" />
                  <path d="M402 132H458" stroke="#22d3ee" stroke-width="3" />
                  <path d="M430 160V224H242V172" stroke="#38bdf8" stroke-width="4" stroke-linecap="round" />
                  <path d="M122 130V76H520V132" stroke="#1d4ed8" stroke-width="4" stroke-dasharray="10 10" />
                  <circle cx="88" cy="130" r="8" fill="#22d3ee" />
                  <circle cx="520" cy="132" r="8" fill="#22d3ee" />
                  <text x="92" y="112" fill="#cbd5e1" font-size="16" font-family="sans-serif">VIN</text>
                  <text x="530" y="112" fill="#cbd5e1" font-size="16" font-family="sans-serif">VOUT</text>
                </g>
                <g data-diagram="power" class="hidden">
                  <path d="M90 118H190" stroke="#f8fafc" stroke-width="4" stroke-linecap="round" />
                  <rect x="190" y="88" width="88" height="62" rx="14" fill="#111827" stroke="#f59e0b" stroke-width="3" />
                  <text x="234" y="126" text-anchor="middle" fill="#f8fafc" font-size="18" font-family="sans-serif">PWM</text>
                  <path d="M278 118H358" stroke="#f59e0b" stroke-width="4" stroke-linecap="round" />
                  <path d="M358 118c18-32 44-32 62 0c18 32 44 32 62 0" stroke="#fde68a" stroke-width="4" stroke-linecap="round" />
                  <path d="M482 118H580" stroke="#f59e0b" stroke-width="4" stroke-linecap="round" />
                  <rect x="580" y="86" width="92" height="64" rx="14" fill="#111827" stroke="#22c55e" stroke-width="3" />
                  <text x="626" y="124" text-anchor="middle" fill="#f8fafc" font-size="18" font-family="sans-serif">LOAD</text>
                  <path d="M358 118V210H626V150" stroke="#fb7185" stroke-width="4" stroke-linecap="round" />
                  <path d="M430 118V256" stroke="#38bdf8" stroke-width="4" stroke-linecap="round" />
                  <path d="M402 256H458" stroke="#38bdf8" stroke-width="4" stroke-linecap="round" />
                  <path d="M412 274H448" stroke="#38bdf8" stroke-width="4" stroke-linecap="round" />
                  <path d="M420 292H440" stroke="#38bdf8" stroke-width="4" stroke-linecap="round" />
                  <text x="86" y="96" fill="#cbd5e1" font-size="16" font-family="sans-serif">VIN</text>
                  <text x="596" y="70" fill="#cbd5e1" font-size="16" font-family="sans-serif">3.3V</text>
                </g>
                <g data-diagram="logic" class="hidden">
                  <rect x="118" y="94" width="124" height="80" rx="18" fill="#111827" stroke="#a78bfa" stroke-width="3" />
                  <text x="180" y="128" text-anchor="middle" fill="#f8fafc" font-size="18" font-family="sans-serif">SENSOR</text>
                  <path d="M242 118H336" stroke="#c084fc" stroke-width="4" stroke-linecap="round" />
                  <rect x="336" y="72" width="132" height="132" rx="24" fill="#111827" stroke="#38bdf8" stroke-width="3" />
                  <text x="402" y="128" text-anchor="middle" fill="#f8fafc" font-size="18" font-family="sans-serif">MCU</text>
                  <path d="M468 104H570" stroke="#38bdf8" stroke-width="4" stroke-linecap="round" />
                  <rect x="570" y="74" width="88" height="62" rx="14" fill="#111827" stroke="#22d3ee" stroke-width="3" />
                  <text x="614" y="112" text-anchor="middle" fill="#f8fafc" font-size="16" font-family="sans-serif">UART</text>
                  <path d="M468 152H570" stroke="#34d399" stroke-width="4" stroke-linecap="round" />
                  <rect x="570" y="122" width="88" height="62" rx="14" fill="#111827" stroke="#34d399" stroke-width="3" />
                  <text x="614" y="160" text-anchor="middle" fill="#f8fafc" font-size="16" font-family="sans-serif">GPIO</text>
                  <path d="M180 174V262H402V204" stroke="#f59e0b" stroke-width="4" stroke-dasharray="10 12" />
                  <path d="M134 262H226" stroke="#f59e0b" stroke-width="4" />
                  <path d="M146 280H214" stroke="#f59e0b" stroke-width="4" />
                  <path d="M158 298H202" stroke="#f59e0b" stroke-width="4" />
                </g>
              </svg>
            </div>
          </div>

          <div class="flex flex-col justify-between gap-6">
            <div class="rounded-[1.5rem] border border-white/10 bg-bg-surface/80 p-6">
              <p class="text-xs uppercase tracking-[0.3em] text-brand-accent">Preset Notes</p>
              <p id="showcase-summary" class="mt-4 text-base leading-7 text-slate-300">{presets[0].summary}</p>
            </div>

            <div class="rounded-[1.5rem] border border-white/10 bg-bg-panel p-6">
              <div class="mb-5 flex items-center justify-between">
                <h4 class="text-lg font-semibold text-white">Quick reference table</h4>
                <span class="text-xs uppercase tracking-[0.3em] text-slate-500">Auto-updates</span>
              </div>
              <table class="w-full text-left text-sm">
                <tbody id="showcase-specs" class="divide-y divide-white/10 text-slate-300">
                  {presets[0].specs.map(([label, value]) => (
                    <tr>
                      <th class="py-3 pr-4 font-medium text-slate-400">{label}</th>
                      <td class="py-3 text-white">{value}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ presets }}>
  const root = document.querySelector('[data-showcase-root]');

  if (root) {
    const buttons = root.querySelectorAll('[data-preset-button]');
    const title = document.getElementById('showcase-title');
    const summary = document.getElementById('showcase-summary');
    const specs = document.getElementById('showcase-specs');
    const diagrams = root.querySelectorAll('[data-diagram]');

    const renderSpecs = (rows) => {
      if (!specs) return;
      specs.innerHTML = rows.map(([label, value]) => `
        <tr>
          <th class="py-3 pr-4 font-medium text-slate-400">${label}</th>
          <td class="py-3 text-white">${value}</td>
        </tr>
      `).join('');
    };

    const applyPreset = (presetId) => {
      const activePreset = presets.find((preset) => preset.id === presetId) || presets[0];

      buttons.forEach((button) => {
        const isActive = button.getAttribute('data-preset') === activePreset.id;
        button.setAttribute('aria-pressed', String(isActive));
        button.classList.toggle('border-brand-primary', isActive);
        button.classList.toggle('bg-brand-primary/10', isActive);
        button.classList.toggle('text-white', isActive);
        button.classList.toggle('shadow-[0_0_20px_rgba(59,130,246,0.16)]', isActive);
        button.classList.toggle('border-white/10', !isActive);
        button.classList.toggle('text-slate-300', !isActive);
      });

      diagrams.forEach((diagram) => {
        diagram.classList.toggle('hidden', diagram.getAttribute('data-diagram') !== activePreset.id);
      });

      if (title) title.textContent = activePreset.title;
      if (summary) summary.textContent = activePreset.summary;
      renderSpecs(activePreset.specs);
    };

    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        applyPreset(button.getAttribute('data-preset'));
      });
    });
  }
</script>
