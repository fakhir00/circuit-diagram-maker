                  <div>
                    <p class="text-[10px] uppercase tracking-[0.4em] text-brand-accent font-bold">Schematic breakdown</p>
                    <h4 class="mt-1 text-base font-semibold text-white">Critical path allocation</h4>
                  </div>
                  <div class="rounded-full border border-white/5 bg-white/5 px-2 py-0.5 text-[9px] font-bold uppercase tracking-[0.2em] text-slate-500">
                    Auto-profiled
                  </div>
                </div>
                <div id="showcase-stages" class="mt-6 space-y-3">
                  {presets[0].stages.map((stage) => (
                    <div class="rounded-xl border border-white/5 bg-white/[0.02] p-3.5 transition-colors hover:bg-white/[0.04]">
                      <div class="flex items-start justify-between gap-4">
                        <div>
                          <p class="text-xs font-bold text-white tracking-wide">{stage.name}</p>
                          <p class="mt-0.5 text-[11px] text-slate-500 leading-relaxed">{stage.detail}</p>
                        </div>
                        <span class="text-[11px] font-mono text-brand-accent">{stage.load}%</span>
                      </div>
                      <div class="mt-2.5 h-1.5 overflow-hidden rounded-full bg-white/5">
                        <div class="h-full rounded-full bg-gradient-to-r from-brand-primary/80 to-cyan-400/80" style={`width: ${stage.load}%`}></div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>

              <div class="space-y-6">
                <div class="rounded-2xl border border-white/5 bg-white/[0.01] p-5 backdrop-blur-3xl">
                  <p class="text-[10px] uppercase tracking-[0.4em] text-brand-accent font-bold">Operating metrics</p>
                  <div id="showcase-metrics" class="mt-5 space-y-4">
                    {presets[0].metrics.map((metric) => (
                      <div>
                        <div class="mb-1.5 flex items-center justify-between gap-3 text-[11px]">
                          <span class="text-slate-400 font-medium">{metric.label}</span>
                          <span class="font-mono text-white">{metric.value}</span>
                        </div>
                        <div class="h-1.5 overflow-hidden rounded-full bg-white/5">
                          <div class={`metric-bar h-full rounded-full metric-${metric.accent}`} style={`width: ${metric.strength}%`}></div>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>

                <div class="rounded-2xl border border-white/5 bg-white/[0.01] p-5 backdrop-blur-3xl">
                  <div class="flex items-center justify-between gap-4">
                    <p class="text-[10px] uppercase tracking-[0.4em] text-brand-accent font-bold">Design checkpoints</p>
                    <span class="text-[9px] font-bold uppercase tracking-[0.2em] text-slate-600">Review cues</span>
                  </div>
                  <div id="showcase-checkpoints" class="mt-5 flex flex-wrap gap-2">
                    {presets[0].checkpoints.map((item) => (
                      <span class="rounded-lg border border-white/5 bg-white/[0.03] px-2.5 py-1.5 text-[11px] font-medium text-slate-400 transition-colors hover:text-white hover:bg-white/5">{item}</span>
