---
interface Props {
  items: Array<{
    question: string;
    answer: string;
    display: boolean;
  }>;
  title: string;
}

const { items, title } = Astro.props;
const visibleItems = items.filter(item => item.display !== false);
---

<section class="py-24 bg-bg-panel border-t border-white/5">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold text-white text-center mb-12">{title}</h2>
    
    <div class="space-y-4">
      {visibleItems.map((item, index) => (
        <details class="group bg-bg-surface border border-white/10 rounded-xl overflow-hidden transition-all duration-300 open:border-brand-primary/50">
          <summary class="flex justify-between items-center p-6 cursor-pointer list-none text-white font-medium hover:bg-white/5 transition-colors">
            <span>{item.question}</span>
            <svg class="w-5 h-5 text-slate-400 group-open:rotate-180 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="p-6 pt-0 text-slate-400 leading-relaxed border-t border-white/5 bg-bg-panel/30">
            {item.answer}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  /* Remove default arrow in some browsers */
  summary::-webkit-details-marker {
    display: none;
  }
</style>
