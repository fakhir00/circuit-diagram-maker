---
interface Props {
  presetId?: string;
  showAll?: boolean;
  showcaseIds?: string[];
}

const { presetId, showAll, showcaseIds } = Astro.props;

// If we are in showAll mode, we use all IDs. Otherwise, just the single ID.
const idsToRender = showAll && showcaseIds ? showcaseIds : (presetId ? [presetId] : ['analog']);
---

<svg class="h-full w-full text-brand-accent" viewBox="0 0 760 460" fill="none" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <filter id="currentGlow">
      <feGaussianBlur stdDeviation="3.5" result="blur"/>
      <feComposite in="SourceGraphic" in2="blur" operator="over"/>
    </filter>
    <filter id="wireGlow">
      <feGaussianBlur stdDeviation="1.5" result="blur"/>
      <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
  </defs>

  {idsToRender.includes('analog') && (
    <g data-diagram="analog" class={showAll && idsToRender[0] !== 'analog' ? 'hidden' : ''} transform="translate(68, 55)">
      <path d="M88 130H184" stroke="currentColor" stroke-width="6" stroke-linecap="round" filter="url(#wireGlow)" />
      <path d="M88 130V216H188" stroke="#38bdf8" stroke-width="6" stroke-linecap="round" filter="url(#wireGlow)" />
      <circle r="5" fill="#22d3ee" filter="url(#currentGlow)"><animateMotion dur="1s" repeatCount="indefinite" path="M88 130H184" /></circle>
      <circle r="5" fill="#38bdf8" filter="url(#currentGlow)"><animateMotion dur="2.5s" repeatCount="indefinite" path="M88 130V216H188" /></circle>
      <rect x="184" y="92" width="116" height="80" rx="16" fill="#111827" stroke="#60a5fa" stroke-width="3" />
      <text x="242" y="138" text-anchor="middle" fill="#e2e8f0" font-size="20" font-family="sans-serif" font-weight="bold">OP-AMP</text>
      <path d="M300 132H402" stroke="#67e8f9" stroke-width="4" stroke-linecap="round" />
      <circle r="4" fill="#67e8f9" filter="url(#currentGlow)"><animateMotion dur="0.8s" repeatCount="indefinite" path="M300 132H402" /></circle>
      <circle cx="430" cy="132" r="28" fill="#0f172a" stroke="#22d3ee" stroke-width="3" />
      <path d="M430 104V160" stroke="#22d3ee" stroke-width="3" />
      <path d="M402 132H458" stroke="#22d3ee" stroke-width="3" />
      <path d="M458 132H520" stroke="#22d3ee" stroke-width="4" stroke-linecap="round" />
      <circle r="4" fill="#22d3ee" filter="url(#currentGlow)"><animateMotion dur="0.4s" repeatCount="indefinite" path="M458 132H520" /></circle>
      <path d="M430 160V224H242V172" stroke="#38bdf8" stroke-width="4" stroke-linecap="round" />
      <circle r="4" fill="#38bdf8" filter="url(#currentGlow)"><animateMotion dur="3s" repeatCount="indefinite" path="M430 160V224H242V172" /></circle>
      <path d="M88 130V76H520V132" stroke="#1d4ed8" stroke-width="4" stroke-dasharray="10 10" />
      <circle r="3.5" fill="#1d4ed8" filter="url(#currentGlow)"><animateMotion dur="5s" repeatCount="indefinite" path="M88 130V76H520V132" /></circle>
      <circle cx="88" cy="130" r="6" fill="#22d3ee" />
      <circle cx="520" cy="132" r="6" fill="#22d3ee" />
      <text x="92" y="112" fill="#cbd5e1" font-size="16" font-family="sans-serif" font-weight="bold">VIN</text>
      <text x="530" y="112" fill="#cbd5e1" font-size="16" font-family="sans-serif" font-weight="bold">VOUT</text>
    </g>
  )}

  {idsToRender.includes('power') && (
    <g data-diagram="power" class={showAll && idsToRender[0] !== 'power' ? 'hidden' : ''} transform="translate(35, 45)">
      <path d="M90 118H200" stroke="#f8fafc" stroke-width="6" stroke-linecap="round" filter="url(#wireGlow)" />
      <circle r="5" fill="#60a5fa" filter="url(#currentGlow)"><animateMotion dur="1s" repeatCount="indefinite" path="M90 118H200" /></circle>
      <circle cx="100" cy="118" r="6" fill="#60a5fa" />
      <rect x="190" y="88" width="88" height="62" rx="14" fill="#111827" stroke="#f59e0b" stroke-width="3" />
      <text x="234" y="126" text-anchor="middle" fill="#f8fafc" font-size="18" font-family="sans-serif" font-weight="bold">PWM</text>
      <path d="M268 118H368" stroke="#f59e0b" stroke-width="6" stroke-linecap="round" filter="url(#wireGlow)" />
      <circle r="5" fill="#f59e0b" filter="url(#currentGlow)"><animateMotion dur="0.8s" repeatCount="indefinite" path="M268 118H368" /></circle>
      <path d="M358 118c18-32 44-32 62 0s44 32 62 0" stroke="#fde68a" stroke-width="6" stroke-linecap="round" filter="url(#wireGlow)" />
      <circle r="4" fill="#fde68a" filter="url(#currentGlow)"><animateMotion dur="1.5s" repeatCount="indefinite" path="M358 118c18-32 44-32 62 0s44 32 62 0" /></circle>
      <path d="M472 118H590" stroke="#f59e0b" stroke-width="6" stroke-linecap="round" filter="url(#wireGlow)" />
      <circle r="5" fill="#f59e0b" filter="url(#currentGlow)"><animateMotion dur="1s" repeatCount="indefinite" path="M472 118H590" /></circle>
      <rect x="580" y="86" width="92" height="64" rx="14" fill="#111827" stroke="#22c55e" stroke-width="3" />
      <text x="626" y="124" text-anchor="middle" fill="#f8fafc" font-size="18" font-family="sans-serif" font-weight="bold">LOAD</text>
      <path d="M358 118V210H626V150" stroke="#fb7185" stroke-width="6" stroke-linecap="round" filter="url(#wireGlow)" />
      <circle r="4" fill="#fb7185" filter="url(#currentGlow)"><animateMotion dur="2.5s" repeatCount="indefinite" path="M358 118V210H626V150" /></circle>
      <path d="M430 210V256" stroke="#38bdf8" stroke-width="6" stroke-linecap="round" filter="url(#wireGlow)" />
      <path d="M402 256H458" stroke="#38bdf8" stroke-width="4" stroke-linecap="round" />
      <path d="M412 274H448" stroke="#38bdf8" stroke-width="4" stroke-linecap="round" />
      <path d="M420 292H440" stroke="#38bdf8" stroke-width="4" stroke-linecap="round" />
      <text x="86" y="96" fill="#cbd5e1" font-size="16" font-family="sans-serif" font-weight="bold">VIN</text>
      <text x="596" y="70" fill="#cbd5e1" font-size="16" font-family="sans-serif" font-weight="bold">3.3V</text>
    </g>
  )}

  {idsToRender.includes('logic') && (
    <g data-diagram="logic" class={showAll && idsToRender[0] !== 'logic' ? 'hidden' : ''} transform="translate(30, 40)">
      <rect x="118" y="94" width="124" height="80" rx="18" fill="#111827" stroke="#a78bfa" stroke-width="3" />
      <text x="180" y="128" text-anchor="middle" fill="#f8fafc" font-size="18" font-family="sans-serif" font-weight="bold">SENSOR</text>
      <path d="M242 118H336" stroke="#c084fc" stroke-width="4" stroke-linecap="round" />
      <circle r="4" fill="#a78bfa" filter="url(#currentGlow)"><animateMotion dur="1.2s" repeatCount="indefinite" path="M242 118H336" /></circle>
      <rect x="336" y="72" width="132" height="132" rx="24" fill="#111827" stroke="#38bdf8" stroke-width="3" />
      <text x="402" y="128" text-anchor="middle" fill="#f8fafc" font-size="18" font-family="sans-serif" font-weight="bold">MCU</text>
      <path d="M468 104H570" stroke="#38bdf8" stroke-width="4" stroke-linecap="round" />
      <circle r="3.5" fill="#38bdf8" filter="url(#currentGlow)"><animateMotion dur="1s" repeatCount="indefinite" path="M468 104H570" /></circle>
      <rect x="570" y="74" width="88" height="62" rx="14" fill="#111827" stroke="#22d3ee" stroke-width="3" />
      <text x="614" y="112" text-anchor="middle" fill="#f8fafc" font-size="16" font-family="sans-serif" font-weight="bold">UART</text>
      <path d="M468 152H570" stroke="#34d399" stroke-width="4" stroke-linecap="round" />
      <circle r="3.5" fill="#34d399" filter="url(#currentGlow)"><animateMotion dur="1.5s" repeatCount="indefinite" path="M468 152H570" /></circle>
      <rect x="570" y="122" width="88" height="62" rx="14" fill="#111827" stroke="#34d399" stroke-width="3" />
      <text x="614" y="160" text-anchor="middle" fill="#f8fafc" font-size="16" font-family="sans-serif" font-weight="bold">GPIO</text>
      <path d="M180 174V262H402V204" stroke="#f59e0b" stroke-width="4" stroke-dasharray="10 12" />
      <circle r="3.5" fill="#f59e0b" filter="url(#currentGlow)"><animateMotion dur="3s" repeatCount="indefinite" path="M180 174V262H402V204" /></circle>
      <path d="M134 262H226" stroke="#f59e0b" stroke-width="4" />
      <path d="M146 280H214" stroke="#f59e0b" stroke-width="4" />
      <path d="M158 298H202" stroke="#f59e0b" stroke-width="4" />
    </g>
  )}

  {idsToRender.includes('audio') && (
    <g data-diagram="audio" class={showAll && idsToRender[0] !== 'audio' ? 'hidden' : ''} transform="translate(30, 0)">
      <path d="M80 200H180" stroke="#a855f7" stroke-width="4" />
      <circle r="4" fill="#a855f7" filter="url(#currentGlow)"><animateMotion dur="2s" repeatCount="indefinite" path="M80 200H180" /></circle>
      <rect x="180" y="170" width="40" height="60" rx="4" fill="#111827" stroke="#a855f7" stroke-width="3" />
      <path d="M220 200H320" stroke="#a855f7" stroke-width="4" />
      <circle r="4" fill="#a855f7" filter="url(#currentGlow)"><animateMotion dur="1s" repeatCount="indefinite" path="M220 200H320" /></circle>
      <circle cx="350" cy="200" r="30" fill="#0f172a" stroke="#ec4899" stroke-width="3" />
      <path d="M335 185 L350 200 L335 215" stroke="#ec4899" stroke-width="3" />
      <path d="M380 200H480" stroke="#ec4899" stroke-width="4" />
      <circle r="4" fill="#ec4899" filter="url(#currentGlow)"><animateMotion dur="0.8s" repeatCount="indefinite" path="M380 200H480" /></circle>
      <rect x="480" y="170" width="40" height="60" rx="4" fill="#111827" stroke="#38bdf8" stroke-width="3" />
      <path d="M520 200H620" stroke="#38bdf8" stroke-width="4" />
      <circle r="4" fill="#38bdf8" filter="url(#currentGlow)"><animateMotion dur="2.5s" repeatCount="indefinite" path="M520 200H620" /></circle>
      <text x="80" y="180" fill="#94a3b8" font-size="14">AUDIO IN</text>
      <text x="620" y="180" fill="#94a3b8" font-size="14">LINE OUT</text>
    </g>
  )}

  {idsToRender.includes('iot') && (
    <g data-diagram="iot" class={showAll && idsToRender[0] !== 'iot' ? 'hidden' : ''} transform="translate(110, 0)">
      <rect x="60" y="180" width="40" height="80" rx="4" fill="#111827" stroke="#22c55e" stroke-width="3" />
      <path d="M90 220H210" stroke="#22c55e" stroke-width="4" />
      <circle r="4" fill="#22c55e" filter="url(#currentGlow)"><animateMotion dur="3s" repeatCount="indefinite" path="M90 220H210" /></circle>
      <rect x="200" y="150" width="140" height="140" rx="20" fill="#111827" stroke="#3b82f6" stroke-width="3" />
      <text x="270" y="210" text-anchor="middle" fill="#f8fafc" font-size="18" font-weight="bold">ESP32</text>
      <text x="270" y="235" text-anchor="middle" fill="#60a5fa" font-size="10">LOW POWER</text>
      <path d="M140 70V160" stroke="#f59e0b" stroke-width="3" stroke-dasharray="4 4" />
      <circle r="3" fill="#f59e0b" filter="url(#currentGlow)"><animateMotion dur="1.2s" repeatCount="indefinite" path="M140 70V160" /></circle>
      <circle cx="140" cy="80" r="4" fill="#f59e0b" />
      <circle cx="140" cy="150" r="4" fill="#3b82f6" />
      <rect x="100" y="30" width="80" height="50" rx="8" fill="#111827" stroke="#f59e0b" stroke-width="2" />
      <text x="140" y="60" text-anchor="middle" fill="#94a3b8" font-size="12">SENSOR</text>
      <path d="M330 220H450" stroke="#ef4444" stroke-width="4" stroke-dasharray="8 4" />
      <circle r="4" fill="#ef4444" filter="url(#currentGlow)"><animateMotion dur="0.8s" repeatCount="indefinite" path="M330 220H450" /></circle>
      <path d="M440 200V240M440 220 L480 180M440 220 L480 260" stroke="#ef4444" stroke-width="3" stroke-linecap="round" />
      <text x="470" y="160" fill="#ef4444" font-size="14" font-weight="bold">RF OUT</text>
    </g>
  )}

  {idsToRender.includes('gates') && (
    <g data-diagram="gates" class={showAll && idsToRender[0] !== 'gates' ? 'hidden' : ''} transform="translate(60, 40)">
      <path d="M80 100H200" stroke="#a78bfa" stroke-width="4" />
      <path d="M80 180H200" stroke="#a78bfa" stroke-width="4" />
      <path d="M200 80H230C260 80 280 105 280 140C280 175 260 200 230 200H200V80Z" fill="#111827" stroke="#a78bfa" stroke-width="3" />
      <text x="235" y="145" text-anchor="middle" fill="#a78bfa" font-size="24" font-weight="bold">&</text>
      <path d="M280 140H380" stroke="#38bdf8" stroke-width="4" />
      <path d="M80 260H380" stroke="#38bdf8" stroke-width="4" />
      <path d="M380 120C400 120 420 130 430 140C440 150 480 180 480 200C480 220 440 250 430 260C420 270 400 280 380 280C400 250 400 150 380 120Z" fill="#111827" stroke="#38bdf8" stroke-width="3" />
      <text x="420" y="210" text-anchor="middle" fill="#38bdf8" font-size="24" font-weight="bold">≥</text>
      <path d="M480 200H580" stroke="#22d3ee" stroke-width="4" />
      <circle r="4" fill="#a78bfa" filter="url(#currentGlow)"><animateMotion dur="2s" repeatCount="indefinite" path="M80 100H200" /></circle>
      <circle r="4" fill="#38bdf8" filter="url(#currentGlow)"><animateMotion dur="1s" repeatCount="indefinite" path="M280 140H380" /></circle>
      <circle r="4" fill="#22d3ee" filter="url(#currentGlow)"><animateMotion dur="0.8s" repeatCount="indefinite" path="M480 200H580" /></circle>
      <text x="80" y="80" fill="#94a3b8" font-size="12">INPUT A</text>
      <text x="580" y="180" fill="#22d3ee" font-size="14" font-weight="bold">RESULT</text>
    </g>
  )}

  {idsToRender.includes('arduino') && (
    <g data-diagram="arduino" class={showAll && idsToRender[0] !== 'arduino' ? 'hidden' : ''} transform="translate(40, 20)">
      <rect x="100" y="80" width="220" height="300" rx="12" fill="#111827" stroke="#008184" stroke-width="3" />
      <rect x="115" y="100" width="190" height="15" rx="2" fill="#1e293b" />
      <rect x="115" y="345" width="190" height="15" rx="2" fill="#1e293b" />
      <rect x="120" y="180" width="60" height="80" rx="4" fill="#334155" />
      <text x="210" y="230" text-anchor="middle" fill="#008184" font-size="24" font-weight="bold">ARDUINO</text>
      <path d="M305 107H450" stroke="#fbbf24" stroke-width="3" stroke-dasharray="4 4" />
      <circle r="3" fill="#fbbf24" filter="url(#currentGlow)"><animateMotion dur="1.5s" repeatCount="indefinite" path="M305 107H450" /></circle>
      <rect x="450" y="90" width="40" height="20" rx="2" fill="#111827" stroke="#fbbf24" stroke-width="2" />
      <path d="M470 110V180" stroke="#f87171" stroke-width="3" />
      <circle cx="470" cy="200" r="15" fill="#f87171" filter="url(#currentGlow)" fill-opacity="0.2" />
      <circle cx="470" cy="200" r="10" fill="#ef4444" stroke="#f87171" stroke-width="2" />
      <text x="470" y="240" text-anchor="middle" fill="#f87171" font-size="12" font-weight="bold">D13 LED</text>
    </g>
  )}

  {idsToRender.includes('pcb_tool') && (
    <g data-diagram="pcb_tool" class={showAll && idsToRender[0] !== 'pcb_tool' ? 'hidden' : ''} transform="translate(60, 40)">
      <path d="M0 0H600V350H0Z" fill="url(#pcbGrid)" opacity="0.1" />
      <defs>
        <pattern id="pcbGrid" width="40" height="40" patternUnits="userSpaceOnUse">
          <path d="M 40 0 L 0 0 0 40" fill="none" stroke="white" stroke-width="1"/>
        </pattern>
      </defs>
      <path d="M100 100H250V250H400" stroke="#ef4444" stroke-width="5" stroke-linecap="round" stroke-linejoin="round" />
      <path d="M100 250H250V100H400" stroke="#22c55e" stroke-width="5" stroke-linecap="round" stroke-linejoin="round" opacity="0.6" />
      <circle cx="250" cy="100" r="8" fill="#111827" stroke="#fbbf24" stroke-width="3" />
      <circle cx="250" cy="250" r="8" fill="#111827" stroke="#fbbf24" stroke-width="3" />
      <circle cx="100" cy="100" r="10" fill="#111827" stroke="#ef4444" stroke-width="3" />
      <circle cx="400" cy="250" r="10" fill="#111827" stroke="#ef4444" stroke-width="3" />
      <circle r="4" fill="#ef4444" filter="url(#currentGlow)"><animateMotion dur="2s" repeatCount="indefinite" path="M100 100H250V250H400" /></circle>
      <text x="100" y="80" fill="#ef4444" font-size="12" font-weight="bold">TOP LAYER</text>
      <text x="400" y="280" fill="#22c55e" font-size="12" font-weight="bold" opacity="0.8">BOTTOM LAYER</text>
    </g>
  )}
</svg>
