---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface PostData {
  title: string;
  description: string;
  date: Date;
  author?: string;
  image?: string;
  tags?: string[];
}

interface Props {
  post: {
    data: PostData;
    body?: string;
  };
  Content: any;
  headings?: Heading[];
  locale: string;
}

const { post, Content, headings = [], locale } = Astro.props;
const articleHeadings = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
const sectionHeadings = articleHeadings.filter((heading) => heading.depth === 2);
const primaryTag = post.data.tags?.[0] || 'Engineering';
const normalizedLocale = locale === 'en' ? 'en-US' : locale;
const wordCount = typeof post.body === 'string'
  ? post.body.trim().split(/\s+/).filter(Boolean).length
  : 0;
const readMinutes = Math.max(4, Math.ceil(wordCount / 190));
const isEnglishLocale = locale.toLowerCase().startsWith('en');
const localePrefix = isEnglishLocale ? '' : `/${locale}`;
const homePath = `${localePrefix}/`;
const blogPath = `${localePrefix}/blog/`;
const structurePreview = sectionHeadings.slice(0, 6);
---

<article class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8">
  <header class="mx-auto max-w-6xl">
    <div class="rounded-[2rem] border border-white/10 bg-[radial-gradient(circle_at_top,rgba(59,130,246,0.12),transparent_45%),linear-gradient(180deg,rgba(15,23,42,0.95),rgba(7,12,21,0.94))] px-6 py-8 shadow-[0_24px_90px_rgba(0,0,0,0.32)] sm:px-8 sm:py-10 lg:px-12">
      <nav aria-label="Breadcrumb" class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-400">
        <a href={homePath} class="hover:text-slate-200 transition-colors">Home</a>
        <span class="mx-2 text-slate-600">/</span>
        <a href={blogPath} class="hover:text-slate-200 transition-colors">Blog</a>
        <span class="mx-2 text-slate-600">/</span>
        <span class="text-slate-300">Article</span>
      </nav>

      <div class="mt-5 flex flex-wrap items-center gap-3 text-[11px] font-semibold uppercase tracking-[0.26em] text-slate-400">
        <span class="rounded-full border border-brand-primary/25 bg-brand-primary/10 px-3 py-1 text-brand-accent">{primaryTag}</span>
        <span class="h-1 w-1 rounded-full bg-slate-600"></span>
        <time datetime={post.data.date.toISOString()}>
          {post.data.date.toLocaleDateString(normalizedLocale, { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <span class="h-1 w-1 rounded-full bg-slate-600"></span>
        <span>{readMinutes} min read</span>
        <span class="h-1 w-1 rounded-full bg-slate-600"></span>
        <span>{post.data.author || 'Circuit Diagram Maker Team'}</span>
      </div>

      <h1 class="mt-6 text-4xl font-black tracking-tight text-white sm:text-5xl lg:text-6xl leading-[1.08]">
        {post.data.title}
      </h1>

      <p class="mt-6 max-w-4xl text-lg leading-8 text-slate-300 sm:text-xl">
        {post.data.description}
      </p>

      <div class="mt-8 grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
        <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-4">
          <p class="text-[10px] uppercase tracking-[0.25em] text-slate-500">Primary Topic</p>
          <p class="mt-2 text-sm font-semibold text-white">{primaryTag}</p>
        </div>
        <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-4">
          <p class="text-[10px] uppercase tracking-[0.25em] text-slate-500">Article Sections</p>
          <p class="mt-2 text-sm font-semibold text-white">{sectionHeadings.length || 'Structured guide'}</p>
        </div>
        <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-4">
          <p class="text-[10px] uppercase tracking-[0.25em] text-slate-500">Read Time</p>
          <p class="mt-2 text-sm font-semibold text-white">{readMinutes} minutes</p>
        </div>
        <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-4">
          <p class="text-[10px] uppercase tracking-[0.25em] text-slate-500">Format</p>
          <p class="mt-2 text-sm font-semibold text-white">Interactive technical article</p>
        </div>
      </div>

      {post.data.tags && post.data.tags.length > 0 && (
        <div class="mt-6 flex flex-wrap gap-2">
          {post.data.tags.slice(0, 6).map((tag) => (
            <span class="rounded-full border border-white/10 bg-white/[0.04] px-3 py-1.5 text-xs font-medium uppercase tracking-[0.16em] text-slate-300">{tag}</span>
          ))}
        </div>
      )}

      {post.data.image && (
        <div class="mt-8 overflow-hidden rounded-[1.5rem] border border-white/10 shadow-2xl">
          <img src={post.data.image} alt={post.data.title} class="h-full w-full object-cover" />
        </div>
      )}
    </div>
  </header>

  <div class="mx-auto mt-10 grid max-w-7xl gap-8 xl:grid-cols-[minmax(0,1fr)_320px]">
    <div class="min-w-0 space-y-8">
      <section class="rounded-[1.7rem] border border-white/10 bg-[linear-gradient(180deg,rgba(9,14,24,0.9),rgba(15,23,42,0.92))] p-6 shadow-[0_16px_50px_rgba(0,0,0,0.22)] sm:p-7">
        <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.28em] text-brand-accent">Article Structure</p>
            <h2 class="mt-2 text-2xl font-bold tracking-tight text-white">Professional reading map</h2>
          </div>
          <span class="text-[11px] uppercase tracking-[0.24em] text-slate-500">H1 + H2/H3 hierarchy</span>
        </div>

        <div class="mt-6 grid gap-3 sm:grid-cols-2">
          {structurePreview.length > 0 ? structurePreview.map((heading, index) => (
            <a href={`#${heading.slug}`} class="group rounded-xl border border-white/10 bg-white/[0.03] p-4 transition hover:border-brand-primary/30 hover:bg-brand-primary/5">
              <p class="text-[10px] uppercase tracking-[0.24em] text-slate-500">Section {index + 1}</p>
              <p class="mt-2 text-sm font-semibold leading-6 text-slate-200 group-hover:text-white">{heading.text}</p>
            </a>
          )) : (
            <div class="rounded-xl border border-white/10 bg-white/[0.03] p-4 text-sm text-slate-300 sm:col-span-2">
              Structured section headings will appear here when the article includes `##` headings.
            </div>
          )}
        </div>
      </section>

      <section class="rounded-[2rem] border border-white/10 bg-[linear-gradient(180deg,rgba(15,23,42,0.94),rgba(7,12,21,0.94))] p-6 shadow-[0_20px_80px_rgba(0,0,0,0.22)] sm:p-8">
        <div class="blog-article" data-blog-article>
          <Content />
        </div>
      </section>
    </div>

    <aside class="hidden xl:block">
      <div class="sticky top-24 space-y-5">
        <div class="rounded-[1.5rem] border border-white/10 bg-bg-panel/90 p-5 shadow-[0_14px_40px_rgba(0,0,0,0.22)]">
          <p class="text-xs font-semibold uppercase tracking-[0.28em] text-brand-accent">On This Page</p>
          {articleHeadings.length > 0 ? (
            <nav class="mt-5">
              <ol class="space-y-2">
                {articleHeadings.map((heading) => (
                  <li class:list={['rounded-xl transition', heading.depth === 3 ? 'ml-4' : '']}>
                    <a
                      href={`#${heading.slug}`}
                      class:list={[
                        'block rounded-xl border border-transparent px-3 py-2 text-sm leading-6 text-slate-300 transition hover:border-white/10 hover:bg-white/[0.04] hover:text-white',
                        heading.depth === 2 ? 'font-semibold' : 'text-slate-400'
                      ]}
                    >
                      {heading.text}
                    </a>
                  </li>
                ))}
              </ol>
            </nav>
          ) : (
            <p class="mt-4 text-sm leading-7 text-slate-400">Section anchors appear automatically when the article includes subheadings.</p>
          )}
        </div>

        <div class="rounded-[1.5rem] border border-white/10 bg-bg-panel/90 p-5 shadow-[0_14px_40px_rgba(0,0,0,0.22)]">
          <p class="text-xs font-semibold uppercase tracking-[0.28em] text-brand-accent">Delivery Checklist</p>
          <table class="mt-4 w-full text-left text-sm">
            <tbody class="divide-y divide-white/10">
              <tr>
                <th class="py-2 pr-3 font-medium text-slate-400">Heading depth</th>
                <td class="py-2 text-white">H1 with structured H2/H3</td>
              </tr>
              <tr>
                <th class="py-2 pr-3 font-medium text-slate-400">Companion media</th>
                <td class="py-2 text-white">Interactive per section</td>
              </tr>
              <tr>
                <th class="py-2 pr-3 font-medium text-slate-400">Reader support</th>
                <td class="py-2 text-white">TOC + summary map</td>
              </tr>
              <tr>
                <th class="py-2 pr-3 font-medium text-slate-400">Technical style</th>
                <td class="py-2 text-white">Diagram/table/image-ready</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </aside>
  </div>
</article>

<script is:inline>
  (() => {
    const articleRoot = document.querySelector('[data-blog-article]');
    if (!articleRoot) return;

    const escapeHtml = (value) => value
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');

    const normalizeHeadingHierarchy = () => {
      articleRoot.querySelectorAll('h1').forEach((heading) => {
        const replacement = document.createElement('h2');
        Array.from(heading.attributes).forEach((attr) => replacement.setAttribute(attr.name, attr.value));
        replacement.innerHTML = heading.innerHTML;
        heading.replaceWith(replacement);
      });
    };

    const toShortTitle = (value, maxLen = 42) => {
      const normalized = (value || '').trim();
      return escapeHtml((normalized.length > maxLen ? `${normalized.slice(0, maxLen)}...` : normalized).toUpperCase());
    };

    const collectContextText = (heading) => {
      let text = heading.textContent || '';
      let cursor = heading.nextElementSibling;
      let blocks = 0;
      while (cursor && cursor.tagName !== 'H2' && cursor.tagName !== 'H3' && blocks < 3) {
        text += ` ${cursor.textContent || ''}`;
        blocks += 1;
        cursor = cursor.nextElementSibling;
      }
      return text;
    };

    const resolveCompanionModel = (headingTitle, heading) => {
      const text = headingTitle.toLowerCase();
      const foldedText = text.normalize('NFD').replace(/[\u0300-\u036f]/g, '');
      const keywordText = `${text} ${foldedText}`;
      const isMajorSection = heading.tagName === 'H2';
      const baseRows = [
        ['Anchor', heading.id ? `#${heading.id}` : 'Inline section'],
        ['Section level', isMajorSection ? 'Primary' : 'Supporting']
      ];

      if (/(power|ground|gnd|vcc|vdd|voltage|current|supply|battery|rail|polarity|decoupling|potencia|tierra|voltaje|alimentacion|bateria|masa|alimentation|tension|masse|batterie|питан|земл|напряж|батар|мощн|शक्ति|वोल्ट|बैटरी|ग्राउंड|पावर|जमीन)/.test(keywordText)) {
        return {
          key: 'power',
          eyebrow: 'Power And Rail Analysis',
          summary: 'This section focuses on supply integrity, return paths, polarity, and stable power distribution.',
          visualMeta: 'Use this as a rail checklist before final review.',
          rows: [
            ['Focus', 'Power architecture'],
            ['Validate', 'Source, rail labels, return path'],
            ...baseRows
          ]
        };
      }

      if (/(wire|wiring|route|routing|connect|connection|junction|path|net|trace|cable|conexion|ruta|enrut|trayectoria|conex|провод|соедин|маршрут|цепь|путь|कनेक्ट|कनेक्शन|तार|मार्ग|रूट)/.test(keywordText)) {
        return {
          key: 'routing',
          eyebrow: 'Connection Topology',
          summary: 'This section explains net flow, wire clarity, and orthogonal routing decisions.',
          visualMeta: 'Use this to verify wiring logic and crossings.',
          rows: [
            ['Focus', 'Net connectivity'],
            ['Validate', 'Junctions, crossings, and path direction'],
            ...baseRows
          ]
        };
      }

      if (/(symbol|component|resistor|capacitor|inductor|diode|led|transistor|mosfet|op-amp|microcontroller|gate|ic|simbolo|simbol|componente|resistencia|condensador|diodo|microcontrolador|puerta|символ|компонент|резистор|конденс|диод|транзистор|микроконтроллер|логическ|प्रतीक|घटक|रेसिस्ट|कैपेसिटर|डायोड|ट्रांजिस्टर|माइक्रोकंट्रोलर|लॉजिक)/.test(keywordText)) {
        return {
          key: 'symbols',
          eyebrow: 'Component Semantics',
          summary: 'This section maps symbols to functional meaning so readers interpret intent, not only shape.',
          visualMeta: 'Confirm each symbol family matches the expected function.',
          rows: [
            ['Focus', 'Symbol interpretation'],
            ['Validate', 'Part role and naming consistency'],
            ...baseRows
          ]
        };
      }

      if (/(label|annotation|designator|reference|naming|value|pinout|etiqueta|anotacion|referencia|valor|marcado|обознач|маркиров|метк|значен|подпис|लेबल|संदर्भ|मान|नाम|पिन)/.test(keywordText)) {
        return {
          key: 'labeling',
          eyebrow: 'Label Integrity',
          summary: 'This section targets reference designators, readable net names, and consistent value annotations.',
          visualMeta: 'Check labels before handoff to avoid review friction.',
          rows: [
            ['Focus', 'Documentation quality'],
            ['Validate', 'Designators, values, and net names'],
            ...baseRows
          ]
        };
      }

      if (/(export|svg|png|json|download|format|share|publish|output|exportar|descarga|formato|compart|salida|экспорт|формат|выгруз|выход|публика|निर्यात|डाउनलोड|फॉर्मेट|आउटपुट|साझा)/.test(keywordText)) {
        return {
          key: 'export',
          eyebrow: 'Output And Delivery',
          summary: 'This section captures export strategy for handoff, publishing, and long-term maintainability.',
          visualMeta: 'Match output format to where the diagram will be consumed.',
          rows: [
            ['Focus', 'Export workflow'],
            ['Validate', 'Format, readability, and reusability'],
            ...baseRows
          ]
        };
      }

      if (/(mistake|avoid|review|checklist|verify|quality|debug|troubleshoot|best practice|context|conclusion|final|thought|error|errores|evitar|revision|verificar|calidad|depurar|заключ|провер|качест|ошиб|итог|вывод|गलती|बच|समीक्षा|जांच|सत्याप|गुणवत्त|अंतिम|निष्कर्ष)/.test(keywordText)) {
        return {
          key: 'review',
          eyebrow: 'Review And QA',
          summary: 'This section is review-focused: catch readability and correctness issues before publishing.',
          visualMeta: 'Run these checks as a final technical quality pass.',
          rows: [
            ['Focus', 'Quality control'],
            ['Validate', 'Completeness, clarity, and consistency'],
            ...baseRows
          ]
        };
      }

      if (/(step|guide|workflow|process|create|make|build|start|open|paso|guia|proceso|crear|constru|inicio|abrir|шаг|руковод|процесс|созд|сбор|начал|откры|कदम|मार्गदर्श|प्रक्रिया|बन|शुरू|खोल)/.test(keywordText)) {
        return {
          key: 'workflow',
          eyebrow: 'Execution Workflow',
          summary: 'This section describes a procedural flow from setup through validation and delivery.',
          visualMeta: 'Use this sequence while implementing or teaching the section.',
          rows: [
            ['Focus', 'Stepwise execution'],
            ['Validate', 'Order, dependencies, and outcomes'],
            ...baseRows
          ]
        };
      }

      const fallbackKeys = ['workflow', 'review', 'routing', 'labeling'];
      const fallbackIndex = Math.abs(Array.from(keywordText).reduce((acc, ch) => acc + ch.charCodeAt(0), 0)) % fallbackKeys.length;
      const fallbackKey = fallbackKeys[fallbackIndex];

      const fallbackModels = {
        workflow: {
          key: 'workflow',
          eyebrow: 'Context-Derived Workflow',
          summary: 'This section is interpreted as a procedural block with ordered implementation steps.',
          visualMeta: 'Follow the step order to keep execution consistent.',
          rows: [['Focus', 'Context-derived sequence'], ['Validate', 'Step ordering and dependencies'], ...baseRows]
        },
        review: {
          key: 'review',
          eyebrow: 'Context-Derived Review',
          summary: 'This section is interpreted as a quality pass with validation checkpoints.',
          visualMeta: 'Use this card to verify clarity before final publish.',
          rows: [['Focus', 'Context-derived quality check'], ['Validate', 'Accuracy and readability'], ...baseRows]
        },
        routing: {
          key: 'routing',
          eyebrow: 'Context-Derived Topology',
          summary: 'This section is interpreted as a connectivity narrative focused on technical flow.',
          visualMeta: 'Use this card to trace the section logic from input to output.',
          rows: [['Focus', 'Context-derived flow map'], ['Validate', 'Path continuity and endpoint intent'], ...baseRows]
        },
        labeling: {
          key: 'labeling',
          eyebrow: 'Context-Derived Documentation',
          summary: 'This section is interpreted as a documentation block for clear handoff semantics.',
          visualMeta: 'Use this card to keep terms and references consistent.',
          rows: [['Focus', 'Context-derived clarity layer'], ['Validate', 'Terminology and naming coherence'], ...baseRows]
        }
      };

      return fallbackModels[fallbackKey];
    };

    const renderDiagramByType = (type, shortTitle) => {
      if (type === 'power') {
        return `
          <svg class="heading-companion-diagram" viewBox="0 0 760 260" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect x="48" y="78" width="148" height="104" rx="16" fill="#0f172a" stroke="#f59e0b" stroke-width="2.5" />
            <text x="122" y="116" text-anchor="middle" fill="#f8fafc" font-size="14" font-weight="700">SOURCE</text>
            <text x="122" y="138" text-anchor="middle" fill="#94a3b8" font-size="11">${shortTitle}</text>
            <path d="M196 118H360" stroke="#f59e0b" stroke-width="4" stroke-linecap="round" />
            <path d="M196 156H360" stroke="#38bdf8" stroke-width="4" stroke-linecap="round" />
            <rect x="360" y="78" width="162" height="104" rx="16" fill="#0f172a" stroke="#38bdf8" stroke-width="2.5" />
            <text x="441" y="116" text-anchor="middle" fill="#f8fafc" font-size="14" font-weight="700">REGULATE</text>
            <text x="441" y="138" text-anchor="middle" fill="#94a3b8" font-size="11">rail and return path</text>
            <path d="M522 118H692" stroke="#34d399" stroke-width="4" stroke-linecap="round" />
            <path d="M522 156H692" stroke="#34d399" stroke-width="4" stroke-linecap="round" />
            <rect x="612" y="78" width="96" height="104" rx="16" fill="#0f172a" stroke="#34d399" stroke-width="2.5" />
            <text x="660" y="116" text-anchor="middle" fill="#f8fafc" font-size="14" font-weight="700">LOAD</text>
            <text x="660" y="138" text-anchor="middle" fill="#94a3b8" font-size="11">stable rails</text>
          </svg>
        `;
      }

      if (type === 'routing') {
        return `
          <svg class="heading-companion-diagram" viewBox="0 0 760 260" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect x="54" y="82" width="190" height="96" rx="16" fill="#0f172a" stroke="#38bdf8" stroke-width="2.5" />
            <text x="149" y="118" text-anchor="middle" fill="#f8fafc" font-size="14" font-weight="700">NET ENTRY</text>
            <text x="149" y="140" text-anchor="middle" fill="#94a3b8" font-size="11">${shortTitle}</text>
            <path d="M244 130H330V96H470V164H612" stroke="#22d3ee" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
            <circle cx="330" cy="130" r="7" fill="#0f172a" stroke="#22d3ee" stroke-width="2.5" />
            <circle cx="470" cy="96" r="7" fill="#0f172a" stroke="#22d3ee" stroke-width="2.5" />
            <circle cx="470" cy="164" r="7" fill="#0f172a" stroke="#22d3ee" stroke-width="2.5" />
            <rect x="612" y="82" width="98" height="96" rx="16" fill="#0f172a" stroke="#34d399" stroke-width="2.5" />
            <text x="661" y="118" text-anchor="middle" fill="#f8fafc" font-size="14" font-weight="700">TARGET</text>
            <text x="661" y="140" text-anchor="middle" fill="#94a3b8" font-size="11">clean net flow</text>
          </svg>
        `;
      }

      if (type === 'symbols') {
        return `
          <svg class="heading-companion-diagram" viewBox="0 0 760 260" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect x="64" y="74" width="180" height="112" rx="16" fill="#0f172a" stroke="#a78bfa" stroke-width="2.5" />
            <path d="M96 130H212" stroke="#a78bfa" stroke-width="4" />
            <rect x="304" y="74" width="180" height="112" rx="16" fill="#0f172a" stroke="#22d3ee" stroke-width="2.5" />
            <circle cx="394" cy="128" r="28" fill="#0f172a" stroke="#22d3ee" stroke-width="3" />
            <path d="M394 100V156M366 128H422" stroke="#22d3ee" stroke-width="3" />
            <rect x="544" y="74" width="152" height="112" rx="16" fill="#0f172a" stroke="#34d399" stroke-width="2.5" />
            <path d="M578 136h38m0-20v40m18-20h28" stroke="#34d399" stroke-width="3" stroke-linecap="round" />
            <text x="149" y="160" text-anchor="middle" fill="#94a3b8" font-size="11">${shortTitle}</text>
            <text x="394" y="160" text-anchor="middle" fill="#94a3b8" font-size="11">active semantics</text>
            <text x="620" y="160" text-anchor="middle" fill="#94a3b8" font-size="11">io interpretation</text>
          </svg>
        `;
      }

      if (type === 'labeling') {
        return `
          <svg class="heading-companion-diagram" viewBox="0 0 760 260" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect x="86" y="76" width="298" height="108" rx="16" fill="#0f172a" stroke="#38bdf8" stroke-width="2.5" />
            <text x="236" y="113" text-anchor="middle" fill="#f8fafc" font-size="14" font-weight="700">LABEL BLOCK</text>
            <text x="236" y="134" text-anchor="middle" fill="#94a3b8" font-size="11">${shortTitle}</text>
            <rect x="454" y="76" width="226" height="108" rx="16" fill="#0f172a" stroke="#22d3ee" stroke-width="2.5" />
            <text x="567" y="108" text-anchor="middle" fill="#f8fafc" font-size="12" font-weight="700">R1 10k</text>
            <text x="567" y="128" text-anchor="middle" fill="#f8fafc" font-size="12" font-weight="700">NET: SENSE_IN</text>
