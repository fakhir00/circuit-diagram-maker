---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface PostData {
  title: string;
  description: string;
  date: Date;
  author?: string;
  image?: string;
  tags?: string[];
}

interface Props {
  post: {
    data: PostData;
    body?: string;
  };
  Content: any;
  headings?: Heading[];
  locale: string;
}

const { post, Content, headings = [], locale } = Astro.props;
const articleHeadings = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
const sectionHeadings = articleHeadings.filter((heading) => heading.depth === 2);
const primaryTag = post.data.tags?.[0] || 'Engineering';
const normalizedLocale = locale === 'en' ? 'en-US' : locale;
const wordCount = typeof post.body === 'string'
  ? post.body.trim().split(/\s+/).filter(Boolean).length
  : 0;
const readMinutes = Math.max(4, Math.ceil(wordCount / 190));
const isEnglishLocale = locale.toLowerCase().startsWith('en');
const localePrefix = isEnglishLocale ? '' : `/${locale}`;
const homePath = `${localePrefix}/`;
const blogPath = `${localePrefix}/blog/`;
const structurePreview = sectionHeadings.slice(0, 6);
const keyTakeaways = structurePreview.slice(0, 4);
const publishedDate = post.data.date.toLocaleDateString(normalizedLocale, {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<article class="max-w-3xl mx-auto px-4 py-12 md:py-20 lg:py-24">
  <nav aria-label="Breadcrumb" class="flex items-center flex-wrap gap-2 text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-8">
    <a href={homePath} class="hover:text-white transition-colors">Home</a>
    <span>/</span>
    <a href={blogPath} class="hover:text-white transition-colors">Blog</a>
    <span>/</span>
    <span aria-current="page" class="text-white">Article</span>
  </nav>

  <header class="mb-12">
    <div class="inline-flex items-center gap-3 text-[10px] md:text-xs font-mono font-bold text-brand-primary uppercase tracking-wider mb-6 px-4 py-2 bg-brand-primary/10 rounded-full border border-brand-primary/20">
      {primaryTag} <span class="w-1.5 h-1.5 bg-brand-primary rounded-full"></span> {post.data.author || 'Circuit Diagram Maker Team'}
    </div>
    
    <h1 class="text-4xl md:text-5xl lg:text-[3.5rem] font-black text-white leading-[1.1] tracking-tight mb-8">
      {post.data.title}
    </h1>
    
    {post.data.image && (
      <figure class="w-full h-auto rounded-[2rem] overflow-hidden border border-white/10 shadow-2xl mb-12 relative">
         <div class="absolute inset-0 bg-gradient-to-t from-bg-dark/80 via-transparent to-transparent z-10 pointer-events-none"></div>
         <img src={post.data.image} alt={post.data.title} loading="eager" class="w-full h-full object-cover relative z-0" />
      </figure>
    )}

    {articleHeadings.length > 0 && (
      <nav class="bg-bg-surface border border-white/5 shadow-xl rounded-[1.5rem] p-6 md:p-8 mb-8 relative overflow-hidden" aria-label="Table of Contents">
        <div class="absolute top-0 right-0 w-32 h-32 bg-brand-primary/5 blur-3xl -mr-10 -mt-10 pointer-events-none"></div>
        <h4 class="text-xs font-black uppercase tracking-widest text-brand-accent mb-6 flex items-center gap-2">
           <svg class="w-4 h-4 text-brand-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7"/></svg>
           Table of Contents
        </h4>
        <ol class="flex flex-col gap-3 relative z-10">
          {articleHeadings.map((heading) => (
            <li class={`leading-snug ${heading.depth === 3 ? 'ml-6' : ''}`}>
              <a href={`#${heading.slug}`} class="text-slate-300 hover:text-white text-[15px] font-medium transition-colors underline decoration-white/10 underline-offset-4 hover:decoration-white/50 inline-block">
                {heading.text}
              </a>
            </li>
          ))}
        </ol>
      </nav>
    )}

    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-10">
      <div class="bg-bg-panel border border-white/5 rounded-2xl p-5 flex flex-col items-center text-center transition-all hover:bg-bg-surface hover:border-white/10">
        <div class="text-3xl font-black text-white mb-2 tracking-tighter">{readMinutes}</div>
        <div class="text-[9px] font-bold uppercase tracking-widest text-slate-400">Min Read</div>
      </div>
      <div class="bg-bg-panel border border-white/5 rounded-2xl p-5 flex flex-col items-center text-center transition-all hover:bg-bg-surface hover:border-white/10">
        <div class="text-3xl font-black text-white mb-2 tracking-tighter">{wordCount}</div>
        <div class="text-[9px] font-bold uppercase tracking-widest text-slate-400">Words</div>
      </div>
      <div class="bg-bg-panel border border-white/5 rounded-2xl p-5 flex flex-col items-center text-center transition-all hover:bg-bg-surface hover:border-white/10">
        <div class="text-3xl font-black text-white mb-2 tracking-tighter">{sectionHeadings.length}</div>
        <div class="text-[9px] font-bold uppercase tracking-widest text-slate-400">Sections</div>
      </div>
      <div class="bg-bg-panel border border-white/5 rounded-2xl p-5 flex flex-col items-center text-center transition-all hover:bg-bg-surface hover:border-white/10">
        <div class="text-xl font-black text-white mb-2">{post.data.date.toLocaleDateString('en-US', {month: 'short', day: 'numeric'})}</div>
        <div class="text-[9px] font-bold uppercase tracking-widest text-slate-400">Published</div>
      </div>
    </div>
  </header>

  <div class="blog-article" data-blog-article>
    <Content />
  </div>

  <footer class="mt-20 pt-12 border-t border-white/5">
    <div class="bg-gradient-to-br from-bg-surface to-bg-panel border border-white/10 rounded-[2rem] p-8 md:p-10 flex flex-col sm:flex-row gap-8 items-center sm:items-start text-center sm:text-left shadow-2xl mb-12 relative overflow-hidden">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_right,rgba(59,130,246,0.1)_0%,transparent_50%)] pointer-events-none"></div>
      <div class="w-20 h-20 rounded-full bg-gradient-to-tr from-brand-primary to-brand-accent flex items-center justify-center text-3xl font-black text-white shrink-0 shadow-[0_0_20px_rgba(59,130,246,0.3)] border-2 border-white/10 relative z-10">
        {post.data.author ? post.data.author.charAt(0) : 'C'}
      </div>
      <div class="relative z-10">
        <h4 class="text-xl font-black text-white mb-2 tracking-tight">
          <a href="/about-us/" class="hover:text-brand-primary transition-colors">{post.data.author || 'Circuit Diagram Maker Team'}</a>
        </h4>
        <p class="text-slate-400 text-sm md:text-base leading-relaxed mb-0">
          Building free tools for electronics enthusiasts and engineers. Our team focuses on providing intuitive, browser-based circuit design solutions and educational resources for makers worldwide.
        </p>
      </div>
    </div>

    <div class="text-center bg-bg-panel rounded-[2rem] p-10 md:p-14 border border-brand-primary/20 relative overflow-hidden shadow-[0_0_50px_rgba(59,130,246,0.1)]">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(59,130,246,0.15)_0%,transparent_70%)] pointer-events-none"></div>
      <h3 class="text-3xl md:text-4xl font-black text-white mb-5 relative z-10 tracking-tight">Ready to build circuits?</h3>
      <p class="text-slate-300 text-base md:text-lg max-w-xl mx-auto mb-10 relative z-10 leading-relaxed">
        Put your knowledge into practice. Use our free editor to easily sketch, simulate, and export beautiful electronic schematic diagrams directly in your browser.
      </p>
      <a href={`/${isEnglishLocale ? '' : locale + '/'}editor/`} class="inline-flex items-center justify-center gap-3 px-8 py-4 rounded-xl bg-gradient-to-r from-brand-primary to-brand-accent text-white font-bold tracking-widest uppercase text-sm hover:shadow-[0_8px_30px_rgba(59,130,246,0.5)] hover:-translate-y-1 transition-all relative z-10 border border-white/10">
        Open Circuit Editor →
      </a>
    </div>
  </footer>
</article>

<script define:vars={{ locale }}>
  (() => {
    const articleRoot = document.querySelector('[data-blog-article]');
    if (!articleRoot) return;

    const localeCode = String(locale || 'en').toLowerCase();
    const lang = localeCode.startsWith('es')
      ? 'es'
      : localeCode.startsWith('ru')
        ? 'ru'
        : localeCode.startsWith('hi')
          ? 'hi'
          : 'en';

    const i18n = {
      en: {
        blueprint: 'Concept Blueprint',
        tabs: { principle: 'Core Principle', steps: 'Actionable Steps', pitfalls: 'Key Pitfalls' },
        labels: { idea: 'The Big Idea', apply: 'How to Apply This', watch: 'Watch Out For' },
        fallbacks: { step: 'Analyze the surrounding circuit context carefully.', watch: 'Always trace the net connections to verify your assumptions.' }
      },
      es: {
        blueprint: 'Plano Conceptual',
        tabs: { principle: 'Principio Base', steps: 'Pasos a Seguir', pitfalls: 'Riesgos Clave' },
        labels: { idea: 'La Idea Principal', apply: 'Cómo Aplicarlo', watch: 'Presta Atención A' },
        fallbacks: { step: 'Analiza cuidadosamente el contexto del circuito circundante.', watch: 'Siempre rastrea las conexiones para verificar las suposiciones.' }
      },
      ru: {
        blueprint: 'Схема Концепции',
        tabs: { principle: 'Главный Принцип', steps: 'Шаги', pitfalls: 'Ошибки' },
        labels: { idea: 'Главная Идея', apply: 'Как Применить', watch: 'На Что Обратить Внимание' },
        fallbacks: { step: 'Внимательно изучите окружающий контекст цепи.', watch: 'Всегда проверяйте соединения для подтверждения.' }
      },
      hi: {
        blueprint: 'Concept Blueprint',
        tabs: { principle: 'Core Principle', steps: 'Actionable Steps', pitfalls: 'Key Pitfalls' },
        labels: { idea: 'The Big Idea', apply: 'How to Apply This', watch: 'Watch Out For' },
        fallbacks: { step: 'Analyze the surrounding circuit context carefully.', watch: 'Always trace the net connections to verify your assumptions.' }
      }
    };

    const copy = i18n[lang] || i18n.en;

    const escapeHtml = (value) => String(value || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');

    const normalizeHeadingHierarchy = () => {
      articleRoot.querySelectorAll('h1').forEach((heading) => {
        const replacement = document.createElement('h2');
        Array.from(heading.attributes).forEach((attr) => replacement.setAttribute(attr.name, attr.value));
        replacement.innerHTML = heading.innerHTML;
        heading.replaceWith(replacement);
      });
    };

    const tidyText = (value) => String(value || '').replace(/\s+/g, ' ').trim();

    const shorten = (value, maxLength = 108) => {
      const text = tidyText(value);
      if (text.length <= maxLength) return text;
      const sliced = text.slice(0, maxLength);
      const lastSpace = sliced.lastIndexOf(' ');
      return `${sliced.slice(0, lastSpace > 40 ? lastSpace : maxLength).trim()}...`;
    };

    const firstSentence = (value) => {
      const text = tidyText(value);
      if (!text) return '';
      const match = text.match(/.+?[.!?](?:\s|$)/);
      return shorten(match ? match[0] : text, 145);
    };

    const collectSectionText = (heading) => {
      const stopTags = heading.tagName === 'H2' ? ['H2'] : ['H2', 'H3'];
      const parts = [];
      let cursor = heading.nextElementSibling;
      while (cursor && !stopTags.includes(cursor.tagName) && parts.join(' ').length < 900) {
        if (['P', 'BLOCKQUOTE'].includes(cursor.tagName)) {
          parts.push(tidyText(cursor.textContent || ''));
        }
        cursor = cursor.nextElementSibling;
      }
      return tidyText(parts.join(' '));
    };

    const collectListItems = (heading) => {
      const stopTags = heading.tagName === 'H2' ? ['H2'] : ['H2', 'H3'];
      const items = [];
      let cursor = heading.nextElementSibling;
      while (cursor && !stopTags.includes(cursor.tagName) && items.length < 4) {
        if (cursor.tagName === 'UL' || cursor.tagName === 'OL') {
          cursor.querySelectorAll('li').forEach((item) => {
            if (items.length < 4) items.push(shorten(item.textContent || '', 95));
          });
        }
        cursor = cursor.nextElementSibling;
      }
      return items;
    };

    const buildBlueprintCard = (heading, index) => {
      const headingText = tidyText(heading.textContent || `Section ${index + 1}`);
      const sectionText = collectSectionText(heading);
      const listItems = collectListItems(heading);
      
      const intro = firstSentence(sectionText) || shorten(headingText, 130);
      const steps = listItems.length > 0 ? listItems : [copy.fallbacks.step];
      const watchOut = listItems.length > 1 ? listItems[listItems.length - 1] : copy.fallbacks.watch;
      const headingLevel = heading.tagName === 'H2' ? 'major' : 'minor';

      const wrapper = document.createElement('section');
      wrapper.className = `blog-blueprint blog-blueprint--${headingLevel}`;
      wrapper.setAttribute('data-blog-blueprint', '');

      wrapper.innerHTML = `
        <div class="blog-blueprint-head">
          <p>${escapeHtml(copy.blueprint)}</p>
          <h4>${escapeHtml(headingText)}</h4>
        </div>

        <div class="blog-blueprint-tabs" role="tablist">
          <button type="button" class="is-active" data-bp-tab="principle" aria-selected="true">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            ${escapeHtml(copy.tabs.principle)}
          </button>
          <button type="button" data-bp-tab="steps" aria-selected="false">
             <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path></svg>
             ${escapeHtml(copy.tabs.steps)}
          </button>
          <button type="button" data-bp-tab="pitfalls" aria-selected="false">
             <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
             ${escapeHtml(copy.tabs.pitfalls)}
          </button>
        </div>

        <div class="blog-blueprint-content" data-bp-panel="principle">
          <div class="blog-blueprint-card blog-blueprint-card--blue">
            <strong>${escapeHtml(copy.labels.idea)}</strong>
            <p>${escapeHtml(intro)}</p>
          </div>
        </div>

        <div class="blog-blueprint-content hidden" data-bp-panel="steps">
          <div class="blog-blueprint-card blog-blueprint-card--emerald">
             <strong>${escapeHtml(copy.labels.apply)}</strong>
             <ul>
                ${steps.map(li => `<li><span>→</span><aside>${escapeHtml(li)}</aside></li>`).join('')}
             </ul>
          </div>
        </div>

        <div class="blog-blueprint-content hidden" data-bp-panel="pitfalls">
          <div class="blog-blueprint-card blog-blueprint-card--amber">
            <strong>${escapeHtml(copy.labels.watch)}</strong>
            <p>${escapeHtml(watchOut)}</p>
          </div>
        </div>
      `;

      heading.insertAdjacentElement('afterend', wrapper);
    };

    const activateTab = (root, key) => {
      root.querySelectorAll('[data-bp-tab]').forEach((button) => {
        const active = button.getAttribute('data-bp-tab') === key;
        button.classList.toggle('is-active', active);
        button.setAttribute('aria-selected', String(active));
      });

      root.querySelectorAll('[data-bp-panel]').forEach((panel) => {
        panel.classList.toggle('hidden', panel.getAttribute('data-bp-panel') !== key);
      });
    };

    normalizeHeadingHierarchy();

    const headings = Array.from(articleRoot.children).filter((node) => {
      return node instanceof HTMLElement && (node.tagName === 'H2' || node.tagName === 'H3');
    });

    headings.forEach((heading, index) => {
      if (heading.nextElementSibling?.hasAttribute('data-blog-blueprint')) return;
      buildBlueprintCard(heading, index);
    });

    articleRoot.querySelectorAll('[data-blog-blueprint]').forEach((bp) => {
      bp.querySelectorAll('[data-bp-tab]').forEach((button) => {
        button.addEventListener('click', () => {
          activateTab(bp, button.getAttribute('data-bp-tab') || 'principle');
        });
      });
      activateTab(bp, 'principle');
    });
  })();
</script>

<style>
  :global(.blog-article) {
    color: rgb(203 213 225); /* text-slate-300 */
    font-size: 1.12rem;
    line-height: 1.85;
  }

  :global(.blog-article > :first-child) {
    margin-top: 0;
  }

  :global(.blog-article h1),
  :global(.blog-article h2),
  :global(.blog-article h3),
  :global(.blog-article h4),
  :global(.blog-article h5),
  :global(.blog-article h6) {
    color: white;
    letter-spacing: -0.02em;
    scroll-margin-top: 2rem;
    font-weight: 850;
  }

  :global(.blog-article h2) {
    margin-top: 3.5rem;
    margin-bottom: 1.25rem;
    font-size: clamp(2rem, 3.5vw, 2.5rem);
    line-height: 1.15;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }

  :global(.blog-article h3) {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    font-size: clamp(1.4rem, 2.5vw, 1.75rem);
    line-height: 1.25;
  }

  :global(.blog-article p),
  :global(.blog-article ul),
  :global(.blog-article ol),
  :global(.blog-article table),
  :global(.blog-article blockquote),
  :global(.blog-article pre),
  :global(.blog-article figure) {
    margin-top: 1.25rem;
    margin-bottom: 1.25rem;
  }

  :global(.blog-article p) {
    color: rgba(203, 213, 225, 0.95);
  }

  :global(.blog-article ul),
  :global(.blog-article ol) {
    padding-left: 1.5rem;
  }

  :global(.blog-article li) {
    margin: 0.5rem 0;
    padding-left: 0.35rem;
  }

  :global(.blog-article li::marker) {
    color: rgb(59 130 246); /* Blue-500 */
  }

  :global(.blog-article strong) {
    color: white;
    font-weight: 750;
  }

  :global(.blog-article a) {
    color: rgb(125 211 252);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.25em;
  }

  :global(.blog-article a:hover) {
    color: white;
  }

  :global(.blog-article code) {
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 0.4rem;
    background: rgba(255, 255, 255, 0.04);
    padding: 0.2rem 0.4rem;
    font-size: 0.9em;
    color: rgb(167 243 208); /* Emerald 200 */
    word-break: break-word;
  }

  :global(.blog-article pre) {
    overflow-x: auto;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1.25rem;
    background: rgba(2, 6, 23, 0.95);
    padding: 1.25rem 1.5rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.3);
  }

  :global(.blog-article pre code) {
    border: 0;
    padding: 0;
    background: transparent;
    color: rgba(226, 232, 240, 0.98);
    font-size: 0.95rem;
  }

  :global(.blog-article blockquote) {
    margin: 2.5rem 0;
    border-left: 4px solid rgb(56 189 248); /* brand-primary */
    border-radius: 0 1rem 1rem 0;
    background: rgba(56, 189, 248, 0.06);
    padding: 1.5rem;
    color: rgba(226, 232, 240, 0.95);
  }

  :global(.blog-article blockquote::before) {
    content: "💡 Important Note";
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.85rem;
    font-size: 0.85rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgb(56 189 248); /* Primary brand color equivalent */
  }

  :global(.blog-article blockquote p) {
    margin: 0;
    font-size: 1.1rem;
    line-height: 1.7;
    color: inherit;
  }

  :global(.blog-article table) {
    width: 100%;
    margin: 2.5rem 0;
    border-collapse: separate;
    border-spacing: 0;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1.5rem;
    display: block;
    overflow-x: auto;
    box-shadow: 0 10px 30px rgba(0,0,0,0.2);
  }

  :global(.blog-article thead) {
    background: rgba(255, 255, 255, 0.03);
  }

  :global(.blog-article thead th) {
    color: white;
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 1.2rem;
    text-align: left;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  :global(.blog-article th),
  :global(.blog-article td) {
    padding: 1.2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    text-align: left;
    vertical-align: top;
    min-width: 180px;
    background: rgba(15, 23, 42, 0.5); /* Panel bg */
  }

  :global(.blog-article tbody tr:last-child th),
  :global(.blog-article tbody tr:last-child td) {
    border-bottom: 0;
  }

  :global(.blog-article tbody tr:nth-child(even) td),
  :global(.blog-article tbody tr:nth-child(even) th) {
    background: rgba(30, 41, 59, 0.5); /* Slightly lighter panel bg for striping */
  }

  :global(.blog-article hr) {
    margin: 3.5rem 0;
    border: 0;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  :global(.blog-article img) {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.3);
    margin: 2.5rem 0;
  }

  /* Blueprint Interactive Component Styles */
  :global(.blog-article .blog-blueprint) {
    margin: 2.5rem 0 3.5rem;
    border: 1px solid rgba(59, 130, 246, 0.15);
    border-radius: 1.5rem;
    background: linear-gradient(180deg, rgba(15, 23, 42, 0.9), rgba(15, 23, 42, 0.7));
    backdrop-filter: blur(12px);
    padding: 1.5rem;
    box-shadow: 0 10px 40px rgba(59, 130, 246, 0.05);
    transition: all 0.3s ease;
  }
  
  :global(.blog-article .blog-blueprint:hover) {
    border-color: rgba(59, 130, 246, 0.3);
    box-shadow: 0 10px 40px rgba(59, 130, 246, 0.1);
  }

  :global(.blog-article .blog-blueprint--minor) {
