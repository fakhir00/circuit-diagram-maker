---
import BlogSchematicExplorer from './BlogSchematicExplorer.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface PostData {
  title: string;
  description: string;
  date: Date;
  author?: string;
  image?: string;
  tags?: string[];
}

interface Props {
  post: {
    data: PostData;
    body?: string;
  };
  Content: any;
  headings?: Heading[];
  locale: string;
}

const { post, Content, headings = [], locale } = Astro.props;
const articleHeadings = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
const sectionHeadings = articleHeadings.filter((heading) => heading.depth === 2);
const primaryTag = post.data.tags?.[0] || 'Engineering';
const normalizedLocale = locale === 'en' ? 'en-US' : locale;
const wordCount = typeof post.body === 'string'
  ? post.body.trim().split(/\s+/).filter(Boolean).length
  : 0;
const readMinutes = Math.max(4, Math.ceil(wordCount / 190));
const isEnglishLocale = locale.toLowerCase().startsWith('en');
const localePrefix = isEnglishLocale ? '' : `/${locale}`;
const homePath = `${localePrefix}/`;
const blogPath = `${localePrefix}/blog/`;
const structurePreview = sectionHeadings.slice(0, 6);
---

<article class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8">
  <header class="mx-auto max-w-6xl">
    <div class="rounded-[2rem] border border-white/10 bg-[radial-gradient(circle_at_top,rgba(59,130,246,0.12),transparent_45%),linear-gradient(180deg,rgba(15,23,42,0.95),rgba(7,12,21,0.94))] px-6 py-8 shadow-[0_24px_90px_rgba(0,0,0,0.32)] sm:px-8 sm:py-10 lg:px-12">
      <nav aria-label="Breadcrumb" class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-400">
        <a href={homePath} class="hover:text-slate-200 transition-colors">Home</a>
        <span class="mx-2 text-slate-600">/</span>
        <a href={blogPath} class="hover:text-slate-200 transition-colors">Blog</a>
        <span class="mx-2 text-slate-600">/</span>
        <span class="text-slate-300">Article</span>
      </nav>

      <div class="mt-5 flex flex-wrap items-center gap-3 text-[11px] font-semibold uppercase tracking-[0.26em] text-slate-400">
        <span class="rounded-full border border-brand-primary/25 bg-brand-primary/10 px-3 py-1 text-brand-accent">{primaryTag}</span>
        <span class="h-1 w-1 rounded-full bg-slate-600"></span>
        <time datetime={post.data.date.toISOString()}>
          {post.data.date.toLocaleDateString(normalizedLocale, { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <span class="h-1 w-1 rounded-full bg-slate-600"></span>
        <span>{readMinutes} min read</span>
        <span class="h-1 w-1 rounded-full bg-slate-600"></span>
        <span>{post.data.author || 'Circuit Diagram Maker Team'}</span>
      </div>

      <h1 class="mt-6 text-4xl font-black tracking-tight text-white sm:text-5xl lg:text-6xl leading-[1.08]">
        {post.data.title}
      </h1>

      <p class="mt-6 max-w-4xl text-lg leading-8 text-slate-300 sm:text-xl">
        {post.data.description}
      </p>

      <div class="mt-8 grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
        <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-4">
          <p class="text-[10px] uppercase tracking-[0.25em] text-slate-500">Primary Topic</p>
          <p class="mt-2 text-sm font-semibold text-white">{primaryTag}</p>
        </div>
        <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-4">
          <p class="text-[10px] uppercase tracking-[0.25em] text-slate-500">Article Sections</p>
          <p class="mt-2 text-sm font-semibold text-white">{sectionHeadings.length || 'Structured guide'}</p>
        </div>
        <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-4">
          <p class="text-[10px] uppercase tracking-[0.25em] text-slate-500">Read Time</p>
          <p class="mt-2 text-sm font-semibold text-white">{readMinutes} minutes</p>
        </div>
        <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-4">
          <p class="text-[10px] uppercase tracking-[0.25em] text-slate-500">Format</p>
          <p class="mt-2 text-sm font-semibold text-white">Interactive technical article</p>
        </div>
      </div>

      {post.data.tags && post.data.tags.length > 0 && (
        <div class="mt-6 flex flex-wrap gap-2">
          {post.data.tags.slice(0, 6).map((tag) => (
            <span class="rounded-full border border-white/10 bg-white/[0.04] px-3 py-1.5 text-xs font-medium uppercase tracking-[0.16em] text-slate-300">{tag}</span>
          ))}
        </div>
      )}

      {post.data.image && (
        <div class="mt-8 overflow-hidden rounded-[1.5rem] border border-white/10 shadow-2xl">
          <img src={post.data.image} alt={post.data.title} class="h-full w-full object-cover" />
        </div>
      )}
    </div>
  </header>

  <div class="mx-auto mt-10 grid max-w-7xl gap-8 xl:grid-cols-[minmax(0,1fr)_320px]">
    <div class="min-w-0 space-y-8">
      <section class="rounded-[1.7rem] border border-white/10 bg-[linear-gradient(180deg,rgba(9,14,24,0.9),rgba(15,23,42,0.92))] p-6 shadow-[0_16px_50px_rgba(0,0,0,0.22)] sm:p-7">
        <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.28em] text-brand-accent">Article Structure</p>
            <h2 class="mt-2 text-2xl font-bold tracking-tight text-white">Professional reading map</h2>
          </div>
          <span class="text-[11px] uppercase tracking-[0.24em] text-slate-500">H1 + H2/H3 hierarchy</span>
        </div>

        <div class="mt-6 grid gap-3 sm:grid-cols-2">
          {structurePreview.length > 0 ? structurePreview.map((heading, index) => (
            <a href={`#${heading.slug}`} class="group rounded-xl border border-white/10 bg-white/[0.03] p-4 transition hover:border-brand-primary/30 hover:bg-brand-primary/5">
              <p class="text-[10px] uppercase tracking-[0.24em] text-slate-500">Section {index + 1}</p>
              <p class="mt-2 text-sm font-semibold leading-6 text-slate-200 group-hover:text-white">{heading.text}</p>
            </a>
          )) : (
            <div class="rounded-xl border border-white/10 bg-white/[0.03] p-4 text-sm text-slate-300 sm:col-span-2">
              Structured section headings will appear here when the article includes `##` headings.
            </div>
          )}
        </div>
      </section>

      <BlogSchematicExplorer title={post.data.title} tags={post.data.tags || []} />

      <section class="rounded-[2rem] border border-white/10 bg-[linear-gradient(180deg,rgba(15,23,42,0.94),rgba(7,12,21,0.94))] p-6 shadow-[0_20px_80px_rgba(0,0,0,0.22)] sm:p-8">
        <div class="blog-article" data-blog-article>
          <Content />
        </div>
      </section>
    </div>

    <aside class="hidden xl:block">
      <div class="sticky top-24 space-y-5">
        <div class="rounded-[1.5rem] border border-white/10 bg-bg-panel/90 p-5 shadow-[0_14px_40px_rgba(0,0,0,0.22)]">
          <p class="text-xs font-semibold uppercase tracking-[0.28em] text-brand-accent">On This Page</p>
          {articleHeadings.length > 0 ? (
            <nav class="mt-5">
              <ol class="space-y-2">
                {articleHeadings.map((heading) => (
                  <li class:list={['rounded-xl transition', heading.depth === 3 ? 'ml-4' : '']}>
                    <a
                      href={`#${heading.slug}`}
                      class:list={[
                        'block rounded-xl border border-transparent px-3 py-2 text-sm leading-6 text-slate-300 transition hover:border-white/10 hover:bg-white/[0.04] hover:text-white',
                        heading.depth === 2 ? 'font-semibold' : 'text-slate-400'
                      ]}
                    >
                      {heading.text}
                    </a>
                  </li>
                ))}
              </ol>
            </nav>
          ) : (
            <p class="mt-4 text-sm leading-7 text-slate-400">Section anchors appear automatically when the article includes subheadings.</p>
          )}
        </div>

        <div class="rounded-[1.5rem] border border-white/10 bg-bg-panel/90 p-5 shadow-[0_14px_40px_rgba(0,0,0,0.22)]">
          <p class="text-xs font-semibold uppercase tracking-[0.28em] text-brand-accent">Delivery Checklist</p>
          <table class="mt-4 w-full text-left text-sm">
            <tbody class="divide-y divide-white/10">
              <tr>
                <th class="py-2 pr-3 font-medium text-slate-400">Heading depth</th>
                <td class="py-2 text-white">H1 with structured H2/H3</td>
              </tr>
              <tr>
                <th class="py-2 pr-3 font-medium text-slate-400">Companion media</th>
                <td class="py-2 text-white">Interactive per section</td>
              </tr>
              <tr>
                <th class="py-2 pr-3 font-medium text-slate-400">Reader support</th>
                <td class="py-2 text-white">TOC + summary map</td>
              </tr>
              <tr>
                <th class="py-2 pr-3 font-medium text-slate-400">Technical style</th>
                <td class="py-2 text-white">Diagram/table/image-ready</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </aside>
  </div>
</article>

<script is:inline>
  (() => {
    const articleRoot = document.querySelector('[data-blog-article]');
    if (!articleRoot) return;

    const escapeHtml = (value) => value
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');

    const normalizeHeadingHierarchy = () => {
      articleRoot.querySelectorAll('h1').forEach((heading) => {
        const replacement = document.createElement('h2');
        Array.from(heading.attributes).forEach((attr) => replacement.setAttribute(attr.name, attr.value));
        replacement.innerHTML = heading.innerHTML;
        heading.replaceWith(replacement);
      });
    };

    const buildCompanionCard = (heading, index) => {
      const headingTitle = (heading.textContent || `Section ${index + 1}`).trim();
      const safeHeadingTitle = escapeHtml(headingTitle);
      const shortTitle = escapeHtml((headingTitle.length > 44 ? `${headingTitle.slice(0, 44)}...` : headingTitle).toUpperCase());
      const focusType = heading.tagName === 'H2' ? 'Core section' : 'Supporting detail';
      const reviewPriority = heading.tagName === 'H2' ? 'High' : 'Medium';
      const tableRows = [
        ['Section type', focusType],
        ['Review priority', reviewPriority],
        ['Anchor', heading.id ? `#${heading.id}` : 'Inline section'],
        ['Workflow', 'Read -> Validate -> Export']
      ];

      const companion = document.createElement('section');
      companion.className = 'heading-companion';
      companion.setAttribute('data-heading-companion', '');

      companion.innerHTML = `
        <div class="heading-companion-head">
          <p class="heading-companion-eyebrow">Interactive Section Companion</p>
          <h4 class="heading-companion-title">${safeHeadingTitle}</h4>
          <p class="heading-companion-summary">Use the tabs to inspect this section through a diagram, a fast reference table, and a visual snapshot panel.</p>
        </div>

        <div class="heading-companion-tabs" role="tablist" aria-label="Interactive companion tabs">
          <button type="button" class="heading-companion-tab" data-companion-tab="diagram" aria-selected="true">Diagram</button>
          <button type="button" class="heading-companion-tab" data-companion-tab="table" aria-selected="false">Table</button>
          <button type="button" class="heading-companion-tab" data-companion-tab="visual" aria-selected="false">Visual</button>
        </div>

        <div class="heading-companion-panel" data-companion-panel="diagram">
          <svg class="heading-companion-diagram" viewBox="0 0 760 260" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect x="46" y="88" width="182" height="84" rx="16" fill="#0f172a" stroke="#38bdf8" stroke-width="2.5" />
            <text x="137" y="126" text-anchor="middle" fill="#f8fafc" font-size="15" font-weight="700">Section</text>
            <text x="137" y="146" text-anchor="middle" fill="#94a3b8" font-size="11">${shortTitle}</text>
            <path d="M228 130H388" stroke="#38bdf8" stroke-width="4" stroke-linecap="round" />
            <rect x="388" y="88" width="158" height="84" rx="16" fill="#0f172a" stroke="#22d3ee" stroke-width="2.5" />
            <text x="467" y="123" text-anchor="middle" fill="#f8fafc" font-size="14" font-weight="700">Diagram Check</text>
            <text x="467" y="145" text-anchor="middle" fill="#94a3b8" font-size="11">Signal and path clarity</text>
            <path d="M546 130H710" stroke="#22d3ee" stroke-width="4" stroke-linecap="round" />
            <rect x="612" y="88" width="102" height="84" rx="16" fill="#0f172a" stroke="#34d399" stroke-width="2.5" />
            <text x="663" y="123" text-anchor="middle" fill="#f8fafc" font-size="14" font-weight="700">Ready</text>
            <text x="663" y="145" text-anchor="middle" fill="#94a3b8" font-size="11">Publish pass</text>
          </svg>
        </div>

        <div class="heading-companion-panel hidden" data-companion-panel="table">
          <div class="heading-companion-table-wrap">
            <table class="heading-companion-table">
              <tbody>
                ${tableRows.map(([left, right]) => `
                  <tr>
                    <th>${escapeHtml(left)}</th>
                    <td>${escapeHtml(right)}</td>
                  </tr>
                `).join('')}
              </tbody>
            </table>
          </div>
        </div>

        <div class="heading-companion-panel hidden" data-companion-panel="visual">
          <figure class="heading-companion-visual" role="img" aria-label="Visual section summary for ${safeHeadingTitle}">
            <div class="heading-companion-visual-grid"></div>
            <figcaption>
              <p class="heading-companion-visual-title">Snapshot</p>
              <p class="heading-companion-visual-copy">${safeHeadingTitle}</p>
              <p class="heading-companion-visual-meta">This visual card marks this section as documented, reviewable, and export-ready.</p>
            </figcaption>
          </figure>
        </div>
      `;

      heading.insertAdjacentElement('afterend', companion);
    };

    const activateCompanionTab = (companion, activeKey) => {
      const tabs = companion.querySelectorAll('[data-companion-tab]');
      const panels = companion.querySelectorAll('[data-companion-panel]');

      tabs.forEach((tab) => {
        const isActive = tab.getAttribute('data-companion-tab') === activeKey;
        tab.setAttribute('aria-selected', String(isActive));
        tab.classList.toggle('is-active', isActive);
      });

      panels.forEach((panel) => {
        const isActive = panel.getAttribute('data-companion-panel') === activeKey;
        panel.classList.toggle('hidden', !isActive);
      });
    };

    normalizeHeadingHierarchy();

    const headingNodes = Array.from(articleRoot.children).filter((node) => {
      return node instanceof HTMLElement && (node.tagName === 'H2' || node.tagName === 'H3');
    });

    headingNodes.forEach((heading, index) => {
      if (heading.getAttribute('data-companion-ready') === 'true') return;
      buildCompanionCard(heading, index);
      heading.setAttribute('data-companion-ready', 'true');
    });

    articleRoot.querySelectorAll('[data-heading-companion]').forEach((companion) => {
      const tabs = companion.querySelectorAll('[data-companion-tab]');
      tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          const key = tab.getAttribute('data-companion-tab') || 'diagram';
          activateCompanionTab(companion, key);
        });
      });
      activateCompanionTab(companion, 'diagram');
    });
  })();
</script>

<style>
  :global(.blog-article) {
    color: rgb(203 213 225);
    font-size: 1.05rem;
    line-height: 1.9;
  }

  :global(.blog-article > :first-child) {
    margin-top: 0;
  }

  :global(.blog-article h1) {
    margin-top: 3rem;
    margin-bottom: 1rem;
    font-size: clamp(1.8rem, 2.5vw, 2.3rem);
    line-height: 1.2;
    color: white;
    font-weight: 800;
  }

  :global(.blog-article h2),
  :global(.blog-article h3),
  :global(.blog-article h4),
  :global(.blog-article h5),
  :global(.blog-article h6) {
    scroll-margin-top: 7rem;
    color: white;
    letter-spacing: -0.02em;
  }

  :global(.blog-article h2) {
    margin-top: 3rem;
    margin-bottom: 1.1rem;
    padding-left: 0.9rem;
    border-left: 3px solid rgba(96, 165, 250, 0.9);
    font-size: clamp(1.9rem, 2.6vw, 2.4rem);
    line-height: 1.15;
    font-weight: 800;
  }

  :global(.blog-article h3) {
    margin-top: 2.2rem;
    margin-bottom: 0.85rem;
    font-size: clamp(1.35rem, 2vw, 1.7rem);
    line-height: 1.25;
    font-weight: 750;
  }

  :global(.blog-article h4),
  :global(.blog-article h5),
  :global(.blog-article h6) {
    margin-top: 1.6rem;
    margin-bottom: 0.7rem;
    font-size: 1.05rem;
    line-height: 1.4;
    font-weight: 700;
  }

  :global(.blog-article p),
  :global(.blog-article ul),
  :global(.blog-article ol),
  :global(.blog-article table),
  :global(.blog-article blockquote),
  :global(.blog-article pre) {
    margin-top: 1rem;
    margin-bottom: 1rem;
  }

  :global(.blog-article p) {
    color: rgba(203, 213, 225, 0.95);
  }

  :global(.blog-article ul),
  :global(.blog-article ol) {
    padding-left: 1.25rem;
  }

  :global(.blog-article li) {
    margin: 0.6rem 0;
    padding-left: 0.25rem;
  }

  :global(.blog-article li::marker) {
    color: rgba(96, 165, 250, 0.92);
  }

  :global(.blog-article strong) {
    color: white;
    font-weight: 700;
  }

  :global(.blog-article a) {
    color: rgb(125 211 252);
    text-decoration: none;
    border-bottom: 1px solid rgba(125, 211, 252, 0.28);
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  :global(.blog-article a:hover) {
    color: white;
    border-color: rgba(255, 255, 255, 0.4);
  }

  :global(.blog-article code) {
    border: 1px solid rgba(148, 163, 184, 0.14);
    background: rgba(15, 23, 42, 0.8);
    border-radius: 0.5rem;
    padding: 0.16rem 0.42rem;
    color: rgb(165 243 252);
    font-size: 0.92em;
  }

  :global(.blog-article pre) {
    overflow-x: auto;
    border: 1px solid rgba(148, 163, 184, 0.14);
    background: linear-gradient(180deg, rgba(7, 12, 21, 0.98), rgba(15, 23, 42, 0.92));
    border-radius: 1.1rem;
    padding: 1rem 1.1rem;
  }

  :global(.blog-article pre code) {
    border: 0;
    background: transparent;
    padding: 0;
    color: rgb(226 232 240);
  }

  :global(.blog-article blockquote) {
    border: 1px solid rgba(34, 211, 238, 0.2);
    background: linear-gradient(180deg, rgba(8, 47, 73, 0.35), rgba(8, 47, 73, 0.16));
    border-left: 3px solid rgba(52, 211, 153, 0.7);
    border-radius: 1rem;
    padding: 1rem 1.1rem;
    color: rgba(224, 242, 254, 0.92);
  }

  :global(.blog-article blockquote p) {
    margin: 0;
  }

  :global(.blog-article table) {
    width: 100%;
    overflow: hidden;
    border-collapse: separate;
    border-spacing: 0;
    border: 1px solid rgba(99, 102, 241, 0.18);
    border-radius: 1rem;
    background: linear-gradient(180deg, rgba(29, 26, 63, 0.72), rgba(15, 23, 42, 0.82));
    font-size: 0.97rem;
  }

  :global(.blog-article thead th) {
    background: rgba(79, 70, 229, 0.16);
    color: rgb(224 231 255);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  :global(.blog-article th),
  :global(.blog-article td) {
    border-bottom: 1px solid rgba(148, 163, 184, 0.12);
    padding: 0.95rem 1rem;
    text-align: left;
    vertical-align: top;
  }

  :global(.blog-article tbody tr:last-child td),
  :global(.blog-article tbody tr:last-child th) {
    border-bottom: 0;
  }

  :global(.blog-article tbody tr:nth-child(even) td),
  :global(.blog-article tbody tr:nth-child(even) th) {
    background: rgba(255, 255, 255, 0.02);
  }

  :global(.blog-article hr) {
    margin: 2.4rem 0;
    border: 0;
    border-top: 1px solid rgba(148, 163, 184, 0.14);
  }

  :global(.blog-article img) {
    border: 1px solid rgba(148, 163, 184, 0.12);
    border-radius: 1.25rem;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.24);
  }

  :global(.blog-article .heading-companion) {
    margin: 0.9rem 0 1.6rem;
    border-radius: 1.1rem;
    border: 1px solid rgba(148, 163, 184, 0.2);
    background: linear-gradient(180deg, rgba(8, 14, 27, 0.9), rgba(6, 12, 22, 0.88));
    padding: 1rem;
  }

  :global(.blog-article .heading-companion-head) {
    margin-bottom: 0.8rem;
  }

  :global(.blog-article .heading-companion-eyebrow) {
    margin: 0;
    font-size: 0.66rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(125, 211, 252, 0.88);
    font-weight: 700;
  }

  :global(.blog-article .heading-companion-title) {
    margin: 0.45rem 0 0;
    color: white;
    font-size: 1rem;
    line-height: 1.35;
    font-weight: 700;
  }

  :global(.blog-article .heading-companion-summary) {
    margin: 0.45rem 0 0;
    font-size: 0.88rem;
    line-height: 1.55;
    color: rgba(148, 163, 184, 0.95);
  }

  :global(.blog-article .heading-companion-tabs) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-bottom: 0.8rem;
  }

  :global(.blog-article .heading-companion-tab) {
    border: 1px solid rgba(148, 163, 184, 0.25);
    background: rgba(15, 23, 42, 0.75);
    color: rgba(203, 213, 225, 0.92);
    border-radius: 999px;
    padding: 0.32rem 0.72rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: all 0.2s ease;
    cursor: pointer;
  }

  :global(.blog-article .heading-companion-tab.is-active) {
    border-color: rgba(56, 189, 248, 0.62);
    background: rgba(14, 116, 144, 0.25);
    color: white;
  }

  :global(.blog-article .heading-companion-panel.hidden) {
    display: none;
  }

  :global(.blog-article .heading-companion-diagram) {
