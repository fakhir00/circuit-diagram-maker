            <path d="M384 106H454M384 128H454M384 150H454" stroke="#22d3ee" stroke-width="3" stroke-linecap="round" />
          </svg>
        `;
      }

      if (type === 'export') {
        return `
          <svg class="heading-companion-diagram" viewBox="0 0 760 260" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect x="64" y="78" width="244" height="104" rx="16" fill="#0f172a" stroke="#38bdf8" stroke-width="2.5" />
            <text x="186" y="118" text-anchor="middle" fill="#f8fafc" font-size="14" font-weight="700">EDITOR OUTPUT</text>
            <text x="186" y="140" text-anchor="middle" fill="#94a3b8" font-size="11">${shortTitle}</text>
            <path d="M308 130H456" stroke="#22d3ee" stroke-width="4" stroke-linecap="round" />
            <rect x="456" y="66" width="98" height="56" rx="10" fill="#0f172a" stroke="#34d399" stroke-width="2.5" />
            <text x="505" y="100" text-anchor="middle" fill="#f8fafc" font-size="12" font-weight="700">SVG</text>
            <rect x="456" y="128" width="98" height="56" rx="10" fill="#0f172a" stroke="#f59e0b" stroke-width="2.5" />
            <text x="505" y="162" text-anchor="middle" fill="#f8fafc" font-size="12" font-weight="700">PNG</text>
            <rect x="568" y="97" width="98" height="56" rx="10" fill="#0f172a" stroke="#a78bfa" stroke-width="2.5" />
            <text x="617" y="131" text-anchor="middle" fill="#f8fafc" font-size="12" font-weight="700">JSON</text>
          </svg>
        `;
      }

      if (type === 'review') {
        return `
          <svg class="heading-companion-diagram" viewBox="0 0 760 260" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect x="56" y="72" width="648" height="116" rx="18" fill="#0f172a" stroke="#334155" stroke-width="2.5" />
            <path d="M120 108H588" stroke="#38bdf8" stroke-width="4" />
            <path d="M120 132H636" stroke="#22d3ee" stroke-width="4" />
            <path d="M120 156H544" stroke="#f59e0b" stroke-width="4" />
            <circle cx="612" cy="108" r="12" fill="#0f172a" stroke="#34d399" stroke-width="3" />
            <circle cx="658" cy="132" r="12" fill="#0f172a" stroke="#34d399" stroke-width="3" />
            <circle cx="568" cy="156" r="12" fill="#0f172a" stroke="#34d399" stroke-width="3" />
            <text x="146" y="97" fill="#94a3b8" font-size="11">${shortTitle}</text>
            <text x="146" y="121" fill="#94a3b8" font-size="11">clarity review</text>
            <text x="146" y="145" fill="#94a3b8" font-size="11">consistency review</text>
          </svg>
        `;
      }

      if (type === 'workflow') {
        return `
          <svg class="heading-companion-diagram" viewBox="0 0 760 260" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect x="50" y="84" width="134" height="92" rx="14" fill="#0f172a" stroke="#38bdf8" stroke-width="2.5" />
            <text x="117" y="118" text-anchor="middle" fill="#f8fafc" font-size="13" font-weight="700">START</text>
            <text x="117" y="140" text-anchor="middle" fill="#94a3b8" font-size="11">${shortTitle}</text>
            <path d="M184 130H282M340 130H438M496 130H594" stroke="#22d3ee" stroke-width="4" stroke-linecap="round" />
            <rect x="282" y="84" width="58" height="92" rx="14" fill="#0f172a" stroke="#22d3ee" stroke-width="2.5" />
            <text x="311" y="126" text-anchor="middle" fill="#f8fafc" font-size="12" font-weight="700">1</text>
            <rect x="438" y="84" width="58" height="92" rx="14" fill="#0f172a" stroke="#f59e0b" stroke-width="2.5" />
            <text x="467" y="126" text-anchor="middle" fill="#f8fafc" font-size="12" font-weight="700">2</text>
            <rect x="594" y="84" width="116" height="92" rx="14" fill="#0f172a" stroke="#34d399" stroke-width="2.5" />
            <text x="652" y="118" text-anchor="middle" fill="#f8fafc" font-size="13" font-weight="700">DELIVER</text>
            <text x="652" y="140" text-anchor="middle" fill="#94a3b8" font-size="11">validated result</text>
