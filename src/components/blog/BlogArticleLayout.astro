---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface PostData {
  title: string;
  description: string;
  date: Date;
  author?: string;
  image?: string;
  tags?: string[];
}

interface Props {
  post: {
    data: PostData;
    body?: string;
  };
  Content: any;
  headings?: Heading[];
  locale: string;
}

const { post, Content, headings = [], locale } = Astro.props;
const articleHeadings = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
const sectionHeadings = articleHeadings.filter((heading) => heading.depth === 2);
const primaryTag = post.data.tags?.[0] || 'Engineering';
const normalizedLocale = locale === 'en' ? 'en-US' : locale;
const wordCount = typeof post.body === 'string'
  ? post.body.trim().split(/\s+/).filter(Boolean).length
  : 0;
const readMinutes = Math.max(4, Math.ceil(wordCount / 190));
const isEnglishLocale = locale.toLowerCase().startsWith('en');
const localePrefix = isEnglishLocale ? '' : `/${locale}`;
const homePath = `${localePrefix}/`;
const blogPath = `${localePrefix}/blog/`;
const structurePreview = sectionHeadings.slice(0, 6);
const keyTakeaways = structurePreview.slice(0, 4);
const publishedDate = post.data.date.toLocaleDateString(normalizedLocale, {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<article class="blog-shell">
  <header class="blog-hero">
    <nav aria-label="Breadcrumb" class="blog-breadcrumbs">
      <a href={homePath}>Home</a>
      <span>/</span>
      <a href={blogPath}>Blog</a>
      <span>/</span>
      <span aria-current="page">Article</span>
    </nav>

    <div class="blog-kicker-row">
      <span class="blog-kicker">{primaryTag}</span>
      <span class="blog-meta-dot"></span>
      <time datetime={post.data.date.toISOString()}>{publishedDate}</time>
      <span class="blog-meta-dot"></span>
      <span>{readMinutes} min read</span>
      <span class="blog-meta-dot"></span>
      <span>{post.data.author || 'Circuit Diagram Maker Team'}</span>
    </div>

    <div class="blog-hero-grid">
      <div>
        <h1 class="blog-title">{post.data.title}</h1>
        <p class="blog-description">{post.data.description}</p>

        {post.data.tags && post.data.tags.length > 0 && (
          <div class="blog-tag-list">
            {post.data.tags.slice(0, 6).map((tag) => (
              <span class="blog-tag">{tag}</span>
            ))}
          </div>
        )}
      </div>

      <aside class="blog-summary-card" aria-label="Article overview">
        <p class="blog-summary-label">Article Snapshot</p>
        <dl class="blog-summary-grid">
          <div>
            <dt>Sections</dt>
            <dd>{sectionHeadings.length || 'Structured guide'}</dd>
          </div>
          <div>
            <dt>Reading time</dt>
            <dd>{readMinutes} minutes</dd>
          </div>
          <div>
            <dt>Topic</dt>
            <dd>{primaryTag}</dd>
          </div>
          <div>
            <dt>Format</dt>
            <dd>Article + section explainers</dd>
          </div>
        </dl>
      </aside>
    </div>

    {post.data.image && (
      <figure class="blog-hero-media">
        <img src={post.data.image} alt={post.data.title} loading="eager" />
      </figure>
    )}
  </header>

  <div class="blog-grid">
    <main class="blog-main">
      <section class="blog-map-card" aria-labelledby="article-map-title">
        <div class="blog-map-head">
          <div>
            <p class="blog-section-label">Reading Map</p>
            <h2 id="article-map-title">What this article covers</h2>
          </div>
          <p class="blog-map-copy">Use the section map to jump into the topic quickly, then read the in-line explainers beneath each heading for diagrams and reference tables.</p>
        </div>

        <div class="blog-map-grid">
          {keyTakeaways.length > 0 ? keyTakeaways.map((heading, index) => (
            <a href={`#${heading.slug}`} class="blog-map-item">
              <span>0{index + 1}</span>
              <strong>{heading.text}</strong>
            </a>
          )) : (
            <div class="blog-map-empty">
              Add `##` headings to show a section map here.
            </div>
          )}
        </div>
      </section>

      <section class="blog-body-card">
        <div class="blog-article" data-blog-article>
          <Content />
        </div>
      </section>
    </main>

    <aside class="blog-sidebar" aria-label="Article sidebar">
      <div class="blog-sidebar-stack">
        <section class="blog-sidebar-card">
          <p class="blog-section-label">Table of Content</p>
          {articleHeadings.length > 0 ? (
            <nav class="blog-toc" aria-label="Table of contents">
              <ol>
                {articleHeadings.map((heading) => (
                  <li class:list={[heading.depth === 3 ? 'is-subheading' : '']}>
                    <a href={`#${heading.slug}`}>{heading.text}</a>
                  </li>
                ))}
              </ol>
            </nav>
          ) : (
            <p class="blog-sidebar-empty">Headings appear here automatically when the article includes subheadings.</p>
          )}
        </section>

        <section class="blog-sidebar-card">
          <p class="blog-section-label">Article Standards</p>
          <table class="blog-sidebar-table">
            <tbody>
              <tr>
                <th>Hierarchy</th>
                <td>Single page H1 with structured H2/H3 sections</td>
              </tr>
              <tr>
                <th>Support</th>
                <td>Sticky TOC plus per-heading explainer cards</td>
              </tr>
              <tr>
                <th>Format</th>
                <td>Readable prose, responsive tables, wrapped diagrams</td>
              </tr>
            </tbody>
          </table>
        </section>
      </div>
    </aside>
  </div>
</article>

<script define:vars={{ locale }}>
  (() => {
    const articleRoot = document.querySelector('[data-blog-article]');
    if (!articleRoot) return;

    const localeCode = String(locale || 'en').toLowerCase();
    const lang = localeCode.startsWith('es')
      ? 'es'
      : localeCode.startsWith('ru')
        ? 'ru'
        : localeCode.startsWith('hi')
          ? 'hi'
          : 'en';

    const i18n = {
      en: {
        explainer: 'Section explainer',
        tabs: { diagram: 'Diagram', table: 'Table' },
        diagramTitle: 'Section flow',
        tableTitle: 'Quick reference',
        rows: {
          focus: 'Section focus',
          key: 'Key point',
          watch: 'What to watch',
          apply: 'How to use it',
          risk: 'Common pitfall'
        },
        nodes: {
          idea: 'Core idea',
          meaning: 'Meaning',
          usage: 'Usage',
          start: 'Start',
          process: 'Process',
          verify: 'Verify',
          compare: 'Compare',
          difference: 'Difference',
          bestFit: 'Best fit',
          path: 'Path',
          control: 'Control',
          result: 'Result',
          check: 'Check',
          fix: 'Fix',
          outcome: 'Outcome'
        }
      },
      es: {
        explainer: 'Explicador de seccion',
        tabs: { diagram: 'Diagrama', table: 'Tabla' },
        diagramTitle: 'Flujo de la seccion',
        tableTitle: 'Referencia rapida',
        rows: {
          focus: 'Enfoque',
          key: 'Punto clave',
          watch: 'Que revisar',
          apply: 'Como usarlo',
          risk: 'Error comun'
        },
        nodes: {
          idea: 'Idea central',
          meaning: 'Significado',
          usage: 'Uso',
          start: 'Inicio',
          process: 'Proceso',
          verify: 'Verificar',
          compare: 'Comparar',
          difference: 'Diferencia',
          bestFit: 'Mejor uso',
          path: 'Ruta',
          control: 'Control',
          result: 'Resultado',
          check: 'Revisar',
          fix: 'Corregir',
          outcome: 'Resultado'
        }
      },
      ru: {
        explainer: 'Poyasnenie razdela',
        tabs: { diagram: 'Skhema', table: 'Tablitsa' },
        diagramTitle: 'Logika razdela',
        tableTitle: 'Bystraya spravka',
        rows: {
          focus: 'Tema razdela',
          key: 'Glavnaya mysl',
          watch: 'Na chto smotret',
          apply: 'Kak primenit',
          risk: 'Chastaya oshibka'
        },
        nodes: {
          idea: 'Ideya',
          meaning: 'Smysl',
          usage: 'Primenenie',
          start: 'Start',
          process: 'Protsess',
          verify: 'Proverka',
          compare: 'Sravnenie',
          difference: 'Raznitsa',
          bestFit: 'Luchshiy variant',
          path: 'Put',
          control: 'Upravlenie',
          result: 'Rezultat',
          check: 'Proverit',
          fix: 'Ispravit',
          outcome: 'Itog'
        }
      },
      hi: {
        explainer: 'Section guide',
        tabs: { diagram: 'Diagram', table: 'Table' },
        diagramTitle: 'Section flow',
        tableTitle: 'Quick reference',
        rows: {
          focus: 'Section focus',
          key: 'Key point',
          watch: 'What to watch',
          apply: 'How to use it',
          risk: 'Common pitfall'
        },
        nodes: {
          idea: 'Core idea',
          meaning: 'Meaning',
          usage: 'Usage',
          start: 'Start',
          process: 'Process',
          verify: 'Verify',
          compare: 'Compare',
          difference: 'Difference',
          bestFit: 'Best fit',
          path: 'Path',
          control: 'Control',
          result: 'Result',
          check: 'Check',
          fix: 'Fix',
          outcome: 'Outcome'
        }
      }
    };

    const copy = i18n[lang] || i18n.en;

    const escapeHtml = (value) => String(value || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');

    const normalizeHeadingHierarchy = () => {
      articleRoot.querySelectorAll('h1').forEach((heading) => {
        const replacement = document.createElement('h2');
        Array.from(heading.attributes).forEach((attr) => replacement.setAttribute(attr.name, attr.value));
        replacement.innerHTML = heading.innerHTML;
        heading.replaceWith(replacement);
      });
    };

    const tidyText = (value) => String(value || '').replace(/\s+/g, ' ').trim();

    const shorten = (value, maxLength = 108) => {
      const text = tidyText(value);
      if (text.length <= maxLength) return text;
      const sliced = text.slice(0, maxLength);
      const lastSpace = sliced.lastIndexOf(' ');
      return `${sliced.slice(0, lastSpace > 40 ? lastSpace : maxLength).trim()}...`;
    };

    const firstSentence = (value) => {
      const text = tidyText(value);
      if (!text) return '';
      const match = text.match(/.+?[.!?](?:\s|$)/);
      return shorten(match ? match[0] : text, 145);
    };

    const collectSectionText = (heading) => {
      const stopTags = heading.tagName === 'H2' ? ['H2'] : ['H2', 'H3'];
      const parts = [];
      let cursor = heading.nextElementSibling;

      while (cursor && !stopTags.includes(cursor.tagName) && parts.join(' ').length < 900) {
        if (['P', 'UL', 'OL', 'BLOCKQUOTE', 'TABLE'].includes(cursor.tagName)) {
          parts.push(tidyText(cursor.textContent || ''));
        }
        cursor = cursor.nextElementSibling;
      }

      return tidyText(parts.join(' '));
    };

    const collectListItems = (heading) => {
      const stopTags = heading.tagName === 'H2' ? ['H2'] : ['H2', 'H3'];
      const items = [];
      let cursor = heading.nextElementSibling;

      while (cursor && !stopTags.includes(cursor.tagName) && items.length < 4) {
        if (cursor.tagName === 'UL' || cursor.tagName === 'OL') {
          cursor.querySelectorAll('li').forEach((item) => {
            if (items.length < 4) {
              items.push(shorten(item.textContent || '', 80));
            }
          });
        }
        cursor = cursor.nextElementSibling;
      }

      return items;
    };

    const pickKeyword = (headingText, sectionText) => {
      const text = `${headingText} ${sectionText}`.toLowerCase();

      if (/(step|how to|draw|build|create|read|workflow|practice|process|guide|best practice)/.test(text)) return 'workflow';
      if (/(vs|versus|difference|compare|distinguish|n-channel|p-channel)/.test(text)) return 'comparison';
      if (/(mistake|avoid|wrong|review|check|final thought|troubleshoot|problem)/.test(text)) return 'review';
      if (/(application|applications|use case|used in|where used|typical uses|common uses)/.test(text)) return 'application';
      if (/(power|ground|rail|supply|noise|emi|signal|current|voltage|filter|analog|digital)/.test(text)) return 'path';
      if (/(symbol|terminal|gate|drain|source|emitter|collector|base|resistor|capacitor|diode|transistor|mosfet|jfet|led|component)/.test(text)) return 'symbol';
      return 'concept';
    };

    const buildRows = (kind, headingText, sectionText, listItems) => {
      const corePoint = firstSentence(sectionText) || shorten(headingText, 130);
      const bulletSummary = listItems.length > 0 ? listItems.join(' | ') : '';
      const fallbackApply = bulletSummary || 'Use the section notes and surrounding labels to confirm the diagram intent.';

      if (kind === 'workflow') {
        return [
          [copy.rows.focus, headingText],
          [copy.rows.key, corePoint],
          [copy.rows.watch, listItems[0] || 'Follow the order shown in the section before moving to the next block.'],
          [copy.rows.apply, fallbackApply]
        ];
      }

      if (kind === 'comparison') {
        return [
          [copy.rows.focus, headingText],
          [copy.rows.key, corePoint],
          [copy.rows.watch, listItems[0] || 'Look for the difference in labels, arrow direction, or surrounding context.'],
          [copy.rows.apply, listItems[1] || 'Choose the interpretation that matches the surrounding circuit role.']
        ];
      }

      if (kind === 'review') {
        return [
          [copy.rows.focus, headingText],
          [copy.rows.key, corePoint],
          [copy.rows.risk, listItems[0] || 'Readers usually get stuck when labels or context are missing.'],
          [copy.rows.apply, listItems[1] || 'Use designators, values, and nearby nets to confirm meaning.']
        ];
      }

      if (kind === 'application') {
        return [
          [copy.rows.focus, headingText],
          [copy.rows.key, corePoint],
          [copy.rows.watch, listItems[0] || 'Match the component or method to the part of the circuit it is helping.'],
          [copy.rows.apply, listItems[1] || 'Use the surrounding circuit goal to decide whether this application fits.']
        ];
      }

      if (kind === 'path') {
        return [
          [copy.rows.focus, headingText],
          [copy.rows.key, corePoint],
          [copy.rows.watch, listItems[0] || 'Trace the entry path, filtered path, and protected block.'],
          [copy.rows.apply, listItems[1] || 'Read the section from source to destination rather than one isolated symbol at a time.']
        ];
      }

      if (kind === 'symbol') {
        return [
          [copy.rows.focus, headingText],
          [copy.rows.key, corePoint],
          [copy.rows.watch, listItems[0] || 'Check reference labels and terminal names first.'],
          [copy.rows.apply, listItems[1] || 'Use the surrounding circuit role to distinguish similar-looking parts.']
        ];
      }

      return [
        [copy.rows.focus, headingText],
        [copy.rows.key, corePoint],
        [copy.rows.watch, listItems[0] || 'Identify the part, path, or behavior the section is explaining.'],
        [copy.rows.apply, listItems[1] || fallbackApply]
      ];
    };

    const buildDiagramStages = (kind, headingText, sectionText, listItems) => {
      const core = firstSentence(sectionText) || shorten(headingText, 120);
      const support = listItems[0] || shorten(sectionText, 88);
      const result = listItems[1] || 'Use the surrounding labels and circuit context to confirm the takeaway.';

      if (kind === 'workflow') {
        return [
          { label: copy.nodes.start, value: shorten(headingText, 64), tone: 'blue' },
          { label: copy.nodes.process, value: shorten(core, 92), tone: 'cyan' },
          { label: copy.nodes.verify, value: shorten(result, 88), tone: 'green' }
        ];
      }

      if (kind === 'comparison') {
        return [
          { label: copy.nodes.compare, value: shorten(headingText, 64), tone: 'blue' },
          { label: copy.nodes.difference, value: shorten(core, 92), tone: 'amber' },
          { label: copy.nodes.bestFit, value: shorten(result, 88), tone: 'green' }
        ];
      }

      if (kind === 'review') {
        return [
          { label: copy.nodes.check, value: shorten(headingText, 64), tone: 'blue' },
          { label: copy.nodes.fix, value: shorten(support, 92), tone: 'amber' },
          { label: copy.nodes.outcome, value: shorten(result, 88), tone: 'green' }
        ];
      }

      if (kind === 'application') {
        return [
          { label: copy.nodes.idea, value: shorten(headingText, 64), tone: 'blue' },
          { label: copy.nodes.usage, value: shorten(core, 92), tone: 'cyan' },
          { label: copy.nodes.result, value: shorten(result, 88), tone: 'green' }
        ];
      }

      if (kind === 'path') {
        return [
          { label: copy.nodes.path, value: shorten(headingText, 64), tone: 'blue' },
          { label: copy.nodes.control, value: shorten(core, 92), tone: 'cyan' },
          { label: copy.nodes.result, value: shorten(result, 88), tone: 'green' }
        ];
      }

      if (kind === 'symbol') {
        return [
          { label: copy.nodes.idea, value: shorten(headingText, 64), tone: 'blue' },
          { label: copy.nodes.meaning, value: shorten(core, 92), tone: 'cyan' },
          { label: copy.nodes.usage, value: shorten(result, 88), tone: 'green' }
        ];
      }

      return [
        { label: copy.nodes.idea, value: shorten(headingText, 64), tone: 'blue' },
        { label: copy.nodes.meaning, value: shorten(core, 92), tone: 'cyan' },
        { label: copy.nodes.usage, value: shorten(result, 88), tone: 'green' }
      ];
    };

    const renderRows = (rows) => rows.map(([label, value]) => `
      <tr>
        <th>${escapeHtml(label)}</th>
        <td>${escapeHtml(value)}</td>
      </tr>
    `).join('');

    const renderStages = (stages) => stages.map((stage, index) => `
      <div class="blog-explainer-stage blog-explainer-stage--${escapeHtml(stage.tone)}">
        <span>${escapeHtml(stage.label)}</span>
        <strong>${escapeHtml(stage.value)}</strong>
      </div>
      ${index < stages.length - 1 ? '<div class="blog-explainer-link" aria-hidden="true"></div>' : ''}
    `).join('');

    const buildExplainerCard = (heading, index) => {
      const headingText = tidyText(heading.textContent || `Section ${index + 1}`);
      const sectionText = collectSectionText(heading);
      const listItems = collectListItems(heading);
      const kind = pickKeyword(headingText, sectionText);
      const rows = buildRows(kind, headingText, sectionText, listItems);
      const stages = buildDiagramStages(kind, headingText, sectionText, listItems);
      const intro = firstSentence(sectionText) || rows[1][1];
      const headingLevel = heading.tagName === 'H2' ? 'major' : 'minor';

      const wrapper = document.createElement('section');
      wrapper.className = `blog-explainer blog-explainer--${headingLevel}`;
      wrapper.setAttribute('data-blog-explainer', '');

      wrapper.innerHTML = `
        <div class="blog-explainer-head">
          <p>${escapeHtml(copy.explainer)}</p>
          <h4>${escapeHtml(headingText)}</h4>
          <p class="blog-explainer-intro">${escapeHtml(intro)}</p>
        </div>

        <div class="blog-explainer-tabs" role="tablist" aria-label="${escapeHtml(headingText)} helper tabs">
          <button type="button" class="is-active" data-explainer-tab="diagram" aria-selected="true">${escapeHtml(copy.tabs.diagram)}</button>
          <button type="button" data-explainer-tab="table" aria-selected="false">${escapeHtml(copy.tabs.table)}</button>
        </div>

        <div class="blog-explainer-panel" data-explainer-panel="diagram">
          <div class="blog-explainer-panel-card">
            <div class="blog-explainer-panel-head">
              <span>${escapeHtml(copy.diagramTitle)}</span>
              <strong>${escapeHtml(headingText)}</strong>
            </div>
            <div class="blog-explainer-flow">
              ${renderStages(stages)}
            </div>
          </div>
        </div>

        <div class="blog-explainer-panel hidden" data-explainer-panel="table">
          <div class="blog-explainer-panel-card">
            <div class="blog-explainer-panel-head">
              <span>${escapeHtml(copy.tableTitle)}</span>
              <strong>${escapeHtml(headingText)}</strong>
            </div>
            <div class="blog-explainer-table-wrap">
              <table class="blog-explainer-table">
                <tbody>
                  ${renderRows(rows)}
                </tbody>
              </table>
            </div>
          </div>
        </div>
      `;

      heading.insertAdjacentElement('afterend', wrapper);
    };

    const activateTab = (root, key) => {
      root.querySelectorAll('[data-explainer-tab]').forEach((button) => {
        const active = button.getAttribute('data-explainer-tab') === key;
        button.classList.toggle('is-active', active);
        button.setAttribute('aria-selected', String(active));
      });

      root.querySelectorAll('[data-explainer-panel]').forEach((panel) => {
        panel.classList.toggle('hidden', panel.getAttribute('data-explainer-panel') !== key);
      });
    };

    normalizeHeadingHierarchy();

    const headings = Array.from(articleRoot.children).filter((node) => {
      return node instanceof HTMLElement && (node.tagName === 'H2' || node.tagName === 'H3');
    });

    headings.forEach((heading, index) => {
      if (heading.nextElementSibling?.hasAttribute('data-blog-explainer')) return;
      buildExplainerCard(heading, index);
    });

    articleRoot.querySelectorAll('[data-blog-explainer]').forEach((explainer) => {
      explainer.querySelectorAll('[data-explainer-tab]').forEach((button) => {
        button.addEventListener('click', () => {
          activateTab(explainer, button.getAttribute('data-explainer-tab') || 'diagram');
        });
      });
      activateTab(explainer, 'diagram');
    });
  })();
</script>

<style>
  .blog-shell {
    width: min(1200px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 3.5rem 0 5rem;
  }

  .blog-hero {
    border: 1px solid rgba(148, 163, 184, 0.14);
    border-radius: 2rem;
    padding: 2rem;
    background:
      radial-gradient(circle at top left, rgba(56, 189, 248, 0.14), transparent 32%),
      radial-gradient(circle at right, rgba(16, 185, 129, 0.1), transparent 28%),
      linear-gradient(180deg, rgba(8, 15, 28, 0.96), rgba(12, 20, 36, 0.98));
    box-shadow: 0 24px 80px rgba(2, 6, 23, 0.34);
  }

  .blog-breadcrumbs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(148, 163, 184, 0.82);
  }

  .blog-breadcrumbs a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .blog-breadcrumbs a:hover {
    color: white;
  }

  .blog-kicker-row {
    margin-top: 1.25rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(203, 213, 225, 0.88);
  }

  .blog-kicker {
    display: inline-flex;
    align-items: center;
    border: 1px solid rgba(56, 189, 248, 0.26);
    border-radius: 999px;
    padding: 0.45rem 0.8rem;
    background: rgba(14, 165, 233, 0.12);
    color: rgb(125 211 252);
  }

  .blog-meta-dot {
    width: 0.3rem;
    height: 0.3rem;
    border-radius: 999px;
    background: rgba(100, 116, 139, 0.9);
  }

  .blog-hero-grid {
    margin-top: 1.5rem;
    display: grid;
    gap: 1.5rem;
    grid-template-columns: minmax(0, 1.7fr) minmax(280px, 0.9fr);
    align-items: start;
  }

  .blog-title {
    margin: 0;
    font-size: clamp(2.4rem, 5vw, 4.6rem);
