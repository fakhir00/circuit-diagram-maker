---
interface Step {
  title: string;
  description: string;
  icon?: string;
}

interface Props {
  badge?: string;
  ctaHref?: string;
  ctaLabel?: string;
  title: string;
  steps: Step[];
}

const { badge, ctaHref, ctaLabel, title, steps } = Astro.props;
---

<section class="py-24 bg-bg-dark border-t border-white/5 relative overflow-hidden">
  <!-- Subtle background glow -->
  <div class="absolute -top-24 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-brand-primary/5 blur-[120px] rounded-full pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    <div class="text-center mb-16">
      {badge && (
        <p class="text-sm font-semibold uppercase tracking-[0.35em] text-brand-accent mb-4">{badge}</p>
      )}
      <h2 class="text-3xl md:text-4xl font-bold text-white tracking-tight">{title}</h2>
    </div>

    <div class="grid md:grid-cols-3 gap-12 relative">
      <!-- Animated background path for the flow -->
      <svg class="hidden md:block absolute top-[32px] left-[15%] w-[70%] h-[120px] pointer-events-none" viewBox="0 0 800 120" fill="none">
        <defs>
          <filter id="howItWorksWireGlow">
            <feGaussianBlur stdDeviation="3" result="blur" />
            <feMerge>
              <feMergeNode in="blur" />
              <feMergeNode in="SourceGraphic" />
            </feMerge>
          </filter>
        </defs>
        <path
          d="M0,40 Q200,10 400,40 T800,40"
          stroke="#38bdf8"
          stroke-width="3"
          stroke-linecap="round"
          filter="url(#howItWorksWireGlow)"
          class="flow-path-anim"
        />
        <circle r="4" fill="#22d3ee" class="flow-dot-anim">
          <animateMotion dur="3s" repeatCount="indefinite" path="M0,40 Q200,10 400,40 T800,40" />
        </circle>
      </svg>

      {steps.map((step, index) => (
        <div class="flex flex-col items-center text-center group z-10">
          <div class="relative mb-6">
            <div class="w-16 h-16 rounded-2xl bg-bg-panel border border-white/10 flex items-center justify-center text-brand-primary transition-all duration-500 group-hover:border-brand-primary group-hover:shadow-[0_0_30px_rgba(59,130,246,0.4)] group-hover:scale-110">
              <span class="text-2xl font-black">{index + 1}</span>
            </div>
          </div>
          <h3 class="text-xl font-bold text-white mb-3 group-hover:text-brand-primary transition-colors tracking-tight">{step.title}</h3>
          <p class="text-slate-400 leading-relaxed max-w-sm text-sm">
            {step.description}
          </p>
        </div>
      ))}
    </div>

    {ctaHref && ctaLabel && (
      <div class="text-center mt-14">
        <a
          href={ctaHref}
          class="group relative inline-flex items-center gap-2 px-10 py-4 rounded-xl bg-brand-primary text-white font-semibold transition-all duration-300 hover:bg-blue-500 shadow-[0_0_24px_rgba(59,130,246,0.25)] hover:shadow-[0_0_40px_rgba(59,130,246,0.4)] hover:scale-[1.03]"
          id="how-to-cta"
        >
          <span class="relative z-10">{ctaLabel}</span>
          <svg class="w-5 h-5 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    )}
  </div>
</section>

<style>
  .flow-path-anim {
    filter: drop-shadow(0 0 8px rgba(56,189,248,0.8)) drop-shadow(0 0 18px rgba(56,189,248,0.45));
  }
  .flow-dot-anim {
    filter: drop-shadow(0 0 8px rgba(255,255,255,0.9)) drop-shadow(0 0 18px rgba(34,211,238,0.85));
  }
</style>
