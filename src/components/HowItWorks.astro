---
interface Step {
  title: string;
  description: string;
  icon?: string;
}

interface Props {
  title: string;
  steps: Step[];
}

const { title, steps } = Astro.props;
---

<section class="py-24 bg-bg-dark border-t border-white/5 relative overflow-hidden">
  <!-- Subtle background glow -->
  <div class="absolute -top-24 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-brand-primary/5 blur-[120px] rounded-full pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-white tracking-tight">{title}</h2>
    </div>

    <div class="grid md:grid-cols-3 gap-12">
      {steps.map((step, index) => (
        <div class="flex flex-col items-center text-center group">
          <div class="relative mb-6">
            <div class="w-16 h-16 rounded-2xl bg-bg-panel border border-white/10 flex items-center justify-center text-brand-primary transition-all duration-300 group-hover:border-brand-primary group-hover:shadow-[0_0_20px_rgba(59,130,246,0.3)]">
              <span class="text-2xl font-bold">{index + 1}</span>
            </div>
            {index < steps.length - 1 && (
              <div class="hidden md:block absolute top-8 left-20 w-full h-[2px] bg-gradient-to-r from-brand-primary/20 to-transparent pointer-events-none"></div>
            )}
          </div>
          <h3 class="text-xl font-semibold text-white mb-3 group-hover:text-brand-primary transition-colors">{step.title}</h3>
          <p class="text-slate-400 leading-relaxed max-w-sm">
            {step.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
