---
import { useTranslations, getLocalizedPath } from '../../theme/i18n';

const { locale = 'en', editorMode = 'default' } = Astro.props as { locale: string, editorMode: 'default' | 'logic' | 'arduino' | 'pcb' };
const t = useTranslations(locale);

const modeTitles = {
    default: "Circuit Diagram Maker — Editor",
    logic: "Logic Gate Diagram Tool — Designer",
    arduino: "Arduino Circuit Maker — Lab",
    pcb: "PCB Schematic Tool — Layout"
};

const modeDescriptions = {
    default: "Create high-quality circuit diagrams with our professional, browser-based editor. Drag-and-drop components, wire routing, and export to SVG/PNG.",
    logic: "Design and simulate logic gate diagrams with NAND, NOR, and XOR gates. Export professional schematics for academic and professional use.",
    arduino: "Plan your Arduino wiring diagrams with Uno and Mega boards, sensors, and peripherals. The ultimate pre-wiring documentation tool.",
    pcb: "Draft professional PCB schematics with VIAs, surface-mount pads, and silk screen labels before you move to production."
};

const clientI18n = {
    placement: t("editor.app.placement"),
    tools_select: t("editor.tools.select"),
    tools_wire: t("editor.tools.wire"),
    tools_delete: t("editor.tools.delete"),
    tools_label: t("editor.tools.label"),
    status_ready: t("editor.status.ready"),
    status_components: t("editor.status.components"),
    status_wires: t("editor.status.wires")
};

const modeBrandNames = {
    default: 'Circuit Diagram Maker',
    logic: 'Logic Gate Diagram Tool',
    arduino: 'Arduino Circuit Maker',
    pcb: 'PCB Schematic Tool'
};

const modeProjectNames = {
    default: 'Untitled Circuit',
    logic: 'Untitled Logic Diagram',
    arduino: 'Untitled Arduino Circuit',
    pcb: 'Untitled PCB Schematic'
};

const editorConfig = {
    mode: editorMode,
    brandName: modeBrandNames[editorMode] || modeBrandNames.default,
    defaultProjectName: modeProjectNames[editorMode] || modeProjectNames.default,
    storageKey: `circuitforge_autosave_${editorMode}`
};
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{modeTitles[editorMode] || modeTitles.default}</title>
    <meta name="description" content={modeDescriptions[editorMode] || modeDescriptions.default}>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="apple-touch-icon" href="/logo.svg">
    <script set:html={`window.__I18N__ = ${JSON.stringify(clientI18n)}; window.__EDITOR_MODE__ = "${editorMode}"; window.__EDITOR_CONFIG__ = ${JSON.stringify(editorConfig)};`}></script>
</head>
<body>
    <!-- ===== TOP TOOLBAR ===== -->
    <header id="toolbar" class="toolbar">
        <div class="toolbar-left">
            <div class="toolbar-brand">
                <a href="/" style="display: flex; align-items: center; gap: 8px; text-decoration: none; color: inherit;">
                    <svg class="brand-icon" viewBox="0 0 24 24" width="24" height="24">
                        <path d="M4 12h3l2-5 3 10 2-5h3" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                        <circle cx="4" cy="12" r="1.5" fill="currentColor"/>
                        <circle cx="17" cy="12" r="1.5" fill="currentColor"/>
                    </svg>
                    <span class="brand-name">{editorConfig.brandName}</span>
                </a>
            </div>
            <div class="toolbar-divider"></div>
            <div class="toolbar-group">
                <button id="btn-new" class="toolbar-btn" title={t('editor.toolbar.new')}>
                    <svg viewBox="0 0 20 20" width="16" height="16"><path d="M4 2h8l4 4v12a1 1 0 01-1 1H4a1 1 0 01-1-1V3a1 1 0 011-1zm7 1v4h4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    <span>{t('editor.toolbar.new')}</span>
                </button>
                <button id="btn-open" class="toolbar-btn" title={t('editor.toolbar.open')}>
                    <svg viewBox="0 0 20 20" width="16" height="16"><path d="M2 6h3l2-2h6l2 2h3v10H2V6z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
                    <span>{t('editor.toolbar.open')}</span>
                </button>
                <button id="btn-save" class="toolbar-btn" title={t('editor.toolbar.save')}>
                    <svg viewBox="0 0 20 20" width="16" height="16"><path d="M3 3h11l3 3v11a1 1 0 01-1 1H4a1 1 0 01-1-1V3zm4 0v5h6V3m-3 8a2 2 0 100 4 2 2 0 000-4z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
                    <span>{t('editor.toolbar.save')}</span>
                </button>
            </div>
            <div class="toolbar-divider"></div>
            <div class="toolbar-group">
                <button id="btn-undo" class="toolbar-btn" title={t('editor.toolbar.undo')} disabled>
                    <svg viewBox="0 0 20 20" width="16" height="16"><path d="M4 8l4-4M4 8l4 4M4 8h8a4 4 0 010 8H8" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    <span>{t('editor.toolbar.undo')}</span>
                </button>
                <button id="btn-redo" class="toolbar-btn" title={t('editor.toolbar.redo')} disabled>
                    <svg viewBox="0 0 20 20" width="16" height="16"><path d="M16 8l-4-4m4 4l-4 4m4-4H8a4 4 0 000 8h4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    <span>{t('editor.toolbar.redo')}</span>
                </button>
            </div>
            <div class="toolbar-divider"></div>
            <div class="toolbar-group">
                <div class="toolbar-dropdown" id="export-dropdown">
                    <button id="btn-export" class="toolbar-btn" title={t('editor.toolbar.export')}>
                        <svg viewBox="0 0 20 20" width="16" height="16"><path d="M10 3v10m-4-4l4 4 4-4M3 14v2a1 1 0 001 1h12a1 1 0 001-1v-2" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        <span>{t('editor.toolbar.export')}</span>
                        <svg viewBox="0 0 10 6" width="8" height="6" class="dropdown-arrow"><path d="M1 1l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </button>
                    <div class="dropdown-menu" id="export-menu">
                        <button id="btn-export-svg" class="dropdown-item">
                            <svg viewBox="0 0 20 20" width="14" height="14"><rect x="3" y="3" width="14" height="14" rx="2" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M7 13l3-6 3 6" fill="none" stroke="currentColor" stroke-width="1.2"/></svg>
                            {t('editor.toolbar.export.svg')}
                        </button>
                        <button id="btn-export-png" class="dropdown-item">
                            <svg viewBox="0 0 20 20" width="14" height="14"><rect x="3" y="3" width="14" height="14" rx="2" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="8" cy="8" r="2" fill="none" stroke="currentColor" stroke-width="1.2"/><path d="M3 14l4-4 3 3 2-2 5 5" fill="none" stroke="currentColor" stroke-width="1.2"/></svg>
                            {t('editor.toolbar.export.png')}
                        </button>
                        <button id="btn-export-json" class="dropdown-item">
                            <svg viewBox="0 0 20 20" width="14" height="14"><path d="M6 3a3 3 0 00-3 3v2a2 2 0 010 4v2a3 3 0 003 3m8-14a3 3 0 013 3v2a2 2 0 000 4v2a3 3 0 01-3 3" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                            {t('editor.toolbar.export.json')}
                        </button>
                    </div>
                </div>
            </div>
        </div>
        <div class="toolbar-center">
            <input type="text" id="circuit-name" class="circuit-name-input" value={editorConfig.defaultProjectName} spellcheck="false">
        </div>
        <div class="toolbar-right">
            <div class="toolbar-group">
                <button id="btn-zoom-out" class="toolbar-btn toolbar-btn-icon" title={t('editor.toolbar.zoom.out')}>
                    <svg viewBox="0 0 20 20" width="16" height="16"><circle cx="9" cy="9" r="6" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M14 14l3 3M6 9h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                </button>
                <span id="zoom-level" class="zoom-display">{t('editor.toolbar.zoom.level')}</span>
                <button id="btn-zoom-in" class="toolbar-btn toolbar-btn-icon" title={t('editor.toolbar.zoom.in')}>
                    <svg viewBox="0 0 20 20" width="16" height="16"><circle cx="9" cy="9" r="6" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M14 14l3 3M6 9h6M9 6v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                </button>
                <button id="btn-zoom-fit" class="toolbar-btn toolbar-btn-icon" title={t('editor.toolbar.zoom.fit')}>
                    <svg viewBox="0 0 20 20" width="16" height="16"><path d="M3 7V4a1 1 0 011-1h3m6 0h3a1 1 0 011 1v3m0 6v3a1 1 0 01-1 1h-3m-6 0H4a1 1 0 01-1-1v-3" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>
            </div>
            <div class="toolbar-divider"></div>
            <button id="btn-help" class="toolbar-btn toolbar-btn-icon" title="Keyboard Shortcuts">
                <svg viewBox="0 0 20 20" width="16" height="16"><circle cx="10" cy="10" r="7" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M8 7a2 2 0 012-2 2 2 0 012 2c0 1.5-2 2-2 3m0 2v.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </button>
        </div>
    </header>

    <!-- ===== MAIN CONTENT ===== -->
    <div id="app-container" class="app-container">

        <!-- === LEFT SIDEBAR: Tools + Component Library === -->
        <aside id="sidebar" class="sidebar">
            <div class="sidebar-section">
                <div class="sidebar-section-header toggleable-header" data-target="tool-buttons">
                    <span>{t('editor.sidebar.tools')}</span>
                    <svg class="section-chevron" viewBox="0 0 10 6" width="10" height="6"><path d="M1 1l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                </div>
                <div id="tool-buttons" class="tool-buttons">
                    <button id="tool-select" class="tool-btn active" title={t('editor.tools.select')} data-tool="select">
                        <svg viewBox="0 0 24 24" width="18" height="18"><path d="M4 4l7 18 2-7 7-2L4 4z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
                    </button>
                    <button id="tool-wire" class="tool-btn" title={t('editor.tools.wire')} data-tool="wire">
                        <svg viewBox="0 0 24 24" width="18" height="18"><path d="M4 12h6v-6h4v12h6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><circle cx="4" cy="12" r="2" fill="currentColor"/><circle cx="20" cy="18" r="2" fill="currentColor"/></svg>
                    </button>
                    <button id="tool-delete" class="tool-btn" title={t('editor.tools.delete')} data-tool="delete">
                        <svg viewBox="0 0 24 24" width="18" height="18"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
                    </button>
                    <button id="tool-label" class="tool-btn" title={t('editor.tools.label')} data-tool="label">
                        <svg viewBox="0 0 24 24" width="18" height="18"><path d="M5 19h14M7 5l5 14M17 5l-5 14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </button>
                </div>
            </div>

            <!-- Component Library -->
            <div class="sidebar-section sidebar-section-grow">
                <div class="sidebar-section-header toggleable-header" data-target="component-library-wrap">
                    <span>{t('editor.sidebar.components')}</span>
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <div class="view-toggle">
                        <button id="view-grid" class="view-btn active" title="Grid View">
                            <svg viewBox="0 0 16 16" width="14" height="14"><rect x="1" y="1" width="6" height="6" rx="1" fill="currentColor"/><rect x="9" y="1" width="6" height="6" rx="1" fill="currentColor"/><rect x="1" y="9" width="6" height="6" rx="1" fill="currentColor"/><rect x="9" y="9" width="6" height="6" rx="1" fill="currentColor"/></svg>
                        </button>
                        <button id="view-list" class="view-btn" title="List View">
                            <svg viewBox="0 0 16 16" width="14" height="14"><rect x="1" y="2" width="14" height="3" rx="1" fill="currentColor"/><rect x="1" y="7" width="14" height="3" rx="1" fill="currentColor"/><rect x="1" y="12" width="14" height="3" rx="1" fill="currentColor"/></svg>
                        </button>
                    </div>
                    <svg class="section-chevron" viewBox="0 0 10 6" width="10" height="6"><path d="M1 1l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                    </div>
                </div>
                <div id="component-library-wrap" class="component-library-wrap">
                    <div class="search-container">
                        <svg class="search-icon" viewBox="0 0 20 20" width="14" height="14"><circle cx="8" cy="8" r="5" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M13 13l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                        <input type="text" id="component-search" class="search-input" placeholder={t('editor.sidebar.search')} spellcheck="false">
                    </div>
                    <div id="component-library" class="component-library">
                        <!-- Populated by JavaScript -->
                    </div>
                </div>
            </div>
        </aside>

        <!-- === CANVAS AREA === -->
        <main id="canvas-container" class="canvas-container">
            <canvas id="circuit-canvas"></canvas>
            <div id="coord-display" class="coord-display">
                <span id="coord-x">X: 0</span>
                <span id="coord-y">Y: 0</span>
            </div>
            <div id="status-bar" class="status-bar">
                <span id="status-text">{t('editor.status.ready')}</span>
                <span id="component-count">{t('editor.status.components')}: 0</span>
                <span id="wire-count">{t('editor.status.wires')}: 0</span>
            </div>
        </main>

        <!-- === RIGHT PANEL: Properties + Layers === -->
        <aside id="right-panel" class="right-panel">
            <div class="panel-section" id="properties-section">
                <div class="panel-section-header toggleable-header" data-target="properties-content">
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <svg viewBox="0 0 20 20" width="14" height="14"><path d="M11 3a1 1 0 10-2 0v1a7 7 0 106 6h1a1 1 0 100-2h-1A7 7 0 0011 4V3z" fill="none" stroke="currentColor" stroke-width="1.3"/><circle cx="10" cy="10" r="2" fill="none" stroke="currentColor" stroke-width="1.3"/></svg>
                        <span>{t('editor.panel.properties')}</span>
                    </div>
                    <svg class="section-chevron" viewBox="0 0 10 6" width="10" height="6"><path d="M1 1l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                </div>
                <div id="properties-content" class="properties-content">
                    <div class="empty-state">
                        <svg viewBox="0 0 48 48" width="40" height="40" opacity="0.3"><path d="M24 8l-2 8h-8l6 5-2 8 6-5 6 5-2-8 6-5h-8z" fill="none" stroke="currentColor" stroke-width="1.5"/></svg>
                        <p>{t('editor.panel.properties.empty')}</p>
                    </div>
                </div>
            </div>

            <div class="panel-section" id="info-section">
                <div class="panel-section-header toggleable-header" data-target="info-content-wrap">
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <svg viewBox="0 0 20 20" width="14" height="14"><circle cx="10" cy="10" r="7" fill="none" stroke="currentColor" stroke-width="1.3"/><path d="M10 9v4M10 7v.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                        <span>{t('editor.panel.info')}</span>
                    </div>
                    <svg class="section-chevron" viewBox="0 0 10 6" width="10" height="6"><path d="M1 1l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                </div>
                <div id="info-content-wrap" class="info-content">
                    <div class="info-shortcuts desktop-shortcuts">
                        <div class="shortcut-row"><kbd>V</kbd> {t('editor.shortcut.select')}</div>
                        <div class="shortcut-row"><kbd>W</kbd> {t('editor.shortcut.wire')}</div>
                        <div class="shortcut-row"><kbd>R</kbd> {t('editor.shortcut.rotate')}</div>
                        <div class="shortcut-row"><kbd>Del</kbd> {t('editor.shortcut.delete')}</div>
                        <div class="shortcut-row"><kbd>Ctrl+Z</kbd> {t('editor.shortcut.undo')}</div>
                        <div class="shortcut-row"><kbd>Ctrl+S</kbd> {t('editor.shortcut.save')}</div>
                        <div class="shortcut-row"><kbd>Space</kbd> {t('editor.shortcut.pan')}</div>
                        <div class="shortcut-row"><kbd>Scroll</kbd> {t('editor.shortcut.zoom')}</div>
                    </div>
                    <div class="info-shortcuts mobile-shortcuts hidden">
                        <div class="shortcut-row"><kbd>Tap</kbd> {t('editor.mobile.shortcut.select')}</div>
                        <div class="shortcut-row"><kbd>1-Drag</kbd> {t('editor.mobile.shortcut.move')}</div>
                        <div class="shortcut-row"><kbd>2-Drag</kbd> {t('editor.mobile.shortcut.pan')}</div>
                        <div class="shortcut-row"><kbd>Pinch</kbd> {t('editor.mobile.shortcut.zoom')}</div>
                        <div class="shortcut-row"><kbd>Hold</kbd> {t('editor.mobile.shortcut.menu')}</div>
                    </div>
                </div>
            </div>
        </aside>
    </div>

    <!-- ===== MODALS ===== -->
    <div id="modal-overlay" class="modal-overlay hidden">
        <div id="modal-content" class="modal-content">
            <div class="modal-header">
                <h2 id="modal-title">Keyboard Shortcuts</h2>
                <button id="modal-close" class="modal-close">&times;</button>
            </div>
            <div id="modal-body" class="modal-body">
                <!-- Populated dynamically -->
            </div>
        </div>
    </div>
    <div id="context-menu" class="context-menu hidden">
        <button class="context-item" data-action="cut"><span>{t('editor.context.cut')}</span><kbd>Ctrl+X</kbd></button>
        <button class="context-item" data-action="copy"><span>{t('editor.context.copy')}</span><kbd>Ctrl+C</kbd></button>
        <button class="context-item" data-action="paste"><span>{t('editor.context.paste')}</span><kbd>Ctrl+V</kbd></button>
        <div class="context-divider"></div>
        <button class="context-item" data-action="rotate-cw"><span>{t('editor.context.rotate.cw')}</span><kbd>R</kbd></button>
        <button class="context-item" data-action="rotate-ccw"><span>{t('editor.context.rotate.ccw')}</span><kbd>Shift+R</kbd></button>
        <button class="context-item" data-action="flip-h"><span>{t('editor.context.flip.h')}</span><kbd>H</kbd></button>
        <button class="context-item" data-action="flip-v"><span>{t('editor.context.flip.v')}</span><kbd>F</kbd></button>
        <div class="context-divider"></div>
        <button class="context-item" data-action="duplicate"><span>{t('editor.context.duplicate')}</span><kbd>Ctrl+D</kbd></button>
        <button class="context-item context-item-danger" data-action="delete"><span>{t('editor.shortcut.delete')}</span><kbd>Del</kbd></button>
    </div>
    <div id="toast-container" class="toast-container"></div>
    <input type="file" id="file-input" accept=".circuit,.json" style="display:none">
    
    <script type="module" src="/js/app.js"></script>
</body>
</html>
