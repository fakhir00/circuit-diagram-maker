---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { defaultLocale, getLocalizedPath, useTranslations } from '../../theme/i18n';

interface Props { locale: string; }
const { locale } = Astro.props;
const t = useTranslations(locale);
const fallbackT = useTranslations(defaultLocale);

function readLocalizedValue(key: string) {
  const localizedValue = t(key);

  if (localizedValue !== undefined && localizedValue !== null) {
    return localizedValue;
  }

  return fallbackT(key);
}

function readText(key: string) {
  const value = readLocalizedValue(key);
  if (typeof value === 'string' && value.trim().length > 0) {
    return value;
  }

  const fallbackValue = fallbackT(key);
  return typeof fallbackValue === 'string' ? fallbackValue : '';
}

function readStringArray(key: string) {
  const value = readLocalizedValue(key);
  if (Array.isArray(value) && value.every((item) => typeof item === 'string')) {
    return value;
  }

  const fallbackValue = fallbackT(key);
  return Array.isArray(fallbackValue) ? fallbackValue.filter((item) => typeof item === 'string') : [];
}

function readShortcutRows(key: string) {
  const value = readLocalizedValue(key);
  if (Array.isArray(value) && value.every((row) => Array.isArray(row))) {
    return value.map((row) => [
      typeof row[0] === 'string' ? row[0] : '',
      typeof row[1] === 'string' ? row[1] : '',
      typeof row[2] === 'string' ? row[2] : ''
    ]);
  }

  const fallbackValue = fallbackT(key);
  return Array.isArray(fallbackValue) ? fallbackValue : [];
}

function readCardArray(key: string) {
  const value = readLocalizedValue(key);
  if (Array.isArray(value) && value.every((item) => item && typeof item === 'object' && !Array.isArray(item))) {
    return value;
  }

  const fallbackValue = fallbackT(key);
  return Array.isArray(fallbackValue) ? fallbackValue : [];
}

const guideSections = readCardArray('docs.guide.sections');
const shortcutHeaders = readStringArray('docs.shortcuts.headers');
const shortcutRows = readShortcutRows('docs.shortcuts.rows');
const drcCards = readCardArray('docs.drc.cards');
const standards = readCardArray('docs.standards.cards');
const resourceCards = readCardArray('docs.resources.cards');
---

<BaseLayout title={readText('docs.meta.title')} description={readText('docs.meta.description')}>
  <section class="relative overflow-hidden border-b border-white/5 bg-bg-dark py-24">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(34,211,238,0.1),transparent_30%),radial-gradient(circle_at_bottom_left,rgba(59,130,246,0.1),transparent_30%)]"></div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.35em] text-brand-accent">{readText('docs.hero.badge')}</p>
        <h1 class="mt-4 text-4xl sm:text-5xl font-extrabold tracking-tight text-white">{readText('docs.hero.title')}</h1>
        <p class="mt-6 text-xl leading-relaxed text-slate-400">
          {readText('docs.hero.description')}
        </p>
      </div>
    </div>
  </section>

  <!-- Guide Sections -->
  <section class="bg-bg-panel py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {guideSections.map((step, index) => (
          <article class="rounded-2xl border border-white/10 bg-bg-surface/70 p-6 hover:border-brand-primary/20 transition-colors">
            <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-brand-primary/15 text-base font-bold text-brand-primary mb-4">
              {index + 1}
            </div>
            <h2 class="text-lg font-semibold text-white">{step.title}</h2>
            <p class="mt-3 text-sm leading-relaxed text-slate-400">{step.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Keyboard Shortcuts -->
  <section class="border-t border-white/5 bg-bg-dark py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-8">
        <h2 class="text-3xl font-bold text-white">{readText('docs.shortcuts.title')}</h2>
        <p class="mt-3 text-slate-400">{readText('docs.shortcuts.description')}</p>
      </div>
      <div class="overflow-hidden rounded-2xl border border-white/10 bg-bg-panel">
        <div class="overflow-x-auto">
          <table class="w-full text-left text-sm">
            <thead class="bg-white/5 text-slate-300">
              <tr>
                {shortcutHeaders.map((header: string) => (
                  <th class="px-6 py-4 font-semibold uppercase tracking-[0.22em]">{header}</th>
                ))}
              </tr>
            </thead>
            <tbody class="divide-y divide-white/10 text-slate-300">
              {shortcutRows.map((row) => (
                <tr class="hover:bg-white/5 transition-colors">
                  <td class="px-6 py-3"><kbd class="px-2 py-1 rounded bg-white/10 text-xs text-white font-mono">{row[0]}</kbd></td>
                  <td class="px-6 py-3 font-medium text-white">{row[1]}</td>
                  <td class="px-6 py-3 text-slate-400">{row[2]}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- Design Rule Check (DRC) Section -->
  <section class="py-20 bg-bg-dark border-t border-white/5 relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(34,211,238,0.05),transparent_60%)]"></div>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <div class="mb-10 text-center">
        <h2 class="text-3xl font-bold text-white">{readText('docs.drc.title')}</h2>
        <p class="mt-4 text-slate-400">{readText('docs.drc.description')}</p>
      </div>
      <div class="grid gap-4 sm:grid-cols-2">
        {drcCards.map((card: any) => (
          <div class="p-5 rounded-2xl border border-white/10 bg-bg-panel/40">
            <h3 class="font-bold text-brand-primary mb-3 text-sm uppercase tracking-wider">{card.title}</h3>
            <ul class="space-y-3 text-sm text-slate-300">
              {card.items.map((item: string) => (
                <li class="flex items-start gap-3"><span class="text-emerald-400">✓</span>{item}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Best Practices -->
  <section class="py-20 bg-bg-panel border-t border-white/5">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-white mb-8 text-center">{readText('docs.standards.title')}</h2>
      <div class="space-y-6 text-slate-400 leading-relaxed bg-bg-dark/50 p-8 rounded-3xl border border-white/5">
        <p>{readText('docs.standards.intro')}</p>
        <div class="grid gap-6">
          {standards.map((card: any, index: number) => (
            <div class="flex gap-4">
              <div class="mt-1 text-brand-accent">
                {index === 0 && <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>}
                {index === 1 && <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 11l5-5m0 0l5 5m-5-5v12"/></svg>}
                {index === 2 && <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M3 14h18m-9-4v8m-7 0h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>}
              </div>
              <div>
                <h4 class="text-white font-semibold">{card.title}</h4>
                <p class="text-sm">{card.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Related Links -->
  <section class="py-12 bg-bg-dark border-t border-white/5">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-xl font-bold text-white mb-6">{readText('docs.resources.title')}</h2>
      <div class="grid gap-4 sm:grid-cols-3">
        <a href={getLocalizedPath('/components/', locale)} class="rounded-xl border border-white/10 bg-bg-panel/60 p-4 hover:border-brand-primary/30 transition-colors group">
          <h3 class="font-semibold text-white group-hover:text-brand-primary transition-colors">{resourceCards[0].title}</h3>
          <p class="text-sm text-slate-500 mt-1">{resourceCards[0].body}</p>
        </a>
        <a href={getLocalizedPath('/editor/', locale)} class="rounded-xl border border-white/10 bg-bg-panel/60 p-4 hover:border-brand-primary/30 transition-colors group">
          <h3 class="font-semibold text-white group-hover:text-brand-primary transition-colors">{resourceCards[1].title}</h3>
          <p class="text-sm text-slate-500 mt-1">{resourceCards[1].body}</p>
        </a>
        <a href={getLocalizedPath('/blog/', locale)} class="rounded-xl border border-white/10 bg-bg-panel/60 p-4 hover:border-brand-primary/30 transition-colors group">
          <h3 class="font-semibold text-white group-hover:text-brand-primary transition-colors">{resourceCards[2].title}</h3>
          <p class="text-sm text-slate-500 mt-1">{resourceCards[2].body}</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
