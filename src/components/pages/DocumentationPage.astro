---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLocalizedPath } from '../../theme/i18n';

interface Props {
  locale: string;
}

const { locale } = Astro.props;

const steps = [
  {
    title: 'Open the editor',
    body: 'Start with a blank canvas or a reusable structure, then place the major blocks before drilling into detail.'
  },
  {
    title: 'Define net flow',
    body: 'Keep signals readable by aligning wires, naming critical nets, and separating control paths from high-current sections.'
  },
  {
    title: 'Review and export',
    body: 'Use consistent references, confirm symbol labels, and export SVG or PNG assets for documentation and handoff.'
  }
];

const shortcutRows = [
  ['Select', 'Click / drag', 'Move and group components'],
  ['Wire', 'Shift + drag', 'Create clean orthogonal connections'],
  ['Annotate', 'Double click label', 'Name parts and signals quickly'],
  ['Duplicate', 'Cmd/Ctrl + D', 'Repeat standard blocks'],
  ['Export', 'Toolbar action', 'Generate SVG or PNG output']
];
---

<BaseLayout title="Documentation" description="Read the editor workflow, conventions, and quick references for circuit diagram creation.">
  <section class="relative overflow-hidden border-b border-white/5 bg-bg-dark py-24">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(34,211,238,0.14),transparent_22%),radial-gradient(circle_at_bottom_left,rgba(59,130,246,0.12),transparent_24%)]"></div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.35em] text-brand-accent">Documentation</p>
        <h1 class="mt-4 text-5xl font-extrabold tracking-tight text-white">Read the workflow before your first schematic review</h1>
        <p class="mt-6 text-xl leading-relaxed text-slate-400">
          This guide covers how to structure diagrams, work faster in the editor, and keep exported assets readable for collaborators.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-bg-panel py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-6 lg:grid-cols-3">
        {steps.map((step, index) => (
          <article class="rounded-[1.75rem] border border-white/10 bg-bg-surface/70 p-6">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-brand-primary/20 text-lg font-semibold text-white">
              {index + 1}
            </div>
            <h2 class="mt-5 text-2xl font-semibold text-white">{step.title}</h2>
            <p class="mt-3 leading-7 text-slate-400">{step.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="border-t border-white/5 bg-bg-dark py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 lg:grid-cols-[380px_minmax(0,1fr)]">
        <aside class="rounded-[2rem] border border-white/10 bg-[linear-gradient(180deg,rgba(59,130,246,0.14),rgba(15,23,42,0.96))] p-6">
          <h2 class="text-2xl font-semibold text-white">Reading order for clean diagrams</h2>
          <p class="mt-3 text-slate-400">Treat the page like a technical story: source on the left, decision logic in the middle, outputs and connectors on the right.</p>
          <div class="mt-6 overflow-hidden rounded-[1.5rem] border border-white/10 bg-[#081120] p-4">
            <svg class="h-auto w-full" viewBox="0 0 340 340" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="34" y="48" width="84" height="56" rx="14" fill="#111827" stroke="#38bdf8" stroke-width="3" />
              <rect x="128" y="132" width="84" height="56" rx="14" fill="#111827" stroke="#a78bfa" stroke-width="3" />
              <rect x="222" y="216" width="84" height="56" rx="14" fill="#111827" stroke="#34d399" stroke-width="3" />
              <path d="M118 76H166V132" stroke="#93c5fd" stroke-width="4" stroke-linecap="round" />
              <path d="M212 160H260V216" stroke="#67e8f9" stroke-width="4" stroke-linecap="round" />
              <text x="76" y="81" text-anchor="middle" fill="#f8fafc" font-size="14" font-family="sans-serif">INPUT</text>
              <text x="170" y="165" text-anchor="middle" fill="#f8fafc" font-size="14" font-family="sans-serif">LOGIC</text>
              <text x="264" y="249" text-anchor="middle" fill="#f8fafc" font-size="14" font-family="sans-serif">OUTPUT</text>
            </svg>
          </div>
          <a href={getLocalizedPath('/components/', locale)} class="mt-6 inline-flex rounded-full border border-white/10 px-4 py-2 text-sm font-medium text-white transition hover:border-white/20 hover:bg-white/5">
            See components reference
          </a>
        </aside>

        <div class="overflow-hidden rounded-[2rem] border border-white/10 bg-bg-panel">
          <div class="border-b border-white/10 px-6 py-5">
            <h2 class="text-2xl font-semibold text-white">Shortcut and action table</h2>
            <p class="mt-2 text-slate-400">A quick-reference set of editor actions for faster drafting and cleanup.</p>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full text-left text-sm">
              <thead class="bg-white/5 text-slate-300">
                <tr>
                  <th class="px-6 py-4 font-semibold uppercase tracking-[0.22em]">Task</th>
                  <th class="px-6 py-4 font-semibold uppercase tracking-[0.22em]">Action</th>
                  <th class="px-6 py-4 font-semibold uppercase tracking-[0.22em]">Result</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-white/10 text-slate-300">
                {shortcutRows.map((row) => (
                  <tr>
                    <td class="px-6 py-4 font-medium text-white">{row[0]}</td>
                    <td class="px-6 py-4">{row[1]}</td>
                    <td class="px-6 py-4 text-slate-400">{row[2]}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
