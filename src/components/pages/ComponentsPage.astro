---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLocalizedPath, useTranslations } from '../../theme/i18n';

interface Props { locale: string; }
const { locale } = Astro.props;
const t = useTranslations(locale);
const categoryColors = [
  'border-cyan-500/30',
  'border-purple-500/30',
  'border-blue-500/30',
  'border-amber-500/30',
  'border-emerald-500/30',
  'border-rose-500/30'
];
const categories = t('components.categories').map((category: any, index: number) => ({
  ...category,
  color: categoryColors[index] || 'border-white/10'
}));
const tableHeaders = t('components.table.headers');
const tableRows = t('components.table.rows');
const howParagraphs = t('components.how.paragraphs');
---

<BaseLayout title={t('components.meta.title')} description={t('components.meta.description')}>
  <section class="relative overflow-hidden border-b border-white/5 bg-bg-dark py-24">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(34,211,238,0.1),transparent_30%),radial-gradient(circle_at_bottom_right,rgba(59,130,246,0.1),transparent_30%)]"></div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.35em] text-brand-accent">{t('components.hero.badge')}</p>
        <h1 class="mt-4 text-4xl sm:text-5xl font-extrabold tracking-tight text-white">{t('components.hero.title')}</h1>
        <p class="mt-6 text-xl leading-relaxed text-slate-400">
          {t('components.hero.description')}
        </p>
        <p class="mt-4 text-slate-400 leading-relaxed">
          {t('components.hero.body')}
        </p>
      </div>
    </div>
  </section>

  <!-- Category Cards -->
  <section class="bg-bg-panel py-20">
    <div class="mx-auto grid max-w-7xl gap-6 px-4 sm:px-6 md:grid-cols-2 lg:grid-cols-3 lg:px-8">
      {categories.map((cat: any) => (
        <article class={`rounded-2xl border ${cat.color} bg-bg-surface/70 p-6 hover:bg-bg-surface transition-colors`}>
          <h2 class="text-xl font-semibold text-white">{cat.title}</h2>
          <p class="mt-3 text-sm leading-6 text-slate-400">{cat.notes}</p>
          <ul class="mt-5 space-y-2 text-slate-300">
            {cat.items.map((item: string) => (
              <li class="rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-sm hover:border-brand-primary/20 hover:bg-brand-primary/5 transition-colors cursor-default">{item}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <!-- Reference Table -->
  <section class="border-t border-white/5 bg-bg-dark py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-8">
        <h2 class="text-3xl font-bold text-white">{t('components.table.title')}</h2>
        <p class="mt-3 text-slate-400">{t('components.table.description')}</p>
      </div>
      <div class="overflow-hidden rounded-2xl border border-white/10 bg-bg-panel">
        <div class="overflow-x-auto">
          <table class="w-full text-left text-sm">
            <thead class="bg-white/5 text-slate-300">
              <tr>
                {tableHeaders.map((header: string) => (
                  <th class="px-6 py-4 font-semibold uppercase tracking-[0.22em]">{header}</th>
                ))}
              </tr>
            </thead>
            <tbody class="divide-y divide-white/10 text-slate-300">
              {tableRows.map((row: any[]) => (
                <tr class="hover:bg-white/5 transition-colors">
                  <td class="px-6 py-4 font-medium text-white">{row[0]}</td>
                  <td class="px-6 py-4">{row[1]}</td>
                  <td class="px-6 py-4 text-slate-400">{row[2]}</td>
                  <td class="px-6 py-4 font-mono text-xs text-brand-accent">{row[3]}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- How to Place -->
  <section class="py-16 bg-bg-panel border-t border-white/5">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-white mb-6">{t('components.how.title')}</h2>
      <div class="space-y-4 text-slate-400 leading-relaxed">
        {howParagraphs.map((paragraph: string) => (
          <p>{paragraph}</p>
        ))}
      </div>
      <div class="mt-8 flex flex-wrap gap-4">
        <a href={getLocalizedPath('/editor/', locale)} class="rounded-xl bg-brand-primary px-6 py-3 text-sm font-semibold text-white transition hover:bg-blue-500">
          {t('components.actions.primary')}
        </a>
        <a href={getLocalizedPath('/docs/', locale)} class="rounded-xl border border-white/10 px-6 py-3 text-sm font-medium text-white transition hover:border-white/20 hover:bg-white/5">
          {t('components.actions.secondary')}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
