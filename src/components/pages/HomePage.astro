---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLocalizedPath, useTranslations } from '../../theme/i18n';
import HowItWorks from '../HowItWorks.astro';
import FeatureMatrix from '../FeatureMatrix.astro';
import FAQ from '../FAQ.astro';
import Hero3DPreview from '../Hero3DPreview.astro';
import InteractiveCircuitShowcase from '../InteractiveCircuitShowcase.astro';
import HomeContentSections from '../HomeContentSections.astro';

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const faqItems = t('faq');
const howItWorksSteps = [
  {
    title: 'Draft Your Circuit',
    description: 'Use the smart drag-and-drop library containing 40+ industry-standard symbols to start your design.'
  },
  {
    title: 'Auto-Route Wires',
    description: 'Our Manhattan routing engine keeps connections orthogonal, readable, and snapped to the grid.'
  },
  {
    title: 'Export & Share',
    description: 'Download crisp SVG or high-DPI PNG outputs for specs, handoff docs, and technical reports.'
  }
];

const matrixHeaders = ['Feature', 'Circuit Diagram Maker', 'Legacy Tools'];
const matrixRows = [
  ['Browser Based', 'Yes', 'No'],
  ['Smart Routing', 'Yes', 'Limited'],
  ['SVG Export', 'Yes', 'Yes'],
  ['High-DPI PNG', 'Yes', 'No'],
  ['Component Presets', 'Yes', 'Limited'],
  ['Shared Documentation Flow', 'Yes', 'No']
];
---

<BaseLayout>
  <section class="relative overflow-hidden bg-bg-dark pt-24 pb-24">
    <div class="absolute inset-x-0 top-0 h-96 bg-gradient-to-b from-brand-primary/10 to-transparent"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(6,182,212,0.12),transparent_24%),radial-gradient(circle_at_bottom_left,rgba(59,130,246,0.16),transparent_28%)]"></div>
    <div class="relative mx-auto grid max-w-7xl gap-14 px-4 sm:px-6 lg:grid-cols-[minmax(0,1fr)_460px] lg:px-8">
      <div class="max-w-3xl">
        <p class="mb-5 text-sm font-semibold uppercase tracking-[0.35em] text-brand-accent">Browser-based schematic workspace</p>
        <h1 class="text-5xl font-extrabold tracking-tight text-white md:text-6xl">
          {t('home.hero.title')}
        </h1>
        <p class="mt-6 text-xl leading-relaxed text-slate-400">
          {t('home.hero.subtitle')}
        </p>
        <div class="mt-10 flex flex-col gap-4 sm:flex-row">
          <a href={getLocalizedPath('/editor/', locale)} class="rounded-xl bg-brand-primary px-8 py-3 text-center font-semibold text-white transition hover:bg-blue-500 hover:shadow-[0_0_30px_rgba(59,130,246,0.32)]">
            {t('home.hero.cta')}
          </a>
          <a href={getLocalizedPath('/docs/', locale)} class="rounded-xl border border-white/10 bg-bg-surface px-8 py-3 text-center font-medium text-white transition hover:border-white/20 hover:bg-white/5">
            {t('home.hero.secondary')}
          </a>
        </div>
        <div class="mt-12 grid gap-4 sm:grid-cols-3">
          <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
            <div class="text-3xl font-bold text-white">40+</div>
            <div class="mt-2 text-sm uppercase tracking-[0.25em] text-slate-400">Core symbols</div>
          </div>
          <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
            <div class="text-3xl font-bold text-white">3</div>
            <div class="mt-2 text-sm uppercase tracking-[0.25em] text-slate-400">Workflow tracks</div>
          </div>
          <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
            <div class="text-3xl font-bold text-white">95</div>
            <div class="mt-2 text-sm uppercase tracking-[0.25em] text-slate-400">Static pages built</div>
          </div>
        </div>
      </div>

      <div class="relative">
        <div class="absolute -inset-6 rounded-[2rem] bg-gradient-to-br from-brand-primary/10 to-brand-secondary/5 blur-2xl"></div>
        <div class="relative overflow-hidden rounded-[2rem] border border-white/10 bg-bg-panel shadow-2xl" style="box-shadow: 0 25px 80px rgba(0,0,0,0.5), 0 0 60px rgba(59,130,246,0.08);">
          <Hero3DPreview />
        </div>
      </div>
    </div>
  </section>

  <InteractiveCircuitShowcase />
  <HowItWorks title={t('home.how_it_works.title')} steps={howItWorksSteps} />
  <HomeContentSections locale={locale} />
  <FeatureMatrix title={t('home.data.title')} headers={matrixHeaders} rows={matrixRows} />
  <FAQ title={t('home.faq.title')} items={faqItems} />
</BaseLayout>
