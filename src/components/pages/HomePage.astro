---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLocalizedPath, useTranslations } from '../../theme/i18n';
import HowItWorks from '../HowItWorks.astro';
import FeatureMatrix from '../FeatureMatrix.astro';
import FAQ from '../FAQ.astro';
import InteractiveCircuitShowcase from '../InteractiveCircuitShowcase.astro';
import RelatedToolsSection from '../RelatedToolsSection.astro';

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const faqItems = t('faq');

const howItWorksSteps = t('home.how_it_works.steps');
const matrixHeaders = t('home.data.headers');
const matrixRows = t('home.data.rows');

const featureCardIcons = [
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M9 12h6M12 9v6"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><path d="M4 12h4v-4h4v8h4v-4h4"/><circle cx="4" cy="12" r="1.5" fill="currentColor"/><circle cx="20" cy="12" r="1.5" fill="currentColor"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><path d="M12 3v10m-4-4l4 4 4-4M4 15v3a2 2 0 002 2h12a2 2 0 002-2v-3"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><path d="M4 6h16M4 12h10M4 18h14"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><path d="M20 7l-8 8-4-4-5 5"/><path d="M20 7h-6m6 0v6"/></svg>`
];

const featureCards = t('home.features.cards').map((card: any, i: number) => ({
  ...card,
  icon: featureCardIcons[i]
}));

const benefitItems = t('home.benefits.items');
const powerFeatures = t('home.power_features.items');
const howToSteps = t('home.how_to.steps');
const exampleItems = t('home.examples.items');
const moreToolItems = t('home.more_tools.items');

const personas = t('home.personas');
const homeMetaTitle = locale === 'en'
  ? 'Circuit Diagram Maker (Free Online Tool) – Draw Easy'
  : t('home.hero.title');

const homeMetaDescription = locale === 'en'
  ? 'Create circuit diagrams online for free with our easy-to-use circuit diagram maker. Draw, edit, and customize schematics instantly—no download needed.'
  : (t('home.hero.meta_desc') || t('home.hero.subtitle'));

const pageSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": homeMetaTitle,
      "author": { "@type": "Person", "name": "Circuit Diagram Maker Team" },
      "datePublished": "2026-01-01T00:00:00Z",
      "dateModified": new Date().toISOString()
    },
    {
      "@type": "BlogPosting",
      "headline": homeMetaTitle
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://circuitdiagram.org/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqItems && Array.isArray(faqItems) ? faqItems.filter((f: any) => f.display !== false).map((faq: any) => ({
        "@type": "Question",
        "name": faq.question,
        "acceptedAnswer": { "@type": "Answer", "text": faq.answer }
      })) : []
    }
  ]
};

const currentDateIso = new Date().toISOString();
const currentDateFormatted = new Date().toLocaleDateString('en-US', {month: 'short', day: 'numeric', year: 'numeric'});
---

<BaseLayout title={homeMetaTitle} description={homeMetaDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />
  <!-- ███ HERO SECTION ███ -->
  <section class="relative overflow-hidden bg-bg-dark" id="hero">
    <!-- Background gradients -->
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(59,130,246,0.12),transparent_50%),radial-gradient(ellipse_at_bottom_right,rgba(6,182,212,0.08),transparent_40%)]"></div>
    
    <div class="relative mx-auto max-w-7xl px-4 pt-16 pb-8 sm:px-6 lg:px-8">
      <!-- Hero text -->
      <div class="text-center max-w-4xl mx-auto mb-8 relative z-10">
        <p class="mb-5 text-sm font-semibold uppercase tracking-[0.35em] text-brand-accent">{t('home.hero.badge')}</p>
        <h1 class="text-4xl sm:text-5xl md:text-7xl font-black tracking-tight leading-[1.05]">
          <span class="bg-gradient-to-br from-white via-white to-slate-400 bg-clip-text text-transparent" id="hero-typed">{t('home.hero.title')}</span>
        </h1>
        <p class="mt-6 text-lg sm:text-xl text-slate-400 leading-relaxed max-w-3xl mx-auto" set:html={t('home.hero.subtitle')}></p>
        <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href={getLocalizedPath('/editor/', locale)} 
             class="group relative px-8 py-3.5 rounded-xl bg-brand-primary text-white font-semibold transition-all duration-300 hover:bg-blue-500 shadow-[0_0_24px_rgba(59,130,246,0.25)] hover:shadow-[0_0_40px_rgba(59,130,246,0.4)] hover:scale-[1.03] w-full sm:w-auto text-center"
             id="hero-cta">
            <span class="relative z-10">{t('home.hero.cta')}</span>
            <div class="absolute inset-0 rounded-xl bg-gradient-to-r from-blue-600 to-cyan-500 opacity-0 group-hover:opacity-100 transition-opacity"></div>
          </a>
          <a href={getLocalizedPath('/docs/', locale)} class="px-8 py-3.5 rounded-xl border border-white/10 bg-bg-surface/50 backdrop-blur-sm text-white font-medium transition-all hover:border-white/20 hover:bg-white/5 w-full sm:w-auto text-center">
            {t('home.hero.secondary')}
          </a>
        </div>
      </div>

      <!-- Animated stat counters -->
      <div class="grid grid-cols-3 gap-4 max-w-lg mx-auto mb-8">
        <div class="text-center group">
          <div class="text-2xl sm:text-3xl font-black text-white counter" data-target="40">0</div>
          <div class="text-[10px] sm:text-xs uppercase tracking-[0.3em] text-slate-500 mt-1 group-hover:text-brand-accent transition-colors">{t('home.stats.symbols')}</div>
        </div>
        <div class="text-center group">
          <div class="text-2xl sm:text-3xl font-black text-white counter" data-target="3">0</div>
          <div class="text-[10px] sm:text-xs uppercase tracking-[0.3em] text-slate-500 mt-1 group-hover:text-brand-accent transition-colors">{t('home.stats.formats')}</div>
        </div>
        <div class="text-center group">
          <div class="text-2xl sm:text-3xl font-black text-white">100%</div>
          <div class="text-[10px] sm:text-xs uppercase tracking-[0.3em] text-slate-500 mt-1 group-hover:text-brand-accent transition-colors">{t('home.stats.free')}</div>
        </div>
      </div>
    </div>

  </section>

  <!-- ███ WHAT IS A CIRCUIT DIAGRAM MAKER? ███ -->
  <section class="py-20 bg-bg-panel border-t border-white/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-2 items-center">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.35em] text-brand-accent mb-4">{t('home.what_is.badge')}</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-white tracking-tight">{t('home.what_is.title')}</h2>
          <p class="mt-6 text-lg text-slate-400 leading-relaxed">
            {t('home.what_is.p1')}
          </p>
          <p class="mt-4 text-slate-400 leading-relaxed">
            {t('home.what_is.p2')}
          </p>
          <p class="mt-4 text-slate-400 leading-relaxed">
            {t('home.what_is.p3')}
          </p>
        </div>
        <!-- Animated SVG circuit being drawn -->
        <div class="rounded-2xl border border-white/10 bg-bg-dark/80 p-6 overflow-hidden relative group">
          <div class="absolute inset-0 bg-brand-primary/5 opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"></div>
          <svg class="w-full h-auto relative z-10" viewBox="0 0 500 300" fill="none" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <filter id="wireGlowHome">
                <feGaussianBlur stdDeviation="2" result="blur"/>
                <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
              </filter>
              <filter id="nodeGlowHome">
                <feGaussianBlur stdDeviation="4" result="blur"/>
                <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
              </filter>
            </defs>
            <rect x="5" y="5" width="490" height="290" rx="12" fill="none" stroke="rgba(59,130,246,0.1)" stroke-width="1.5" stroke-dasharray="4 4"/>
            
            <!-- Path 1: Source to Resistor -->
            <path id="h-wire-1" class="anim-draw-high" d="M60,200 L60,100 L120,100" stroke="#3b82f6" stroke-width="3.5" stroke-linecap="round" filter="url(#wireGlowHome)"/>
            <circle r="4" fill="#60a5fa" filter="url(#nodeGlowHome)">
              <animateMotion dur="2.5s" repeatCount="indefinite" path="M60,200 L60,100 L120,100" />
            </circle>

            <!-- Component: Resistor -->
            <g class="anim-fade-1">
              <rect x="120" y="85" width="60" height="30" rx="3" fill="#111827" stroke="#60a5fa" stroke-width="2.5"/>
              <text x="150" y="105" text-anchor="middle" fill="#94a3b8" font-size="10" font-family="monospace">10K</text>
            </g>

            <!-- Path 2: Resistor to Transistor -->
            <path id="h-wire-2" class="anim-draw-mid" d="M180,100 L240,100 L240,150" stroke="#22d3ee" stroke-width="3.5" stroke-linecap="round" filter="url(#wireGlowHome)"/>
            
            <!-- Component: Transistor (Simplified NPN) -->
            <g class="anim-fade-2">
              <circle cx="270" cy="150" r="28" fill="#111827" stroke="#38bdf8" stroke-width="2.5"/>
              <path d="M255,135 L270,150 L255,165" stroke="#38bdf8" stroke-width="2.5"/>
              <path d="M270,123 V177" stroke="#38bdf8" stroke-width="2" opacity="0.4"/>
              <text x="305" y="155" fill="#94a3b8" font-size="10" font-family="monospace">Q1</text>
            </g>

            <!-- Path 3: Transistor to Capacitor -->
            <path id="h-wire-3" class="anim-draw-low" d="M270,178 L270,230 L380,230" stroke="#34d399" stroke-width="3.5" stroke-linecap="round" filter="url(#wireGlowHome)"/>
            
            <!-- Component: Capacitor -->
            <g class="anim-fade-3">
              <path d="M380,210 V250 M392,210 V250" stroke="#10b981" stroke-width="3.5" stroke-linecap="round"/>
              <path d="M360,230 L380,230 M392,230 L430,230" stroke="#10b981" stroke-width="2.5"/>
            </g>

            <!-- Final Node -->
            <circle class="anim-fade-3" cx="430" cy="230" r="6" fill="#10b981" filter="url(#nodeGlowHome)"/>

            <!-- Terminals -->
            <circle class="anim-fade-0" cx="60" cy="200" r="7" fill="#3b82f6" filter="url(#nodeGlowHome)"/>
            <text class="anim-fade-0" x="60" y="225" text-anchor="middle" fill="#3b82f6" font-size="11" font-weight="bold">SOURCE</text>
            <text class="anim-fade-3" x="430" y="210" text-anchor="middle" fill="#10b981" font-size="11" font-weight="bold">OUTPUT</text>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- ███ BENEFITS SECTION ███ -->
  <section class="py-16 bg-bg-panel border-t border-white/5 relative overflow-hidden" id="benefits">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_left,rgba(34,211,238,0.06),transparent_50%)]"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-sm font-semibold uppercase tracking-[0.35em] text-brand-accent mb-4">{t('home.benefits.badge')}</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-white tracking-tight">{t('home.benefits.title')}</h2>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {benefitItems.map((item: any, i: number) => (
          <div class="group relative rounded-2xl border border-white/10 bg-bg-dark/60 p-6 transition-all duration-300 hover:border-emerald-500/30 hover:bg-bg-surface/40 hover:shadow-[0_0_30px_rgba(16,185,129,0.08)]" style={`animation-delay: ${i * 100}ms`}>
            <div class="w-11 h-11 rounded-xl bg-emerald-500/10 flex items-center justify-center mb-4 group-hover:bg-emerald-500/20 transition-colors">
              <svg class="w-5 h-5 text-emerald-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-white mb-2 group-hover:text-emerald-400 transition-colors">{item.label}</h3>
            <p class="text-sm text-slate-400 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ███ WHY USE OUR CIRCUIT DIAGRAM MAKER ███ -->
  <section class="py-20 bg-bg-dark border-t border-white/5 relative group/section">
    <a href={getLocalizedPath('/editor/', locale)} class="absolute inset-0 z-10 block cursor-default" aria-label={t('nav.editor')}></a>
    <div class="relative z-0 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pointer-events-none group-hover/section:bg-brand-primary/[0.02] transition-colors duration-500 rounded-[3rem]">
      <div class="text-center max-w-3xl mx-auto mb-14 pt-8">
        <p class="text-sm font-semibold uppercase tracking-[0.35em] text-brand-accent mb-4">{t('home.features.badge')}</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-white tracking-tight group-hover/section:text-brand-primary transition-colors">{t('home.features.title')}</h2>
        <p class="mt-4 text-lg text-slate-400">{t('home.features.subtitle')} <span class="text-brand-primary underline underline-offset-4 decoration-1 pointer-events-auto cursor-pointer">{t('home.features.cta')} &rarr;</span></p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 pb-8">
        {featureCards.map((card: any, i: number) => (
          <div class="group/card rounded-2xl border border-white/10 bg-bg-panel/60 p-6 transition-all duration-300 group-hover/section:border-brand-primary/20 pointer-events-auto cursor-pointer hover:border-brand-primary/40 hover:bg-bg-surface/50 hover:shadow-[0_0_30px_rgba(59,130,246,0.08)]" style={`animation-delay: ${i * 80}ms`}>
            <div class="w-12 h-12 rounded-xl bg-brand-primary/10 flex items-center justify-center text-brand-primary mb-4 group-hover/card:bg-brand-primary/20 transition-colors">
              <Fragment set:html={card.icon} />
            </div>
            <h3 class="text-lg font-semibold text-white mb-2">{card.title}</h3>
            <p class="text-sm text-slate-400 leading-relaxed">{card.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ███ POWERFUL FEATURES SECTION ███ -->
  <section class="py-20 bg-bg-dark border-t border-white/5 relative overflow-hidden" id="power-features">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(59,130,246,0.08),transparent_50%)]"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-14">
        <p class="text-sm font-semibold uppercase tracking-[0.35em] text-brand-accent mb-4">{t('home.power_features.badge')}</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-white tracking-tight">{t('home.power_features.title')}</h2>
        <p class="mt-4 text-lg text-slate-400">{t('home.power_features.subtitle')}</p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2">
        {powerFeatures.map((feat: any, i: number) => (
          <div class="group rounded-2xl border border-white/10 bg-bg-panel/70 p-7 transition-all duration-300 hover:border-brand-primary/30 hover:bg-bg-surface/50 hover:shadow-[0_0_40px_rgba(59,130,246,0.06)]">
            <div class="flex items-start gap-5">
              <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-brand-primary/10 flex items-center justify-center text-brand-primary group-hover:bg-brand-primary/20 transition-colors">
                <span class="text-xl font-black">{String(i + 1).padStart(2, '0')}</span>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-white mb-2 group-hover:text-brand-primary transition-colors">{feat.title}</h3>
                <p class="text-sm text-slate-400 leading-relaxed">{feat.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ███ INTERACTIVE SCHEMATIC SHOWCASE ███ -->
  <InteractiveCircuitShowcase locale={locale} />

  <!-- ███ HOW TO MAKE A CIRCUIT DIAGRAM ███ -->
  <section class="py-24 bg-bg-panel border-t border-white/5 relative overflow-hidden" id="how-to">
    <div class="absolute -top-24 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-cyan-500/5 blur-[120px] rounded-full pointer-events-none"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold uppercase tracking-[0.35em] text-brand-accent mb-4">{t('home.how_to.badge')}</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white tracking-tight">{t('home.how_to.title')}</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-10 relative">
        <!-- Connection line -->
        <svg class="hidden md:block absolute top-[40px] left-[15%] w-[70%] h-[6px] pointer-events-none" viewBox="0 0 800 6" fill="none">
          <line x1="0" y1="3" x2="800" y2="3" stroke="url(#howToGrad)" stroke-width="2" stroke-dasharray="8 4" opacity="0.4"/>
          <defs><linearGradient id="howToGrad" x1="0" y1="0" x2="800" y2="0"><stop offset="0%" stop-color="#3b82f6"/><stop offset="100%" stop-color="#22d3ee"/></linearGradient></defs>
        </svg>
        {howToSteps.map((step: any, index: number) => (
          <div class="flex flex-col items-center text-center group z-10">
            <div class="relative mb-6">
              <div class="w-20 h-20 rounded-2xl bg-bg-dark border-2 border-white/10 flex items-center justify-center transition-all duration-500 group-hover:border-brand-primary group-hover:shadow-[0_0_40px_rgba(59,130,246,0.35)] group-hover:scale-110">
                <span class="text-3xl font-black bg-gradient-to-br from-blue-400 to-cyan-400 bg-clip-text text-transparent">{step.number}</span>
              </div>
            </div>
            <h3 class="text-xl font-bold text-white mb-3 group-hover:text-brand-primary transition-colors tracking-tight">{step.title}</h3>
            <p class="text-slate-400 leading-relaxed max-w-xs text-sm">{step.desc}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-14">
        <a href={getLocalizedPath('/editor/', locale)}
           class="group relative inline-flex items-center gap-2 px-10 py-4 rounded-xl bg-brand-primary text-white font-semibold transition-all duration-300 hover:bg-blue-500 shadow-[0_0_24px_rgba(59,130,246,0.25)] hover:shadow-[0_0_40px_rgba(59,130,246,0.4)] hover:scale-[1.03]"
           id="how-to-cta">
          <span class="relative z-10">{t('home.how_to.cta')}</span>
          <svg class="w-5 h-5 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ███ HOW IT WORKS ███ -->
  <HowItWorks title={t('home.how_it_works.title')} steps={howItWorksSteps} />

  <!-- ███ EXAMPLES SECTION ███ -->
  <section class="py-20 bg-bg-dark border-t border-white/5 relative" id="examples">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-14">
        <p class="text-sm font-semibold uppercase tracking-[0.35em] text-brand-accent mb-4">{t('home.examples.badge')}</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-white tracking-tight">{t('home.examples.title')}</h2>
        <p class="mt-4 text-lg text-slate-400">{t('home.examples.subtitle')}</p>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {exampleItems.map((ex: any, i: number) => (
          <a href={getLocalizedPath('/editor/', locale)}
             class="group rounded-2xl border border-white/10 bg-bg-panel/60 p-6 transition-all duration-300 hover:border-cyan-500/30 hover:bg-bg-surface/50 hover:shadow-[0_0_30px_rgba(6,182,212,0.08)] block">
            <div class="w-12 h-12 rounded-xl bg-cyan-500/10 flex items-center justify-center mb-4 group-hover:bg-cyan-500/20 transition-colors">
              <svg class="w-6 h-6 text-cyan-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="3" y="3" width="18" height="18" rx="3"/>
                <path d="M8 12h8M12 8v8" opacity="0.5"/>
              </svg>
            </div>
            <h3 class="text-base font-semibold text-white mb-2 group-hover:text-cyan-400 transition-colors">{ex.title}</h3>
            <p class="text-sm text-slate-400 leading-relaxed">{ex.desc}</p>
          </a>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href={getLocalizedPath('/editor/', locale)} class="text-brand-accent hover:text-white font-semibold transition-colors text-sm">
          {t('home.examples.cta')}
        </a>
      </div>
    </div>
  </section>

  <!-- ███ COMPARISON TABLE ███ -->
  <FeatureMatrix title={t('home.data.title')} headers={matrixHeaders} rows={matrixRows} />

  <!-- ███ WHO USES CIRCUIT DIAGRAM MAKER ███ -->
  <section class="py-20 bg-bg-dark border-t border-white/5 relative group/who">
    <a href={getLocalizedPath('/editor/', locale)} class="absolute inset-0 z-10 block cursor-default" aria-label={t('nav.editor')}></a>
