        tableCaption: 'Step 2 mapping checks',
        tableHeaders: ['Mapping Item', 'Review Action', 'Result'],
        tableRows: [
          ['LED', 'Check anode/cathode assignment', 'Correct polarity mapping'],
          ['Transistor', 'Confirm base/collector/emitter order', 'Valid switching behavior'],
          ['IC', 'Validate pin-1 orientation', 'Correct row placement plan']
