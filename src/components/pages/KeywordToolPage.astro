      tableCaption: 'Master conversion stages',
      tableHeaders: ['Stage', 'What Happens', 'Expected Output'],
      tableRows: [
        ['Input', 'Schematic is parsed and validated', 'Clean net/source model'],
        ['Mapping', 'Components and pins are resolved', 'Component mapping report'],
        ['Layout', 'Rows/rails/wires are assigned', 'Breadboard layout instructions'],
        ['Share', 'Layout is exported', 'PNG/SVG/JSON deliverable']
      ]
    },
    subs: [
      {
        id: 'step-1-upload-or-draw-your-schematic',
        title: 'Step 1: Upload or Draw Your Schematic',
        illustrationSummary:
          'This step illustration provides a mini input sandbox where users can test netlist lines and symbol placement. Validation feedback appears immediately, showing accepted and rejected input. It reduces parser errors before conversion starts.',
        purpose:
          'Content purpose: explain accepted source formats and help users create a structurally valid starting schematic.',
        diagramTitle: 'Input Validation Sandbox',
        diagramSteps: [
          {
            label: 'Upload',
            detail: 'Load an existing schematic file or paste a connection list.'
          },
          {
            label: 'Draw',
            detail: 'Create symbols and wire them directly in the editor canvas.'
          },
          {
            label: 'Validate',
            detail: 'Fix format issues before moving to component mapping.'
          }
        ],
        tableCaption: 'Step 1 checklist',
        tableHeaders: ['Input Type', 'Requirement', 'Pass Condition'],
        tableRows: [
          ['Netlist', 'NODE_A -> NODE_B format', 'All lines parse successfully'],
          ['Symbol drawing', 'Pins connected to valid nets', 'No orphan symbol pins'],
          ['Naming', 'Consistent labels', 'No duplicate ambiguous node names']
        ]
      },
      {
        id: 'step-2-review-component-mapping',
