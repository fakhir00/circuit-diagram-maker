        illustrationSummary:
          'This illustration shows two resistors in series with interactive node labels for each junction. Users can change values and inspect how intermediate nodes remain connected in physical layout. It clarifies row planning for chained components.',
        purpose:
          'Content purpose: demonstrate series path continuity and intermediate node preservation during conversion.',
        diagramTitle: 'Series Resistor Path Explorer',
        diagramSteps: [
          {
            label: 'Chain',
            detail: 'Define the resistor chain order in the schematic source.'
          },
          {
            label: 'Node',
            detail: 'Preserve the midpoint node when mapping to breadboard rows.'
          },
          {
            label: 'Verify',
            detail: 'Confirm continuity from source through both resistors to sink.'
          }
        ],
        tableCaption: 'Series resistor conversion checks',
        tableHeaders: ['Element', 'Conversion Action', 'Verification'],
        tableRows: [
          ['R1/R2 order', 'Keep component order intact', 'Expected node sequence'],
          ['Midpoint node', 'Assign dedicated row', 'No unintended branching'],
          ['Terminal rails', 'Connect to proper rails', 'Stable end-to-end path']
        ]
      },
      {
        id: 'example-3-transistor-as-a-switch',
        title: 'Example 3: Transistor as a Switch',
        illustrationSummary:
          'This transistor switch demo toggles control input and shows collector-emitter state changes in real time. Pin overlays help users avoid base/collector/emitter confusion during placement. It highlights how active components demand stricter mapping discipline.',
        purpose:
          'Content purpose: teach correct transistor orientation and control-path conversion for switching circuits.',
        diagramTitle: 'Transistor Switch Mapping Demo',
        diagramSteps: [
          {
            label: 'Pin map',
            detail: 'Identify B/C/E pins and align them with the chosen transistor package.'
          },
          {
            label: 'Control',
            detail: 'Route base control through the correct resistor path.'
          },
          {
            label: 'Load path',
            detail: 'Confirm collector-emitter load connection behaves as intended.'
          }
        ],
        tableCaption: 'Transistor switch validation',
        tableHeaders: ['Risk Area', 'Correct Mapping', 'Failure If Wrong'],
        tableRows: [
          ['Pin order', 'B-C-E aligned with part package', 'Switch logic fails'],
          ['Base resistor', 'Resistor on control line', 'Overdrive or unstable switching'],
          ['Load routing', 'Collector/emitter path verified', 'No output activation']
