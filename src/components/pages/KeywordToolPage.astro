  },
  {
    question: 'Can I share the conversion output with teammates?',
    answer: 'Yes. Export visual formats for reviews and JSON for editable project transfer.',
    display: true
  }
];

const booleanFaqItems: ToolFaqItem[] = [
  {
    question: 'What notation does the Boolean Expression Simplifier accept?',
    answer: "The tool accepts multiple notations simultaneously. You can use '+' for OR, '·' or '*' or just adjacency for AND, and apostrophe (A') or '!' for NOT. Parentheses for grouping are fully supported.",
    display: true
  },
  {
    question: 'What simplification algorithm is used?',
    answer: 'The tool uses the Quine-McCluskey algorithm, which is the provably optimal method for finding prime implicants and selecting essential ones. It guarantees the minimum SOP form.',
    display: true
  },
  {
    question: 'How many variables are supported?',
    answer: 'Up to 5 variables (A through E) are supported, producing up to 32-row truth tables. For most practical digital logic problems this is sufficient.',
    display: true
  },
  {
    question: 'What is the output format of the simplified expression?',
    answer: "The result is shown in standard Sum-of-Products (SOP) form using the apostrophe notation (e.g. A'B + AB'). The truth table and a gate network diagram are also generated automatically.",
    display: true
  },
  {
    question: 'Can I use this for Karnaugh map problems?',
    answer: 'Yes. The Quine-McCluskey algorithm is equivalent to solving a K-map but works for more than 4 variables where K-maps are impractical.',
    display: true
  },
  {
    question: 'Does the tool handle expressions that are always true or always false?',
    answer: 'Yes. Tautologies (always 1) and contradictions (always 0) are detected automatically and displayed as constant outputs.',
    display: true
  }
];

const localizedTruthContent = translateObject('keyword.truth.content', truthContent);
const normalizedTruthContent = {
  ...localizedTruthContent,
  sections: (localizedTruthContent.sections || truthContent.sections).map((section: any, index: number) => ({
    ...section,
    id: truthContent.sections[index]?.id || section.id
  }))
};
const localizedBooleanFaqItems = translateObject<ToolFaqItem[]>('keyword.boolean.faq', booleanFaqItems);
const booleanContent = translateObject('keyword.boolean.content', {
  howItWorks: {
    title: 'How Boolean Expression Simplification Works',
    intro:
      'Boolean algebra simplification reduces complex logical expressions into their minimal equivalent form using a set of algebraic laws. Every digital circuit, from basic gates to complex processors, operates on boolean logic — and simplification directly reduces gate count, power consumption and propagation delay in real hardware.',
    cards: [
      {
        title: 'Sum of Products (SOP)',
        description:
          'The standard form where AND terms are ORed together. Every boolean function can be expressed in SOP and it maps directly to a two-level AND-OR gate network.'
      },
      {
        title: 'Prime Implicants',
        description:
          'A prime implicant is a product term that cannot be combined with another term to produce a simpler term. The Quine-McCluskey method finds all prime implicants systematically.'
      },
      {
        title: 'Essential Prime Implicants',
        description:
          'An essential prime implicant covers at least one minterm that no other prime implicant covers. The minimum cover must include all essential prime implicants.'
      }
    ]
  },
  identities: {
    title: "De Morgan's Laws and Boolean Identities",
    intro:
      'These fundamental identities allow you to transform and simplify boolean expressions. The simplifier applies these automatically.',
    headers: {
      name: 'Identity Name',
      expression: 'Expression',
      description: 'Description'
    },
    rows: {
      deMorgan1: { name: 'De Morgan 1', description: 'NAND equals OR of complements' },
      deMorgan2: { name: 'De Morgan 2', description: 'NOR equals AND of complements' },
      absorption: { name: 'Absorption', description: 'Removes redundant product terms' },
      consensus: { name: 'Consensus', description: 'Eliminates redundant consensus terms' },
      complement: { name: 'Complement', description: 'A variable OR its complement is always 1' },
      idempotent: { name: 'Idempotent', description: 'Repeated terms collapse to a single term' }
    }
  },
  quine: {
    title: 'Quine-McCluskey Algorithm Step by Step',
    intro:
      'The Quine-McCluskey method is a tabular technique that systematically finds the minimum SOP form of a boolean function. Unlike K-maps it works for any number of variables and is computer-friendly.',
    steps: [
      {
        title: 'List all minterms.',
        description:
          'Convert each row where the output is 1 to its binary representation and group by number of 1-bits.'
      },
      {
        title: 'Merge adjacent groups.',
        description:
          "Combine pairs that differ in exactly one bit position, replacing that bit with a dash (don't-care). Repeat until no more merges are possible."
      },
      {
        title: 'Identify prime implicants.',
        description:
          'Any term that could not be merged further is a prime implicant. Collect all of them into a prime implicant chart.'
      },
      {
        title: 'Select essential prime implicants.',
        description:
          'Find every minterm covered by exactly one prime implicant — that implicant is essential. Include all essentials in the final expression.'
      },
      {
        title: 'Cover remaining minterms.',
        description:
          'For any minterms not yet covered by essentials, choose additional prime implicants greedily to minimize the total term count.'
      }
    ]
  }
});

const resolvedHeading = toolMeta[toolKey].title;
const activeFaqItems = toolKey === 'boolean-expression-simplifier' ? localizedBooleanFaqItems : normalizedTruthContent.faqItems;
const pageDescription = toolMeta[toolKey].description;
---

<BaseLayout title={resolvedHeading} description={pageDescription}>
  <article aria-labelledby="tool-page-title">
    <InlineKeywordTool toolKey={toolKey} heading={resolvedHeading} locale={locale} />

    {toolKey === 'boolean-expression-simplifier' ? (
      <>
        <section class="border-t border-white/5 bg-bg-dark py-14 sm:py-16">
          <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
            <article class="rounded-2xl border border-white/10 bg-bg-surface/50 p-5 sm:p-6">
              <header>
                <h2 class="text-2xl font-bold tracking-tight text-white sm:text-3xl">{booleanContent.howItWorks.title}</h2>
                <p class="mt-4 text-slate-300 leading-7">{booleanContent.howItWorks.intro}</p>
              </header>
              <div class="mt-6 grid gap-6 lg:grid-cols-3">
                <div class="rounded-xl border border-white/10 bg-bg-dark/80 p-5">
                  <h3 class="font-semibold text-white">{booleanContent.howItWorks.cards[0].title}</h3>
                  <p class="mt-2 text-sm text-slate-400 leading-6">{booleanContent.howItWorks.cards[0].description}</p>
                </div>
                <div class="rounded-xl border border-white/10 bg-bg-dark/80 p-5">
                  <h3 class="font-semibold text-white">{booleanContent.howItWorks.cards[1].title}</h3>
                  <p class="mt-2 text-sm text-slate-400 leading-6">{booleanContent.howItWorks.cards[1].description}</p>
                </div>
                <div class="rounded-xl border border-white/10 bg-bg-dark/80 p-5">
                  <h3 class="font-semibold text-white">{booleanContent.howItWorks.cards[2].title}</h3>
                  <p class="mt-2 text-sm text-slate-400 leading-6">{booleanContent.howItWorks.cards[2].description}</p>
                </div>
              </div>
            </article>
          </div>
        </section>

        <section class="border-t border-white/5 bg-bg-panel py-14 sm:py-16">
          <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
            <article class="rounded-2xl border border-white/10 bg-bg-surface/50 p-5 sm:p-6">
              <header>
                <h2 class="text-2xl font-bold tracking-tight text-white sm:text-3xl">{booleanContent.identities.title}</h2>
                <p class="mt-4 text-slate-300 leading-7">{booleanContent.identities.intro}</p>
              </header>
              <div class="mt-6 overflow-hidden rounded-2xl border border-white/10">
                <table class="w-full text-left text-sm">
                  <thead class="bg-white/[0.04] text-slate-300">
                    <tr>
                      <th class="px-4 py-3 text-xs font-semibold uppercase tracking-widest">{booleanContent.identities.headers.name}</th>
                      <th class="px-4 py-3 text-xs font-semibold uppercase tracking-widest">{booleanContent.identities.headers.expression}</th>
                      <th class="px-4 py-3 text-xs font-semibold uppercase tracking-widest">{booleanContent.identities.headers.description}</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-white/10 text-slate-300">
                    <tr><td class="px-4 py-3 font-semibold text-white">{booleanContent.identities.rows.deMorgan1.name}</td><td class="px-4 py-3 font-mono text-violet-400">(AB)&apos; = A&apos; + B&apos;</td><td class="px-4 py-3">{booleanContent.identities.rows.deMorgan1.description}</td></tr>
                    <tr><td class="px-4 py-3 font-semibold text-white">{booleanContent.identities.rows.deMorgan2.name}</td><td class="px-4 py-3 font-mono text-violet-400">(A+B)&apos; = A&apos;B&apos;</td><td class="px-4 py-3">{booleanContent.identities.rows.deMorgan2.description}</td></tr>
                    <tr><td class="px-4 py-3 font-semibold text-white">{booleanContent.identities.rows.absorption.name}</td><td class="px-4 py-3 font-mono text-sky-400">A + AB = A</td><td class="px-4 py-3">{booleanContent.identities.rows.absorption.description}</td></tr>
                    <tr><td class="px-4 py-3 font-semibold text-white">{booleanContent.identities.rows.consensus.name}</td><td class="px-4 py-3 font-mono text-sky-400">AB + A&apos;C + BC = AB + A&apos;C</td><td class="px-4 py-3">{booleanContent.identities.rows.consensus.description}</td></tr>
                    <tr><td class="px-4 py-3 font-semibold text-white">{booleanContent.identities.rows.complement.name}</td><td class="px-4 py-3 font-mono text-emerald-400">A + A&apos; = 1 &nbsp; | &nbsp; AA&apos; = 0</td><td class="px-4 py-3">{booleanContent.identities.rows.complement.description}</td></tr>
                    <tr><td class="px-4 py-3 font-semibold text-white">{booleanContent.identities.rows.idempotent.name}</td><td class="px-4 py-3 font-mono text-emerald-400">A + A = A &nbsp; | &nbsp; AA = A</td><td class="px-4 py-3">{booleanContent.identities.rows.idempotent.description}</td></tr>
                  </tbody>
                </table>
              </div>
            </article>
          </div>
        </section>

        <section class="border-t border-white/5 bg-bg-dark py-14 sm:py-16">
          <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
            <article class="rounded-2xl border border-white/10 bg-bg-surface/50 p-5 sm:p-6">
              <header>
                <h2 class="text-2xl font-bold tracking-tight text-white sm:text-3xl">{booleanContent.quine.title}</h2>
                <p class="mt-4 text-slate-300 leading-7">{booleanContent.quine.intro}</p>
              </header>
              <ol class="mt-6 flex flex-col gap-4">
                <li class="flex gap-4 rounded-xl border border-white/10 bg-bg-dark/80 p-4">
                  <span class="shrink-0 flex items-center justify-center rounded-full bg-brand-primary w-8 h-8 text-sm font-bold text-white">1</span>
                  <div><strong class="text-white">{booleanContent.quine.steps[0].title}</strong> <span class="text-slate-400">{booleanContent.quine.steps[0].description}</span></div>
                </li>
                <li class="flex gap-4 rounded-xl border border-white/10 bg-bg-dark/80 p-4">
                  <span class="shrink-0 flex items-center justify-center rounded-full bg-brand-primary w-8 h-8 text-sm font-bold text-white">2</span>
                  <div><strong class="text-white">{booleanContent.quine.steps[1].title}</strong> <span class="text-slate-400">{booleanContent.quine.steps[1].description}</span></div>
                </li>
                <li class="flex gap-4 rounded-xl border border-white/10 bg-bg-dark/80 p-4">
                  <span class="shrink-0 flex items-center justify-center rounded-full bg-brand-primary w-8 h-8 text-sm font-bold text-white">3</span>
                  <div><strong class="text-white">{booleanContent.quine.steps[2].title}</strong> <span class="text-slate-400">{booleanContent.quine.steps[2].description}</span></div>
                </li>
                <li class="flex gap-4 rounded-xl border border-white/10 bg-bg-dark/80 p-4">
                  <span class="shrink-0 flex items-center justify-center rounded-full bg-brand-primary w-8 h-8 text-sm font-bold text-white">4</span>
                  <div><strong class="text-white">{booleanContent.quine.steps[3].title}</strong> <span class="text-slate-400">{booleanContent.quine.steps[3].description}</span></div>
                </li>
                <li class="flex gap-4 rounded-xl border border-white/10 bg-bg-dark/80 p-4">
                  <span class="shrink-0 flex items-center justify-center rounded-full bg-brand-primary w-8 h-8 text-sm font-bold text-white">5</span>
                  <div><strong class="text-white">{booleanContent.quine.steps[4].title}</strong> <span class="text-slate-400">{booleanContent.quine.steps[4].description}</span></div>
                </li>
              </ol>
            </article>
          </div>
        </section>
      </>
    ) : (
      <>
        <section class="border-t border-white/5 bg-bg-panel py-12 sm:py-14" aria-labelledby="workflow-overview-title">
          <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
            <header class="max-w-4xl">
              <h2 id="workflow-overview-title" class="text-2xl font-bold tracking-tight text-white sm:text-3xl">{translateText('keyword.truth.workflow_overview', 'Workflow Overview')}</h2>
              <p class="mt-3 text-slate-400">{normalizedTruthContent.overview}</p>
            </header>

            <nav class="mt-6 rounded-2xl border border-white/10 bg-bg-dark/40 p-4" aria-label={translateText('keyword.truth.on_page_nav', 'On-page workflow sections')}>
              <ol class="grid gap-2 sm:grid-cols-2">
                {normalizedTruthContent.sections.map((section, index) => (
                  <li>
                    <a href={`#${section.id}`} class="block rounded-xl border border-white/10 bg-white/[0.02] px-4 py-3 text-sm font-medium text-slate-200 transition hover:border-brand-primary/35 hover:text-white">
                      {index + 1}. {section.title}
                    </a>
                  </li>
                ))}
              </ol>
            </nav>
          </div>
        </section>

        {normalizedTruthContent.sections.map((section, sectionIndex) => (
          <section id={section.id} class="border-t border-white/5 bg-bg-dark py-14 sm:py-16" aria-labelledby={`${section.id}-title`}>
            <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
              <header class="max-w-4xl">
                <p class="text-xs font-semibold uppercase tracking-[0.22em] text-brand-accent">{translateText('keyword.truth.stage', 'Stage')} {sectionIndex + 1}</p>
                <h2 id={`${section.id}-title`} class="mt-2 text-2xl font-bold tracking-tight text-white sm:text-3xl">{section.title}</h2>
                <p class="mt-3 text-slate-400">{section.description}</p>
              </header>

              <div class="mt-8 grid gap-6 lg:grid-cols-2">
                <figure class="rounded-2xl border border-white/10 bg-bg-surface/70 p-5 sm:p-6" data-illustration-block>
                  <figcaption class="text-base font-semibold text-white">{section.diagramTitle}</figcaption>
                  <svg viewBox="0 0 420 130" class="mt-4 w-full" role="img" aria-label={section.diagramTitle}>
                    {section.diagramSteps.slice(0, -1).map((_, index) => {
                      const stepCount = Math.max(1, section.diagramSteps.length - 1);
                      const x1 = 60 + (280 / stepCount) * index;
                      const x2 = 60 + (280 / stepCount) * (index + 1);
                      return <line x1={x1} y1="62" x2={x2} y2="62" stroke="rgba(148,163,184,0.35)" stroke-width="4" stroke-linecap="round" />;
                    })}

                    {section.diagramSteps.map((step, index) => {
                      const stepCount = Math.max(1, section.diagramSteps.length - 1);
                      const cx = 60 + (280 / stepCount) * index;
                      return (
                        <g>
                          <circle data-ill-node data-active={index === 0 ? 'true' : 'false'} cx={cx} cy="62" r="20" fill="rgba(30,41,59,0.95)" stroke="rgba(148,163,184,0.4)" stroke-width="2.5"></circle>
                          <text x={cx} y="67" text-anchor="middle" fill="#e2e8f0" font-size="11" font-family="Inter, sans-serif">{index + 1}</text>
                          <text x={cx} y="102" text-anchor="middle" fill="#94a3b8" font-size="10" font-family="Inter, sans-serif">{step.label}</text>
                        </g>
                      );
                    })}
                  </svg>

                  <div class="mt-4 flex flex-wrap gap-2">
                    {section.diagramSteps.map((step, index) => (
                      <button
                        type="button"
                        data-ill-button
                        data-active={index === 0 ? 'true' : 'false'}
                        data-ill-detail={step.detail}
                        class="rounded-lg border border-white/15 px-3 py-2 text-xs font-semibold text-slate-300 transition hover:border-brand-primary/40 hover:text-white"
                        aria-pressed={index === 0 ? 'true' : 'false'}
                      >
                        {step.label}
                      </button>
                    ))}
                  </div>

                  <p data-ill-detail class="mt-4 rounded-xl border border-white/10 bg-bg-dark/80 px-4 py-3 text-sm leading-6 text-slate-300">
                    {section.diagramSteps[0].detail}
                  </p>
                </figure>

                <div class="overflow-hidden rounded-2xl border border-white/10 bg-bg-surface/70">
                  <table class="w-full text-left text-sm">
                    <caption class="border-b border-white/10 bg-white/[0.04] px-4 py-3 text-left text-xs font-semibold uppercase tracking-[0.2em] text-slate-300">
                      {section.tableCaption}
                    </caption>
                    <thead class="bg-white/[0.03] text-slate-300">
                      <tr>
                        {section.tableHeaders.map((header) => (
                          <th class="px-4 py-3 text-xs font-semibold uppercase tracking-[0.16em]">{header}</th>
                        ))}
                      </tr>
                    </thead>
                    <tbody class="divide-y divide-white/10 text-slate-300">
                      {section.tableRows.map((row) => (
                        <tr>
                          <td class="px-4 py-3 font-semibold text-white">{row[0]}</td>
                          <td class="px-4 py-3">{row[1]}</td>
                          <td class="px-4 py-3">{row[2]}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          </section>
        ))}
      </>
    )}

    <RelatedToolsSection locale={locale} excludeKeys={[toolKey]} />
  </article>

  <FAQ title={translateText('keyword.faq.title', 'Frequently Asked Questions')} items={activeFaqItems} />

  <script is:inline>
    (() => {
      const blocks = Array.from(document.querySelectorAll('[data-illustration-block]'));
      if (!blocks.length) return;

      blocks.forEach((block) => {
        const buttons = Array.from(block.querySelectorAll('[data-ill-button]'));
        const nodes = Array.from(block.querySelectorAll('[data-ill-node]'));
        const detail = block.querySelector('[data-ill-detail]');
        if (!buttons.length || !nodes.length || !detail) return;

        const activate = (index) => {
          buttons.forEach((button, buttonIndex) => {
            const isActive = buttonIndex === index;
            button.dataset.active = String(isActive);
            button.setAttribute('aria-pressed', String(isActive));
          });

          nodes.forEach((node, nodeIndex) => {
            node.dataset.active = String(nodeIndex <= index);
          });

          detail.textContent = buttons[index]?.dataset.illDetail || '';
        };

        buttons.forEach((button, index) => {
          button.addEventListener('click', () => activate(index));
        });

        activate(0);
      });
    })();
  </script>

  <style>
    [data-ill-button][data-active='true'] {
      border-color: rgba(59, 130, 246, 0.55);
      background: rgba(59, 130, 246, 0.18);
      color: #fff;
    }

    [data-ill-node][data-active='true'] {
      stroke: rgba(59, 130, 246, 0.9);
      fill: rgba(30, 64, 175, 0.35);
    }
  </style>
</BaseLayout>
