---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLocalizedPath, useTranslations } from '../../theme/i18n';
import InlineKeywordTool from './InlineKeywordTool.astro';
import FAQ from '../../components/FAQ.astro';
import RelatedToolsSection from '../../components/RelatedToolsSection.astro';

interface Props {
  locale: string;
  heading: string;
  toolKey: 'boolean-expression-simplifier' | 'truth-table-to-logic-circuit';
}

interface DiagramStep {
  label: string;
  detail: string;
}

interface HeadingBlock {
  id: string;
  title: string;
  illustrationSummary: string;
  purpose: string;
  diagramTitle: string;
  diagramSteps: DiagramStep[];
  tableCaption: string;
  tableHeaders: [string, string, string];
  tableRows: [string, string, string][];
  imageSrc?: string;
}

interface SchematicSection {
  main: HeadingBlock;
  subs?: HeadingBlock[];
}

interface ToolFaqItem {
  question: string;
  answer: string;
  display: boolean;
}

const { locale, heading, toolKey } = Astro.props;
const t = useTranslations(locale);

const translateText = (key: string, fallback: string) => {
  const value = t(key);
  return typeof value === 'string' && value !== key ? value : fallback;
};

const translateObject = <T,>(key: string, fallback: T): T => {
  const value = t(key);
  return value && typeof value === 'object' ? (value as T) : fallback;
};

// Tool-specific metadata (SEO)
const toolMeta = {
  'boolean-expression-simplifier': {
    title: translateText('keyword.heading.boolean_expression_simplifier', heading),
    description: translateText('keyword.meta.boolean_expression_simplifier', 'Simplify any boolean algebra expression instantly. Supports SOP notation, De Morgan law reduction, truth table generation and gate diagram output.')
  },
  'truth-table-to-logic-circuit': {
    title: translateText('keyword.heading.truth_table_to_logic_circuit', heading),
    description: translateText('keyword.meta.truth_table_to_logic_circuit', 'Convert truth-table output patterns into simplified Boolean expressions and practical gate-level circuit plans for faster validation.')
  }
};

