const schematicNavLinks = schematicSections.flatMap((section) => {
  const mainLink = [{ id: section.main.id, title: section.main.title, level: 'h2' }];
  const subLinks = (section.subs || []).map((sub) => ({ id: sub.id, title: sub.title, level: 'h3' }));
  return [...mainLink, ...subLinks];
});

const schematicInternalLinks = [
  {
    title: 'How to Read a Circuit Diagram (Step by Step)',
    href: getLocalizedPath('/blog/how-to-read-a-circuit-diagram-step-by-step-guide/', locale),
    description: 'Build confidence reading symbols, nets, and flow before conversion.'
  },
  {
    title: 'How to Make a Circuit Diagram Online',
    href: getLocalizedPath('/blog/how-to-make-circuit-diagram-online/', locale),
    description: 'Create cleaner source schematics that convert more reliably.'
  },
  {
    title: 'Circuit Components Library',
    href: getLocalizedPath('/components/', locale),
    description: 'Verify symbol meanings and part behavior while mapping components.'
  },
  {
    title: 'Circuit Editor Documentation',
    href: getLocalizedPath('/docs/', locale),
    description: 'Use shortcuts and editor workflows to prepare valid inputs quickly.'
  },
  {
    title: 'Open Circuit Diagram Editor',
    href: getLocalizedPath('/editor/', locale),
    description: 'Draw and refine source schematics before running conversion.'
  }
];

const schematicFaqItems: ToolFaqItem[] = [
  {
    question: 'Can I convert a hand-drawn or rough schematic?',
    answer: 'Yes, but best results come from clean symbol and net labeling before conversion.',
    display: true
  },
  {
    question: 'Does this replace manual hardware verification?',
    answer: 'No. Use the generated plan as guidance, then verify continuity and polarity on real hardware.',
    display: true
  },
  {
    question: 'What parts most often fail during mapping?',
    answer: 'Polarity-sensitive parts and transistor pin-order assumptions cause most mapping issues.',
    display: true
  },
  {
    question: 'Can I share the conversion output with teammates?',
    answer: 'Yes. Export visual formats for reviews and JSON for editable project transfer.',
    display: true
  }
];

const activeFaqItems = toolKey === 'schematic-to-breadboard' ? schematicFaqItems : truthContent.faqItems;

const pageDescription = toolMetaDescriptions[toolKey];
---

<BaseLayout title={heading} description={pageDescription}>
  <article aria-labelledby="tool-page-title">
    <InlineKeywordTool toolKey={toolKey} heading={heading} />

    {toolKey === 'schematic-to-breadboard' ? (
      <>
        <section class="border-t border-white/5 bg-bg-panel py-12 sm:py-14" aria-labelledby="schematic-page-map-title">
          <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
            <header class="max-w-4xl">
              <h2 id="schematic-page-map-title" class="text-2xl font-bold tracking-tight text-white sm:text-3xl">Schematic to Breadboard Content Map</h2>
              <p class="mt-3 text-slate-400">Navigate directly to each required section and step. Every heading includes its own interactive illustration and structured reference table.</p>
            </header>
            <nav class="mt-6 rounded-2xl border border-white/10 bg-bg-dark/40 p-4" aria-label="Schematic to breadboard heading map">
              <ol class="grid gap-2 sm:grid-cols-2">
                {schematicNavLinks.map((link) => (
                  <li>
                    <a href={`#${link.id}`} class:list={[
                      'block rounded-xl border border-white/10 bg-white/[0.02] px-4 py-3 text-sm transition hover:border-brand-primary/35 hover:text-white',
                      link.level === 'h2' ? 'font-semibold text-slate-100' : 'font-medium text-slate-300'
                    ]}>
                      {link.title}
                    </a>
                  </li>
                ))}
              </ol>
            </nav>
          </div>
        </section>

        {schematicSections.map((section) => (
          <section id={section.main.id} class="border-t border-white/5 bg-bg-dark py-14 sm:py-16" aria-labelledby={`${section.main.id}-title`}>
            <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
              <article class="rounded-2xl border border-white/10 bg-bg-surface/50 p-5 sm:p-6">
                <header>
                  <h2 id={`${section.main.id}-title`} class="text-2xl font-bold tracking-tight text-white sm:text-3xl">{section.main.title}</h2>
                  <p class="mt-4 text-slate-300 leading-7">{section.main.illustrationSummary}</p>
                </header>

                <div class="mt-6 grid gap-6 lg:grid-cols-2">
                  <figure class="rounded-2xl border border-white/10 bg-bg-dark/80 p-5" data-illustration-block>
                    <figcaption class="text-base font-semibold text-white">{section.main.diagramTitle}</figcaption>
                    <svg viewBox="0 0 420 130" class="mt-4 w-full" role="img" aria-label={section.main.diagramTitle}>
                      {section.main.diagramSteps.slice(0, -1).map((_, index) => {
                        const stepCount = Math.max(1, section.main.diagramSteps.length - 1);
                        const x1 = 60 + (280 / stepCount) * index;
                        const x2 = 60 + (280 / stepCount) * (index + 1);
