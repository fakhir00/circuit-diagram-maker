        purpose:
          'Prevention tip: work through your connection list one line at a time and physically verify each connection immediately after placing it. Do not wire the entire board and then test — by that point, a single missing jumper in a 30-wire circuit becomes extremely difficult to locate. Sequential verification catches floating connections the moment they occur.',
        diagramTitle: 'Floating Net Heatmap',
        diagramSteps: [
          {
            label: 'Scan',
            detail: 'Scan all required nets and mark unresolved nodes.'
          },
          {
            label: 'Patch',
            detail: 'Insert missing jumper links to restore connectivity.'
          },
          {
            label: 'Finalize',
            detail: 'Re-run continuity checks until all nets report connected.'
          }
        ],
        tableCaption: 'Floating-connection troubleshooting',
        tableHeaders: ['Issue', 'Detection Signal', 'Fix'],
        tableRows: [
          ['Unconnected node', 'Heatmap highlights open net', 'Add missing jumper'],
          ['Partial rail feed', 'Only subset of nodes energized', 'Bridge rail segments'],
          ['Intermittent output', 'Random behavior under motion', 'Secure and re-seat leads']
        ]
      }
    ]
  }
];

const schematicNavLinks = schematicSections.flatMap((section) => {
  const mainLink = [{ id: section.main.id, title: section.main.title, level: 'h2' }];
  const subLinks = (section.subs || []).map((sub) => ({ id: sub.id, title: sub.title, level: 'h3' }));
  return [...mainLink, ...subLinks];
});

const schematicInternalLinks = [
  {
    title: 'How to Read a Circuit Diagram (Step by Step)',
    href: getLocalizedPath('/blog/how-to-read-a-circuit-diagram-step-by-step-guide/', locale),
    description: 'Build confidence reading symbols, nets, and flow before conversion.'
  },
  {
    title: 'How to Make a Circuit Diagram Online',
    href: getLocalizedPath('/blog/how-to-make-circuit-diagram-online/', locale),
    description: 'Create cleaner source schematics that convert more reliably.'
  },
  {
    title: 'Circuit Components Library',
    href: getLocalizedPath('/components/', locale),
    description: 'Verify symbol meanings and part behavior while mapping components.'
  },
  {
    title: 'Circuit Editor Documentation',
    href: getLocalizedPath('/docs/', locale),
    description: 'Use shortcuts and editor workflows to prepare valid inputs quickly.'
  },
  {
    title: 'Open Circuit Diagram Editor',
    href: getLocalizedPath('/editor/', locale),
    description: 'Draw and refine source schematics before running conversion.'
  }
];

const schematicFaqItems: ToolFaqItem[] = [
  {
    question: 'Can I convert a hand-drawn or rough schematic?',
    answer: 'Yes, but best results come from clean symbol and net labeling before conversion.',
    display: true
  },
  {
    question: 'Does this replace manual hardware verification?',
    answer: 'No. Use the generated plan as guidance, then verify continuity and polarity on real hardware.',
    display: true
  },
  {
    question: 'What parts most often fail during mapping?',
