---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLocalizedPath } from '../../theme/i18n';
import InlineKeywordTool from './InlineKeywordTool.astro';

interface Props {
  locale: string;
  heading: string;
  toolKey: 'schematic-to-breadboard' | 'truth-table-to-logic-circuit';
}

const { locale, heading, toolKey } = Astro.props;

const relatedTools = [
  {
    title: 'Logic Gate Diagram Tool',
    href: getLocalizedPath('/logic-gate-diagram-tool/', locale),
    description: 'Build clear gate-level logic diagrams and validate signal flow.'
  },
  {
    title: 'Arduino Circuit Maker',
    href: getLocalizedPath('/arduino-circuit-maker/', locale),
    description: 'Document board pin connections, modules, and wiring paths quickly.'
  },
  {
    title: 'PCB Schematic Tool',
    href: getLocalizedPath('/pcb-schematic-tool/', locale),
    description: 'Draft production-ready schematic structures before PCB layout.'
  }
];
---

<BaseLayout title={heading} description={`${heading} on Circuit Diagram Maker.`}>
  <InlineKeywordTool toolKey={toolKey} heading={heading} />

  <section class="bg-bg-panel py-14 sm:py-16 border-t border-white/5">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold tracking-tight text-white sm:text-3xl">Related Tools</h2>
      <p class="mt-3 max-w-3xl text-slate-400">
        Explore these dedicated tool pages to continue your workflow with logic, Arduino, and PCB-focused diagram setups.
      </p>
      <div class="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {relatedTools.map((tool) => (
          <article class="rounded-2xl border border-white/10 bg-bg-surface/70 p-5 transition-colors hover:border-brand-primary/30 hover:bg-bg-surface">
            <h3 class="text-lg font-semibold text-white">{tool.title}</h3>
            <p class="mt-2 text-sm leading-6 text-slate-400">{tool.description}</p>
            <a href={tool.href} class="mt-4 inline-flex rounded-lg bg-brand-primary px-4 py-2 text-sm font-semibold text-white transition hover:bg-blue-500">
              Open Tool
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
