---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLocalizedPath } from '../../theme/i18n';
import InlineKeywordTool from './InlineKeywordTool.astro';
import FAQ from '../../components/FAQ.astro';
import RelatedToolsSection from '../../components/RelatedToolsSection.astro';

interface Props {
  locale: string;
  heading: string;
  toolKey: 'schematic-to-breadboard' | 'truth-table-to-logic-circuit';
}

interface DiagramStep {
  label: string;
  detail: string;
}

interface HeadingBlock {
  id: string;
  title: string;
  illustrationSummary: string;
  purpose: string;
  diagramTitle: string;
  diagramSteps: DiagramStep[];
  tableCaption: string;
  tableHeaders: [string, string, string];
  tableRows: [string, string, string][];
}

interface SchematicSection {
  main: HeadingBlock;
  subs?: HeadingBlock[];
}

interface ToolFaqItem {
  question: string;
  answer: string;
  display: boolean;
}

const { locale, heading, toolKey } = Astro.props;

const toolMetaDescriptions: Record<Props['toolKey'], string> = {
  'schematic-to-breadboard':
    'Convert schematic diagrams into breadboard layouts with interactive mapping steps, worked examples, and mistake-proof wiring checks.',
  'truth-table-to-logic-circuit':
    'Convert truth-table output patterns into simplified Boolean expressions and practical gate-level circuit plans for faster validation.'
};

const truthContent = {
  overview:
    'This workflow converts output-bit behavior into a simplified Boolean expression and a practical gate-stage plan for quick implementation.',
  sections: [
    {
      id: 'boolean-reduction',
      title: 'Boolean Reduction Pipeline',
      description:
        'The tool validates variable and bit lengths, extracts minterms, and reduces the expression so the final equation is easier to implement.',
      diagramTitle: 'Interactive Simplification Diagram',
      diagramSteps: [
        {
          label: 'Validate',
          detail: 'Variable count determines required truth-table rows before any reduction starts.'
        },
        {
          label: 'Extract',
          detail: 'Rows with output 1 are converted into minterm indexes.'
        },
        {
          label: 'Reduce',
          detail: 'Compatible terms are merged to produce a shorter Boolean expression.'
        }
      ],
      tableCaption: 'Core checks used for expression minimization',
      tableHeaders: ['Input Rule', 'Why It Matters', 'Output'] as [string, string, string],
      tableRows: [
        ['1-4 variables', 'Defines manageable truth-table width', 'Expected bit count'],
        ['Bit-length match', 'Prevents invalid row interpretation', 'Reliable minterm set'],
        ['Prime reduction', 'Removes redundant terms', 'Simplified expression']
      ] as [string, string, string][]
    },
    {
      id: 'gate-planning',
      title: 'Gate-Level Planning and Verification',
      description:
        'After simplification, the tool estimates gate stages and provides a compact implementation path for NOT, AND, and OR composition.',
      diagramTitle: 'Interactive Gate Planning Diagram',
      diagramSteps: [
        {
          label: 'Invert',
          detail: 'Only required complemented literals are sent through NOT stages.'
        },
        {
          label: 'Combine',
          detail: 'Product terms are created with AND gates based on reduced expression terms.'
        },
        {
          label: 'Merge',
          detail: 'Final OR stage collects term outputs into the target function.'
        }
      ],
      tableCaption: 'Gate-stage mapping from reduced expression',
      tableHeaders: ['Gate Stage', 'Purpose', 'Design Benefit'] as [string, string, string],
      tableRows: [
        ['NOT stage', 'Generate complemented literals', 'Reduces wiring ambiguity'],
        ['AND stage', 'Build each product term', 'Keeps logic modular'],
        ['OR stage', 'Merge term outputs', 'Directly matches F output']
      ] as [string, string, string][]
    }
  ],
  faqItems: [
    {
      question: 'How many variables are supported on this page?',
      answer: 'The inline tool accepts between 1 and 4 variables.',
      display: true
    },
    {
      question: 'Why must output bits match exactly 2^n rows?',
      answer: 'Each row represents one input combination. Missing or extra bits break row alignment.',
      display: true
    },
    {
      question: 'Is this useful for class assignments and prototyping?',
      answer: 'Yes. It is useful for quick derivation, checking simplification, and preparing gate-level drafts.',
      display: true
    }
  ] as ToolFaqItem[]
};

const schematicSections: SchematicSection[] = [
  {
    main: {
      id: 'what-is-a-schematic-circuit-diagram',
      title: '1. What is a Schematic Circuit Diagram?',
      illustrationSummary:
        'This interactive illustration uses a schematic-to-breadboard reveal where users switch between symbol view and physical placement view. Clicking each symbol highlights the matching real part and connection rails. It helps users see why schematics describe electrical intent, not physical location.',
      purpose:
        'Content purpose: establish the foundation by defining a schematic circuit diagram, how symbols represent electrical behavior, and how that differs from breadboard wiring layout.',
      diagramTitle: 'Schematic vs Physical Wiring Explorer',
      diagramSteps: [
        {
          label: 'Symbols',
          detail: 'Schematic symbols represent function and electrical relationship, not literal board position.'
        },
        {
          label: 'Nodes',
          detail: 'Node labels and net links show what must connect electrically, regardless of layout shape.'
        },
        {
          label: 'Placement',
          detail: 'Breadboards require physical row and rail placement decisions to realize the same net intent.'
        }
      ],
      tableCaption: 'Schematic foundation reference',
      tableHeaders: ['Concept', 'Schematic View', 'Breadboard View'],
      tableRows: [
        ['Resistor', 'Value + symbol in circuit path', 'Physical lead across two rows'],
        ['Power', 'VCC/GND symbols and net names', 'Positive/negative rail placement'],
        ['Connection', 'Logical net continuity', 'Row jumper and wire continuity']
