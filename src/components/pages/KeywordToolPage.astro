      tableRows: [
        ['Single LED', 'Polarity and resistor placement', 'Beginner'],
        ['Series resistors', 'Node continuity and value tracing', 'Intermediate'],
        ['Transistor switch', 'Pin mapping and control paths', 'Intermediate+']
      ]
    },
    subs: [
      {
        id: 'example-1-single-led-circuit',
        title: 'Example 1: Single LED Circuit',
        illustrationSummary:
          'This interactive LED example lets users toggle resistor values and immediately see current-path feedback. The view highlights anode/cathode orientation and required power path continuity. It is ideal for understanding the smallest valid conversion.',
        purpose:
          'Content purpose: reinforce polarity, resistor safety, and clean VCC-to-GND path mapping.',
