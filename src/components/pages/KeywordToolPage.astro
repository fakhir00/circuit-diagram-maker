  },
  {
    main: {
      id: 'common-mistakes-when-converting-schematics-to-breadboard',
      title: '4. Common Mistakes When Converting Schematics to Breadboard',
      illustrationSummary:
        'This section uses an interactive fix-the-layout challenge where users identify and correct deliberate conversion errors. Each correction updates a validation score and explains electrical consequences. It turns troubleshooting into guided practice.',
      purpose:
        'Content purpose: prevent frequent conversion failures by training users to recognize and resolve high-impact mistakes.',
      diagramTitle: 'Find-and-Fix Error Challenge',
      diagramSteps: [
        {
          label: 'Detect',
          detail: 'Spot rail, orientation, or continuity mistakes in a faulty layout.'
        },
        {
          label: 'Correct',
          detail: 'Adjust rows, orientation, and jumpers to match net intent.'
        },
        {
          label: 'Validate',
          detail: 'Run final checks and review why each fix mattered.'
        }
      ],
      tableCaption: 'High-impact conversion mistakes',
      tableHeaders: ['Mistake Type', 'Symptoms', 'Prevention'],
      tableRows: [
        ['Power/GND confusion', 'Circuit appears dead or shorts rails', 'Explicit rail labeling and checks'],
        ['Reversed orientation', 'Part fails or overheats', 'Pin/polarity validation'],
        ['Floating nets', 'Intermittent or no output', 'Continuity verification before power-up']
      ]
