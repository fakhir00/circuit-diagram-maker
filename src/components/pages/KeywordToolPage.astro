  <script is:inline>
    (() => {
      const blocks = Array.from(document.querySelectorAll('[data-illustration-block]'));
      if (!blocks.length) return;

      blocks.forEach((block) => {
        const buttons = Array.from(block.querySelectorAll('[data-ill-button]'));
        const nodes = Array.from(block.querySelectorAll('[data-ill-node]'));
        const detail = block.querySelector('[data-ill-detail]');
        if (!buttons.length || !nodes.length || !detail) return;

        const activate = (index) => {
          buttons.forEach((button, buttonIndex) => {
            const isActive = buttonIndex === index;
            button.dataset.active = String(isActive);
            button.setAttribute('aria-pressed', String(isActive));
          });

          nodes.forEach((node, nodeIndex) => {
            node.dataset.active = String(nodeIndex <= index);
          });

          detail.textContent = buttons[index]?.dataset.illDetail || '';
        };

        buttons.forEach((button, index) => {
          button.addEventListener('click', () => activate(index));
        });

        activate(0);
      });
    })();
  </script>

  <style>
    [data-ill-button][data-active='true'] {
      border-color: rgba(59, 130, 246, 0.55);
      background: rgba(59, 130, 246, 0.18);
      color: #fff;
    }

    [data-ill-node][data-active='true'] {
      stroke: rgba(59, 130, 246, 0.9);
      fill: rgba(30, 64, 175, 0.35);
    }
  </style>
