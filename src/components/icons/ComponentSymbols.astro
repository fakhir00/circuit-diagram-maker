const { symbolId = "", class: className = "w-6 h-6" } = Astro.props;

const id = symbolId.toLowerCase().trim().replace(/\s+/g, '-');
---

<svg 
  viewBox="0 0 24 24" 
  fill="none" 
  stroke="currentColor" 
  stroke-width="1.8" 
  stroke-linecap="round" 
  stroke-linejoin="round" 
  class={className}
>
  {/* Passives */}
  {id.includes('resistor') && <path d="M3 12h3l1.5-4 2 8 2-8 2 8 2-8 1.5 4h3" />}
  {id.includes('capacitor') && <path d="M3 12h7M14 12h7M10 5v14M14 5v14" />}
  {id.includes('inductor') && <path d="M3 12h2a2 2 0 104 0 2 2 0 104 0 2 2 0 104 0h2" />}
  {id.includes('potentiometer') && (
    <>
      <path d="M3 12h2l1-3 1.5 6 1.5-6 1.5 6 1.5-6 1 3h2" />
      <path d="M12 4v4l-2 2M12 4l2 2" />
    </>
  )}
  {id.includes('fuse') && (
    <>
      <rect x="6" y="8" width="12" height="8" rx="1" />
      <path d="M3 12h3M18 12h3M6 12c2-2 4 2 6 0s4-2 6 0" />
    </>
  )}
  {id.includes('thermistor') && (
    <>
      <rect x="6" y="9" width="12" height="6" />
      <path d="M3 12h3M18 12h3M8 17l8-10" />
    </>
  )}

  {/* Semiconductors */}
  {(id.includes('diode') && !id.includes('zener')) && <path d="M3 12h6M15 12h6M9 7v10l6-5-6-5zM15 7v10" />}
  {id.includes('zener') && <path d="M3 12h6M15 12h6M9 7v10l6-5-6-5zM15 7h1v2M14 15h1v2" />}
  {id.includes('led') && (
    <>
      <path d="M3 12h6M15 12h6M9 7v10l6-5-6-5zM15 7v10" />
      <path d="M11 5l2-3M14 6l2-3M13 2h-1M16 3h-1" />
    </>
  )}
  {(id.includes('transistor') || id.includes('mosfet')) && (
    <>
      <circle cx="12" cy="12" r="9" />
      <path d="M9 7v10M9 12h4M13 12l3-4M13 12l3 4" />
    </>
  )}

  {/* ICs */}
  {(id.includes('op-amp') || id.includes('comparator')) && <path d="M4 6v12l14-6-14-6z M18 12h3M2 9h2M2 15h2" />}
  {id.includes('microcontroller') && (
    <>
      <rect x="6" y="6" width="12" height="12" rx="1" />
      <path d="M6 9H4M6 12H4M6 15H4M18 9h2M18 12h2M18 15h2" />
    </>
  )}
  {id.includes('logic-gate') && <path d="M4 6v12h4c4 0 8-3 8-6s-4-6-8-6H4z M2 9h2M2 15h2M16 12h4" />}
  {id.includes('555') && <rect x="5" y="5" width="14" height="14" rx="1" />}
  {id.includes('regulator') && <rect x="6" y="7" width="12" height="10" />}

  {/* Power */}
  {id.includes('battery') && <path d="M10 6v12M14 9v6M6 6v12M18 9v6M3 12h3M18 12h3" />}
  {id.includes('source') && (
    <>
      <circle cx="12" cy="12" r="8" />
      <path d="M12 8v8M10 12h4" />
    </>
  )}
  {id.includes('ground') && <path d="M12 4v12M6 16h12M9 19h6M11 20h2" />}
  {id.includes('rail') && <path d="M12 20V8M8 8l4-4 4 4" />}

  {/* Connector */}
  {id.includes('connector') && <rect x="5" y="8" width="14" height="8" rx="1" />}
  {id.includes('usb') && <rect x="4" y="7" width="16" height="10" rx="1" />}
  {id.includes('antenna') && <path d="M12 20V10M8 6l4 4 4-4" />}

  {/* Electromechanical */}
  {id.includes('relay') && <rect x="4" y="7" width="8" height="10" />}
  {id.includes('switch') && (
    <>
      <circle cx="6" cy="12" r="1.5" />
      <circle cx="18" cy="12" r="1.5" />
      <path d="M18 12l-10-4" />
    </>
  )}
  {id.includes('button') && (
    <>
      <circle cx="6" cy="14" r="1.5" />
      <circle cx="18" cy="14" r="1.5" />
      <path d="M6 10h12" />
    </>
  )}
  {id.includes('motor') && <circle cx="12" cy="12" r="8" />}
  {id.includes('speaker') && <path d="M4 9h4l5-5v16l-5-5H4V9z" />}
  {id.includes('buzzer') && <path d="M6 8h12v4H6V8z M12 12c0 4-4 4-8 4" />}

  {/* Default/Fallback */}
  {!id && <circle cx="12" cy="12" r="9" opacity="0.2" />}
</svg>
