---
import { getLocalizedPath } from '../theme/i18n';

interface Props {
  locale: string;
}

const { locale } = Astro.props;

const comparisonRows = [
  ['Keyboard shortcuts', 'Global command palette, search, quick placement', 'Accelerates expert workflows'],
  ['Reusable symbols', 'Custom labels, grouped references, library categories', 'Keeps large schematics consistent'],
  ['Output formats', 'SVG, PNG, documentation-friendly snapshots', 'Ready for handoff and publishing'],
  ['Review flow', 'Readable net paths and sectioned diagrams', 'Faster reviews with fewer redraw cycles']
];

const workflowCards = [
  {
    title: 'Plan',
    detail: 'Start from a template for analog, power, or control logic and lay out the critical blocks first.'
  },
  {
    title: 'Connect',
    detail: 'Use consistent wire directions, label important nodes, and separate control from power paths.'
  },
  {
    title: 'Publish',
    detail: 'Export clean diagrams and pair them with docs so teammates can review without opening source files.'
  }
];
---

<section class="border-t border-white/5 bg-bg-panel py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid gap-8 lg:grid-cols-[minmax(0,1.1fr)_420px]">
      <div class="rounded-[2rem] border border-white/10 bg-bg-surface/70 p-8">
        <p class="text-sm font-semibold uppercase tracking-[0.32em] text-brand-accent">Reference Tables</p>
        <h2 class="mt-4 text-3xl font-bold tracking-tight text-white">Home page data your team can actually use</h2>
        <p class="mt-4 max-w-2xl text-lg leading-7 text-slate-400">
          The editor is only part of the workflow. These references help reviewers, technical writers, and implementers stay aligned while the schematic evolves.
        </p>

        <div class="mt-8 overflow-hidden rounded-3xl border border-white/10">
          <table class="w-full border-collapse text-left text-sm">
            <thead class="bg-white/5 text-slate-300">
              <tr>
                <th class="px-5 py-4 font-semibold uppercase tracking-[0.22em]">Capability</th>
                <th class="px-5 py-4 font-semibold uppercase tracking-[0.22em]">What you get</th>
                <th class="px-5 py-4 font-semibold uppercase tracking-[0.22em]">Why it matters</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-white/10 bg-bg-panel/60 text-slate-300">
              {comparisonRows.map((row) => (
                <tr class="align-top">
                  <td class="px-5 py-4 font-medium text-white">{row[0]}</td>
                  <td class="px-5 py-4">{row[1]}</td>
                  <td class="px-5 py-4 text-slate-400">{row[2]}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <div class="rounded-[2rem] border border-white/10 bg-[linear-gradient(180deg,rgba(59,130,246,0.12),rgba(15,23,42,0.98))] p-8">
        <p class="text-sm font-semibold uppercase tracking-[0.32em] text-brand-accent">Diagram Workflow</p>
        <div class="mt-8 space-y-6">
          {workflowCards.map((card, index) => (
            <div class="rounded-3xl border border-white/10 bg-black/10 p-5">
              <div class="mb-3 flex items-center gap-4">
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-brand-primary/20 text-sm font-semibold text-white">
                  {index + 1}
                </div>
                <h3 class="text-xl font-semibold text-white">{card.title}</h3>
              </div>
              <p class="text-slate-300">{card.detail}</p>
            </div>
          ))}
        </div>

        <div class="mt-8 rounded-3xl border border-white/10 bg-bg-dark/60 p-6">
          <h3 class="text-lg font-semibold text-white">Need deeper references?</h3>
          <p class="mt-3 text-slate-400">
            Browse the component catalog or read the full documentation path for setup, shortcuts, and diagram conventions.
          </p>
          <div class="mt-5 flex flex-wrap gap-3">
            <a href={getLocalizedPath('/components/', locale)} class="rounded-full border border-white/10 px-4 py-2 text-sm font-medium text-white transition hover:border-white/20 hover:bg-white/5">
              Browse components
            </a>
            <a href={getLocalizedPath('/docs/', locale)} class="rounded-full bg-brand-primary px-4 py-2 text-sm font-semibold text-white transition hover:bg-blue-500">
              Read docs
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
