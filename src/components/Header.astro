---
import { getLocalizedPath, useTranslations, locales } from '../theme/i18n';

interface Props {
  locale: string;
  config: any;
}

const { locale, config } = Astro.props;
const t = useTranslations(locale);
const currentPath = Astro.url.pathname;
---

<header class="bg-bg-panel border-b border-white/5 sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      
      <!-- Brand -->
      <div class="flex-shrink-0 flex items-center gap-2">
        <a href={getLocalizedPath('/', locale)} class="flex items-center gap-2 group" aria-label="Home">
          <svg class="text-brand-primary w-6 h-6 filter drop-shadow-[0_0_6px_rgba(59,130,246,0.4)] transition-transform group-hover:scale-110" viewBox="0 0 24 24" fill="none">
              <path d="M4 12h3l2-5 3 10 2-5h3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="4" cy="12" r="1.5" fill="currentColor"/>
              <circle cx="17" cy="12" r="1.5" fill="currentColor"/>
          </svg>
          <span class="font-bold text-lg tracking-tight bg-gradient-to-br from-white to-slate-400 bg-clip-text text-transparent group-hover:from-brand-primary group-hover:to-brand-secondary transition-all">
            {config.site.name}
          </span>
        </a>
      </div>

      <!-- JSON-LD SiteNavigationElement -->
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "ItemList",
        "itemListElement": config.nav.map((item: any, index: number) => ({
          "@type": "SiteNavigationElement",
          "position": index + 1,
          "name": t(item.labelKey),
          "url": new URL(getLocalizedPath(item.path, locale), config.site.url)
        }))
      })} />

      <!-- Desktop Nav -->
      <nav class="hidden md:flex space-x-6">
        {config.nav.map((item: any) => {
           const isActive = currentPath === getLocalizedPath(item.path, locale);
           return (
             <a 
               href={getLocalizedPath(item.path, locale)} 
               class={`text-sm font-medium transition-colors ${isActive ? 'text-brand-accent' : 'text-slate-300 hover:text-white'}`}
             >
               {t(item.labelKey)}
             </a>
           );
        })}
      </nav>

      <!-- Language Switcher & Mobile Menu Toggle -->
      <div class="flex items-center gap-4">
        
        <div class="relative group">
          <button class="flex items-center gap-1 text-sm font-medium text-slate-300 hover:text-white uppercase transition-colors">
            {locale}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </button>
          <div class="absolute right-0 mt-2 w-40 bg-bg-surface border border-white/10 rounded-md shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all grid grid-cols-2 p-2 gap-1 z-50">
            {locales.map((l) => (
              <a href={getLocalizedPath(currentPath, l)} class={`px-2 py-1 text-xs rounded hover:bg-slate-800 ${locale === l ? 'text-brand-primary' : 'text-slate-300'}`}>
                {l.toUpperCase()}
              </a>
            ))}
          </div>
        </div>

        <button id="mobile-menu-btn" class="md:hidden text-slate-300 hover:text-white" aria-expanded="false" aria-label="Toggle menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path id="menu-icon-path" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
        </button>
      </div>

    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-bg-surface border-t border-white/5" aria-hidden="true">
    <div class="px-2 pt-2 pb-3 space-y-1">
      {config.nav.map((item: any) => (
         <a 
           href={getLocalizedPath(item.path, locale)} 
           class="block px-3 py-2 rounded-md text-base font-medium text-slate-300 hover:text-white hover:bg-slate-800"
         >
           {t(item.labelKey)}
         </a>
      ))}
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const icon = document.getElementById('menu-icon-path');

  if (btn && menu && icon) {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      menu.classList.toggle('hidden');
      menu.setAttribute('aria-hidden', String(expanded));
      if (!expanded) {
        icon.setAttribute('d', 'M6 18L18 6M6 6l12 12'); // X icon
        document.body.style.overflow = 'hidden';
      } else {
        icon.setAttribute('d', 'M4 6h16M4 12h16M4 18h16'); // Hamburger
        document.body.style.overflow = '';
      }
    });

    // Close when clicking a link
    menu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        menu.classList.add('hidden');
        btn.setAttribute('aria-expanded', 'false');
        icon.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
        document.body.style.overflow = '';
      });
    });
  }
</script>
