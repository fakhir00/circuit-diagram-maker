---
import { getLocalizedPath, useTranslations, locales } from '../theme/i18n';

interface Props {
  locale: string;
  config: any;
}

const { locale, config } = Astro.props;
const t = useTranslations(locale);
const currentPath = Astro.url.pathname;
---

<header class="bg-bg-panel border-b border-white/5 sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      
      <!-- Brand -->
      <div class="flex-shrink-0 flex items-center gap-2">
        <a href={getLocalizedPath('/', locale)} class="flex items-center gap-3 group" aria-label="Home">
          <div class="relative flex items-center justify-center">
            <svg class="w-9 h-9 transform transition-all duration-500 group-hover:rotate-12 group-hover:scale-110" viewBox="0 0 40 40" fill="none">
              <defs>
                <linearGradient id="logoGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" style="stop-color:var(--color-brand-primary);stop-opacity:1" />
                  <stop offset="100%" style="stop-color:var(--color-brand-secondary);stop-opacity:1" />
                </linearGradient>
                <filter id="logoGlow" x="-20%" y="-20%" width="140%" height="140%">
                  <feGaussianBlur stdDeviation="2" result="blur" />
                  <feComposite in="SourceGraphic" in2="blur" operator="over" />
                </filter>
              </defs>
              <!-- Outer hexagon-ish frame -->
              <path d="M20,2 L36,11 L36,29 L20,38 L4,29 L4,11 Z" 
                    fill="none" stroke="url(#logoGrad)" stroke-width="2.5" stroke-linejoin="round"
                    class="opacity-40 group-hover:opacity-100 transition-opacity" />
              <!-- Schematic Node -->
              <circle cx="20" cy="20" r="5" fill="url(#logoGrad)" filter="url(#logoGlow)" />
              <!-- Connecting Traces -->
              <path d="M10,14 L20,20 L30,14 M20,20 L20,32" 
                    stroke="url(#logoGrad)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <div class="absolute inset-0 bg-brand-primary/20 blur-xl rounded-full scale-0 group-hover:scale-100 transition-transform duration-700 opacity-30"></div>
          </div>
          <div class="flex flex-col leading-none">
            <span class="font-black text-lg sm:text-xl tracking-tight text-white group-hover:text-brand-primary transition-colors uppercase">
              CIRCUIT<span class="text-slate-500">DIAGRAM</span><span class="ml-1 text-slate-600 hidden xs:inline">MAKER</span>
            </span>
            <span class="text-[8px] sm:text-[9px] font-bold text-brand-secondary tracking-[0.15em] sm:tracking-[0.2em] uppercase opacity-70 truncate">Free Online PCB Schematic Tool</span>
          </div>
        </a>
      </div>

      <!-- JSON-LD SiteNavigationElement -->
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "ItemList",
        "itemListElement": config.nav.map((item: any, index: number) => ({
          "@type": "SiteNavigationElement",
          "position": index + 1,
          "name": t(item.labelKey),
          "url": new URL(getLocalizedPath(item.path, locale), config.site.url)
        }))
      })} />

      <!-- Desktop Nav -->
      <nav class="hidden md:flex space-x-6">
        {config.nav.map((item: any) => {
           const isActive = currentPath === getLocalizedPath(item.path, locale);
           return (
             <a 
               href={getLocalizedPath(item.path, locale)} 
               class={`text-sm font-medium transition-colors ${isActive ? 'text-brand-accent' : 'text-slate-300 hover:text-white'}`}
             >
               {t(item.labelKey)}
             </a>
           );
        })}
      </nav>

      <!-- Language Switcher & Mobile Menu Toggle -->
      <div class="flex items-center gap-2 sm:gap-4">
        
        <div class="relative group">
          <button class="flex items-center gap-1 text-sm font-medium text-slate-300 hover:text-white uppercase transition-colors">
            {locale}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </button>
          <div class="absolute right-0 mt-2 w-40 bg-bg-surface border border-white/10 rounded-md shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all grid grid-cols-2 p-2 gap-1 z-50">
            {locales.map((l) => (
              <a href={getLocalizedPath(currentPath, l)} class={`px-2 py-1 text-xs rounded hover:bg-slate-800 ${locale === l ? 'text-brand-primary' : 'text-slate-300'}`}>
                {l.toUpperCase()}
              </a>
            ))}
          </div>
        </div>

        <button id="mobile-menu-btn" class="md:hidden text-slate-300 hover:text-white" aria-expanded="false" aria-label="Toggle menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path id="menu-icon-path" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
        </button>
      </div>

    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-bg-surface border-t border-white/5" aria-hidden="true">
    <div class="px-2 pt-2 pb-3 space-y-1">
      {config.nav.map((item: any) => (
         <a 
           href={getLocalizedPath(item.path, locale)} 
           class="block px-3 py-2 rounded-md text-base font-medium text-slate-300 hover:text-white hover:bg-slate-800"
         >
           {t(item.labelKey)}
         </a>
      ))}
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const icon = document.getElementById('menu-icon-path');

  if (btn && menu && icon) {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      menu.classList.toggle('hidden');
      menu.setAttribute('aria-hidden', String(expanded));
      if (!expanded) {
        icon.setAttribute('d', 'M6 18L18 6M6 6l12 12'); // X icon
        document.body.style.overflow = 'hidden';
      } else {
        icon.setAttribute('d', 'M4 6h16M4 12h16M4 18h16'); // Hamburger
        document.body.style.overflow = '';
      }
    });

    // Close when clicking a link
    menu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        menu.classList.add('hidden');
        btn.setAttribute('aria-expanded', 'false');
        icon.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
        document.body.style.overflow = '';
      });
    });
  }
</script>
