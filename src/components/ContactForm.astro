---
interface Props {
  email: string;
}

const { email } = Astro.props;
---

<div class="bg-bg-dark/40 border border-white/10 rounded-3xl p-8 backdrop-blur-md relative shadow-2xl overflow-hidden group/form">
  <!-- Decorative corner glow -->
  <div class="absolute -top-24 -right-24 w-48 h-48 bg-brand-primary/10 blur-[80px] rounded-full group-hover/form:bg-brand-primary/20 transition-colors duration-700"></div>
  
  <form class="space-y-6 relative z-10" id="contact-form">
    <div class="grid gap-6 sm:grid-cols-2">
      <div>
        <label for="name" class="block text-xs font-bold uppercase tracking-widest text-slate-500 mb-2">Full Name</label>
        <input type="text" id="name" name="name" required class="block w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder-slate-600 focus:border-brand-primary focus:ring-4 focus:ring-brand-primary/10 transition-all outline-none" placeholder="Nikola Tesla" />
      </div>
      <div>
        <label for="email" class="block text-xs font-bold uppercase tracking-widest text-slate-500 mb-2">Email Address</label>
        <input type="email" id="email" name="email" required class="block w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder-slate-600 focus:border-brand-primary focus:ring-4 focus:ring-brand-primary/10 transition-all outline-none" placeholder="nikola@wardenclyffe.io" />
      </div>
    </div>
    
    <div>
      <label for="message" class="block text-xs font-bold uppercase tracking-widest text-slate-500 mb-2">Technical Details / Message</label>
      <textarea id="message" name="message" rows="5" required class="block w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder-slate-600 focus:border-brand-primary focus:ring-4 focus:ring-brand-primary/10 transition-all outline-none resize-none" placeholder="Describe your circuit design challenge or feature request..."></textarea>
    </div>
    
    <div id="form-status" class="hidden text-sm font-medium p-4 rounded-xl border transition-all duration-300"></div>

    <button type="submit" id="submit-btn" class="group/submit relative w-full flex items-center justify-center gap-3 py-4 px-6 rounded-2xl bg-gradient-to-r from-brand-primary to-brand-secondary text-white font-black uppercase tracking-widest text-sm hover:shadow-[0_0_40px_rgba(59,130,246,0.3)] active:scale-[0.98] transition-all disabled:opacity-50 disabled:cursor-not-allowed overflow-hidden">
      <span class="relative z-10 flex items-center gap-2">
        Establish Contact
        <svg class="w-4 h-4 transform group-hover/submit:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
      </span>
      <div class="absolute inset-0 bg-white/20 translate-y-full group-hover/submit:translate-y-0 transition-transform duration-300"></div>
    </button>
  </form>
  
  <div class="mt-10 border-t border-white/5 pt-6 text-center">
    <p class="text-xs font-bold text-slate-600 uppercase tracking-widest">Alternatively</p>
    <a href={`mailto:${email}`} class="mt-2 inline-block text-slate-400 hover:text-brand-primary transition-colors font-medium text-sm border-b border-dashed border-white/20 hover:border-brand-primary/50">{email}</a>
  </div>
</div>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const statusDiv = document.getElementById('form-status');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  if (form && statusDiv && submitBtn) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      submitBtn.disabled = true;
      const originalText = submitBtn.textContent;
      submitBtn.textContent = 'Sending...';
      
      statusDiv.className = 'hidden';
      
      try {
        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());
        
        // Mocking an async XHR endpoint request as per master-prompt-theme contract
        await new Promise((resolve, reject) => {
           setTimeout(() => {
             // Simulate 90% success rate
             if (Math.random() > 0.1) resolve(true);
             else reject('Network Error');
           }, 1500);
        });
        
        statusDiv.textContent = 'Your message has been sent successfully! We will get back to you shortly.';
        statusDiv.className = 'block p-4 rounded-xl bg-green-500/10 text-green-400 text-sm font-medium border border-green-500/20 mb-6';
        form.reset();
      } catch (error) {
        statusDiv.textContent = 'Network Error: Failed to send your message. Please try again or email us directly.';
        statusDiv.className = 'block p-4 rounded-xl bg-red-500/10 text-red-400 text-sm font-medium border border-red-500/20 mb-6';
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = originalText;
      }
    });
  }
</script>
