---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLocaleFromUrl, useTranslations, getLocalizedPath } from '../theme/i18n';
import ContactForm from '../components/ContactForm.astro';

const { locale } = Astro.props;
const t = useTranslations(locale);

const supportFaqs = t('contact.support_faqs');
---

<BaseLayout title={t('contact.meta.title')} description={t('contact.meta.description')}>
  <section class="relative overflow-hidden border-b border-white/5 bg-bg-dark py-20">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(59,130,246,0.08),transparent_40%)]"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-sm font-semibold uppercase tracking-[0.35em] text-brand-accent mb-4">{t('contact.hero.badge')}</p>
      <h1 class="text-4xl font-extrabold tracking-tight text-white">{t('contact.hero.title')}</h1>
      <p class="mt-6 text-xl text-slate-400 leading-relaxed max-w-3xl">
        {t('contact.hero.subtitle')}
      </p>
    </div>
  </section>

  <section class="py-16 bg-bg-panel">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-[1fr_380px]">
        <div>
          <h2 class="text-2xl font-bold text-white mb-6">{t('contact.form.title')}</h2>
          <ContactForm email="support@circuit-diagram.org" />
        </div>

        <div class="space-y-6">
          <div class="rounded-xl border border-white/10 bg-bg-dark/50 p-5">
            <h3 class="text-lg font-semibold text-white mb-3">{t('contact.sidebar.email.title')}</h3>
            <p class="text-sm text-slate-400 mb-2">{t('contact.sidebar.email.desc')}</p>
            <a href="mailto:support@circuit-diagram.org" class="text-brand-primary hover:text-brand-accent text-sm font-medium">support@circuit-diagram.org</a>
          </div>
          <div class="rounded-xl border border-white/10 bg-bg-dark/50 p-5">
            <h3 class="text-lg font-semibold text-white mb-3">{t('contact.sidebar.time.title')}</h3>
            <p class="text-sm text-slate-400">{t('contact.sidebar.time.desc')} <strong class="text-white">{t('contact.sidebar.time.strong')}</strong> {t('contact.sidebar.time.context')}</p>
          </div>
          <div class="rounded-xl border border-white/10 bg-bg-dark/50 p-5">
            <h3 class="text-lg font-semibold text-white mb-3">{t('contact.sidebar.features.title')}</h3>
            <p class="text-sm text-slate-400">{t('contact.sidebar.features.desc')}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Support FAQs -->
  <section class="py-16 bg-bg-dark border-t border-white/5">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-white mb-8">{t('contact.faq.title')}</h2>
      <div class="space-y-4">
        {supportFaqs.map((faq: any) => (
          <details class="group bg-bg-surface border border-white/10 rounded-xl overflow-hidden transition-all duration-300 open:border-brand-primary/50">
            <summary class="flex justify-between items-center p-5 cursor-pointer list-none text-white font-medium hover:bg-white/5 transition-colors">
              <span>{faq.q}</span>
              <svg class="w-5 h-5 text-slate-400 group-open:rotate-180 transition-transform duration-300 flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="p-5 pt-0 text-slate-400 leading-relaxed border-t border-white/5 bg-bg-panel/30">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  summary::-webkit-details-marker { display: none; }
</style>
