---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLocaleFromUrl, useTranslations, getLocalizedPath } from '../theme/i18n';
import ContactForm from '../components/ContactForm.astro';

const locale = getLocaleFromUrl(Astro.url.pathname);
const t = useTranslations(locale);

const supportFaqs = [
  { q: 'My circuit diagram didn\'t save — how do I recover it?', a: 'Circuit Diagram Maker uses browser local storage. If you cleared your browser data, the diagram may be lost. We recommend exporting important projects as JSON files for backup. To prevent data loss, use the Export as JSON feature after every significant editing session.' },
  { q: 'Can I import diagrams from other tools into Circuit Diagram Maker?', a: 'Currently, Circuit Diagram Maker supports importing its own JSON format. You can share JSON files between devices and collaborators. Import support for additional formats is on our development roadmap.' },
  { q: 'The editor loads slowly on my device — what can I do?', a: 'For best performance, use a modern browser (Chrome, Firefox, Edge) with hardware acceleration enabled. Close unused browser tabs to free up memory. Circuit Diagram Maker works best on devices with 4GB+ RAM.' },
];
---

<BaseLayout title="Contact Us — Circuit Diagram Maker Support" description="Get help with Circuit Diagram Maker. Contact our support team for technical issues, feature requests, or general questions about our free circuit diagram tool.">
  <section class="relative overflow-hidden border-b border-white/5 bg-bg-dark py-20">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(59,130,246,0.08),transparent_40%)]"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-sm font-semibold uppercase tracking-[0.35em] text-brand-accent mb-4">Support</p>
      <h1 class="text-4xl font-extrabold tracking-tight text-white">Contact Circuit Diagram Maker Support</h1>
      <p class="mt-6 text-xl text-slate-400 leading-relaxed max-w-3xl">
        Have a question about Circuit Diagram Maker? Found a bug in the editor? Want to request a new component symbol? Our team typically responds within 24 hours on business days. Before reaching out, check our common support questions below.
      </p>
    </div>
  </section>

  <section class="py-16 bg-bg-panel">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-[1fr_380px]">
        <div>
          <h2 class="text-2xl font-bold text-white mb-6">Send Us a Message</h2>
          <ContactForm email="support@circuit-diagram.org" />
        </div>

        <div class="space-y-6">
          <div class="rounded-xl border border-white/10 bg-bg-dark/50 p-5">
            <h3 class="text-lg font-semibold text-white mb-3">📧 Email Support</h3>
            <p class="text-sm text-slate-400 mb-2">For technical issues and feature requests:</p>
            <a href="mailto:support@circuit-diagram.org" class="text-brand-primary hover:text-brand-accent text-sm font-medium">support@circuit-diagram.org</a>
          </div>
          <div class="rounded-xl border border-white/10 bg-bg-dark/50 p-5">
            <h3 class="text-lg font-semibold text-white mb-3">⏱️ Response Time</h3>
            <p class="text-sm text-slate-400">We typically respond within <strong class="text-white">24 hours</strong> on business days (Monday–Friday). For urgent issues with the circuit diagram maker, include "URGENT" in your subject line.</p>
          </div>
          <div class="rounded-xl border border-white/10 bg-bg-dark/50 p-5">
            <h3 class="text-lg font-semibold text-white mb-3">💡 Feature Requests</h3>
            <p class="text-sm text-slate-400">We love hearing from users! If you have an idea for a new component, export format, or editor feature, let us know — the best Circuit Diagram Maker features were suggested by our community.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Support FAQs -->
  <section class="py-16 bg-bg-dark border-t border-white/5">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-white mb-8">Common Support Questions</h2>
      <div class="space-y-4">
        {supportFaqs.map(faq => (
          <details class="group bg-bg-surface border border-white/10 rounded-xl overflow-hidden transition-all duration-300 open:border-brand-primary/50">
            <summary class="flex justify-between items-center p-5 cursor-pointer list-none text-white font-medium hover:bg-white/5 transition-colors">
              <span>{faq.q}</span>
              <svg class="w-5 h-5 text-slate-400 group-open:rotate-180 transition-transform duration-300 flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="p-5 pt-0 text-slate-400 leading-relaxed border-t border-white/5 bg-bg-panel/30">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  summary::-webkit-details-marker { display: none; }
</style>
