---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLocaleFromUrl, useTranslations } from '../theme/i18n';

const locale = getLocaleFromUrl(Astro.url.pathname);
const t = useTranslations(locale);
const lastUpdated = "2023-10-24";
---

<BaseLayout title={t('footer.privacy')}>
  <div class="max-w-4xl mx-auto px-4 py-24 sm:px-6 lg:px-8">
    <h1 class="text-4xl font-bold tracking-tight text-white mb-4">{t('footer.privacy')}</h1>
    <p class="text-slate-400 mb-8">Last updated: {lastUpdated}</p>
    
    <div class="prose prose-invert prose-blue max-w-none text-slate-300">
      <h2>1. Information We Collect</h2>
      <p>We do not collect any personal data when you use the diagram editor. All circuits are saved directly to your local storage. We only collect standard analytics data strictly for operational purposes.</p>
      
      <h2>2. How We Use Your Information</h2>
      <p>Any non-personal data collected is used solely to improve the user experience and maintain the performance of the website.</p>
    </div>
  </div>
</BaseLayout>
