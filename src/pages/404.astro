---
import BaseLayout from './layouts/BaseLayout.astro';
import { getLocalizedPath, getLocaleFromUrl } from './theme/i18n';

const locale = getLocaleFromUrl(Astro.url.pathname);
---

<BaseLayout title="404 - Page Not Found">
  <div class="max-w-7xl mx-auto px-4 py-32 sm:px-6 lg:px-8 flex flex-col items-center text-center">
    <div class="relative mb-8">
      <h1 class="text-9xl font-black text-white/10 select-none">404</h1>
      <div class="absolute inset-0 flex items-center justify-center">
        <svg class="w-20 h-20 text-brand-primary animate-pulse" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
        </svg>
      </div>
    </div>
    <h2 class="text-3xl font-bold text-white mb-4">Oops! Page not found.</h2>
    <p class="text-slate-400 max-w-md mx-auto mb-10 leading-relaxed text-lg">
      It looks like the schematic you're trying to find doesn't exist. Let's get you back to safety.
    </p>
    <a href={getLocalizedPath('/', locale)} class="px-8 py-3 rounded-xl bg-brand-primary hover:bg-blue-600 text-white font-bold transition-all shadow-[0_0_20px_rgba(59,130,246,0.3)] hover:scale-105 active:scale-95">
      Return Home
    </a>
  </div>
</BaseLayout>
