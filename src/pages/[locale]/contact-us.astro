---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { locales, defaultLocale, useTranslations } from '../../theme/i18n';
import ContactForm from '../../components/ContactForm.astro';

export async function getStaticPaths() {
  const otherLocales = locales.filter(l => l !== defaultLocale);
  return otherLocales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
const t = useTranslations(locale || defaultLocale);
---

<BaseLayout title={t('footer.contact')}>
  <section class="relative overflow-hidden bg-bg-dark pt-24 pb-16 border-b border-white/5">
    <!-- Blueprint Grid Background -->
    <div class="absolute inset-0 bg-[radial-gradient(circle,rgba(59,130,246,0.08)_1px,transparent_1px)] [background-size:32px_32px] opacity-40"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-bg-dark/50 to-bg-dark"></div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.35em] text-brand-accent mb-4">Get In Touch</p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-black tracking-tight text-white mb-6 underline decoration-brand-primary/30 decoration-8 underline-offset-8">{t('footer.contact')}</h1>
      <p class="text-xl text-slate-400 max-w-2xl mx-auto leading-relaxed">
        Technical support, feature requests, or academic collaboration — we're here to power your projects.
      </p>
    </div>
  </section>

  <section class="bg-bg-panel py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-2 items-start">
        
        <!-- Support Info -->
        <div class="space-y-8">
          <div class="p-6 rounded-2xl border border-white/10 bg-bg-dark/40 backdrop-blur-sm shadow-xl">
            <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-3">
              <svg class="w-6 h-6 text-brand-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              Direct Support Channels
            </h2>
            <div class="space-y-6">
              <div class="group cursor-pointer">
                <p class="text-xs font-bold text-brand-primary uppercase tracking-widest mb-1">Email us at</p>
                <a href="mailto:support@circuit-diagram.org" class="text-lg font-medium text-slate-300 group-hover:text-white transition-colors">support@circuit-diagram.org</a>
              </div>
              <div class="group cursor-pointer">
                <p class="text-xs font-bold text-brand-secondary uppercase tracking-widest mb-1">Social media</p>
                <p class="text-lg font-medium text-slate-300 group-hover:text-white transition-colors">@CircuitDiagramMaker</p>
              </div>
            </div>
          </div>

          <div class="p-6 rounded-2xl border border-white/10 bg-bg-dark/40 backdrop-blur-sm shadow-xl">
            <h2 class="text-xl font-bold text-white mb-4 flex items-center gap-3">
              <svg class="w-6 h-6 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              Quick Resources
            </h2>
            <div class="grid gap-4">
              <a href="/docs/" class="p-4 rounded-xl border border-white/5 bg-white/5 hover:bg-white/10 transition-all flex items-center justify-between group">
                <span class="text-sm font-medium text-slate-300 group-hover:text-white">Documentation Hub</span>
                <svg class="w-4 h-4 text-slate-500 group-hover:text-brand-primary group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>
              <a href="/blog/" class="p-4 rounded-xl border border-white/5 bg-white/5 hover:bg-white/10 transition-all flex items-center justify-between group">
                <span class="text-sm font-medium text-slate-300 group-hover:text-white">Technical Tutorials</span>
                <svg class="w-4 h-4 text-slate-500 group-hover:text-brand-primary group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <ContactForm email="support@circuit-diagram.org" />
        
      </div>
    </div>
  </section>
</BaseLayout>
