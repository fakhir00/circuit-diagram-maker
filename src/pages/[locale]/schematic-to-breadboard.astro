---
import KeywordToolPage from '../../components/pages/KeywordToolPage.astro';
import { locales, defaultLocale } from '../../theme/i18n';

export async function getStaticPaths() {
  return locales
    .filter((locale) => locale !== defaultLocale)
    .map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
const activeLocale = locale || defaultLocale;
---

<KeywordToolPage
  locale={activeLocale}
  heading="Schematic To Breadboard"
  toolKey="schematic-to-breadboard"
/>

