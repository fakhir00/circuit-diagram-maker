---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BlogArticleLayout from '../../../components/blog/BlogArticleLayout.astro';
import config from '../../../data/config.json';

import { locales, defaultLocale } from '../../../theme/i18n';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  const enPosts = allPosts.filter(p => p.id.startsWith('en/'));
  
  const otherLocales = locales.filter(l => l !== defaultLocale);
  let paths: any[] = [];

  for (const loc of otherLocales) {
    let localePosts = allPosts.filter(p => p.id.startsWith(`${loc}/`));
    
    // If no translated posts for this locale, use English posts!
    if (localePosts.length === 0) {
      localePosts = enPosts;
    }

    localePosts.forEach(post => {
      // Slug is identical across languages assuming filenames are 1:1, or it uses the english slug.
      const slug = post.id.split('/').slice(1).join('/').replace(/\.md$/, '');
      paths.push({
        params: { locale: loc, slug },
        props: { post },
      });
    });
  }

  return paths;
}

const { post } = Astro.props;
const locale = Astro.params.locale || 'en';
const { Content, headings } = await render(post);
const siteUrl = Astro.site || config.site.url;
const canonicalURL = new URL(Astro.url.pathname, siteUrl);

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.data.title,
  "description": post.data.description,
  "image": post.data.image ? new URL(post.data.image, siteUrl) : undefined,
  "datePublished": post.data.date.toISOString(),
  "author": {
    "@type": "Person",
    "name": post.data.author || "CircuitForge Team"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Circuit Diagram Maker",
    "logo": {
      "@type": "ImageObject",
      "url": new URL('/logo.png', siteUrl)
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalURL
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": new URL('/', siteUrl)
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Blog",
      "item": new URL('/blog/', siteUrl)
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": post.data.title,
      "item": canonicalURL
    }
  ]
};
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <BlogArticleLayout post={post} Content={Content} headings={headings} locale={locale} />
</BaseLayout>
