---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BlogArticleLayout from '../../../components/blog/BlogArticleLayout.astro';
import config from '../../../data/config.json';

import { locales, defaultLocale } from '../../../theme/i18n';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  const enPosts = allPosts.filter(p => p.id.startsWith('en/'));
  
  const enPostsBySlug = new Map(
    enPosts.map((post) => [
      post.id.split('/').slice(1).join('/').replace(/\.(md|mdx)$/, ''),
      post,
    ])
  );
  
  const otherLocales = locales.filter(l => l !== defaultLocale);
  let paths: any[] = [];

  for (const loc of otherLocales) {
    const localePosts = allPosts.filter(p => p.id.startsWith(`${loc}/`));
    const localeSlugs = new Set(
      localePosts.map((p) => p.id.split('/').slice(1).join('/').replace(/\.(md|mdx)$/, ''))
    );
    
    // Start with translated posts
    const postsToGenerate = [...localePosts];
    
    // Add English fallbacks for missing translations
    enPosts.forEach((enPost) => {
      const slug = enPost.id.split('/').slice(1).join('/').replace(/\.(md|mdx)$/, '');
      if (!localeSlugs.has(slug)) {
        postsToGenerate.push(enPost);
      }
    });

    postsToGenerate.forEach(post => {
      const slug = post.id.split('/').slice(1).join('/').replace(/\.(md|mdx)$/, '');
      const enPostMatch = enPostsBySlug.get(slug);
      
      // Fallback image logic
      const postWithFallbackImage = post.data.image || !enPostMatch?.data.image
        ? post
        : {
            ...post,
            data: {
              ...post.data,
              image: enPostMatch.data.image,
            },
          };

      paths.push({
        params: { locale: loc, slug },
        props: { post: postWithFallbackImage },
      });
    });
  }

  return paths;
}

const { post } = Astro.props;
const locale = Astro.params.locale || 'en';
const { Content, headings } = await render(post);
const siteUrl = Astro.site || config.site.url;
const canonicalURL = new URL(Astro.url.pathname, siteUrl);

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.data.title,
  "description": post.data.description,
  "image": post.data.image ? new URL(post.data.image, siteUrl) : undefined,
  "datePublished": post.data.date.toISOString(),
  "author": {
    "@type": "Person",
    "name": post.data.author || "CircuitForge Team"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Circuit Diagram Maker",
    "logo": {
      "@type": "ImageObject",
      "url": new URL('/logo.png', siteUrl)
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalURL
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": new URL('/', siteUrl)
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Blog",
      "item": new URL(`/${locale}/blog/`, siteUrl)
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": post.data.title,
      "item": canonicalURL
    }
  ]
};
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <BlogArticleLayout post={post} Content={Content} headings={headings} locale={locale} />
</BaseLayout>
