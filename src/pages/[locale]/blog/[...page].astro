---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getLocaleFromUrl, useTranslations, locales, defaultLocale } from '../../../theme/i18n';
import config from '../../../data/config.json';

export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = await getCollection('blog');
  const enPosts = allPosts.filter(p => p.id.startsWith('en/'));
  
  const enPostsBySlug = new Map(
    enPosts.map((post) => [
      post.id.split('/').slice(1).join('/').replace(/\.(md|mdx)$/, ''),
      post,
    ])
  );
  
  const fromLocales = locales.filter(l => l !== defaultLocale);

  return fromLocales.flatMap((loc) => {
    const localePosts = allPosts.filter(p => p.id.startsWith(`${loc}/`));
    const localeSlugs = new Set(
      localePosts.map((p) => p.id.split('/').slice(1).join('/').replace(/\.(md|mdx)$/, ''))
    );
    
    // Start with translated posts
    const combinedPosts = [...localePosts];
    
    // Add English fallbacks for missing translations
    enPosts.forEach((enPost) => {
      const slug = enPost.id.split('/').slice(1).join('/').replace(/\.(md|mdx)$/, '');
      if (!localeSlugs.has(slug)) {
        combinedPosts.push(enPost);
      }
    });

    const finalPosts = combinedPosts.map((post) => {
      const slug = post.id.split('/').slice(1).join('/').replace(/\.(md|mdx)$/, '');
      const enPostMatch = enPostsBySlug.get(slug);
      
      // Fallback image logic
      if (!post.data.image && enPostMatch?.data.image) {
        return {
          ...post,
          data: {
            ...post.data,
            image: enPostMatch.data.image,
          },
        };
      }
      return post;
    });

    finalPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
    return paginate(finalPosts, { params: { locale: loc }, pageSize: 12 });
  });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const locale = getLocaleFromUrl(Astro.url.pathname);
const t = useTranslations(locale);
const siteUrl = Astro.site || config.site.url;

// Blog Schema
const blogSchema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "Circuit Diagram Maker Blog",
  "description": "Tutorials, news and insights about circuit design and engineering.",
  "url": new URL(Astro.url.pathname, siteUrl),
  "inLanguage": locale,
  "itemListElement": page.data.map((post, index) => {
    const slug = post.id.split('/').slice(1).join('/').replace(/\.(md|mdx)$/, '');
    return {
      "@type": "ListItem",
      "position": index + 1,
      "url": new URL(`/${locale}/blog/${slug}`, siteUrl),
      "name": post.data.title
    };
  })
};

const baseTitle = `${t('nav.blog')} — ${t('brand.name')}`;
const pageTitle = page.currentPage > 1 ? `${baseTitle} - ${t('blog.part')} ${page.currentPage}` : baseTitle;
---

<BaseLayout title={pageTitle} description={t('blog.subtitle')}>
  <script type="application/ld+json" set:html={JSON.stringify(blogSchema)} />

  <section class="page-hero relative overflow-hidden bg-bg-dark pt-32 pb-24 border-b border-white/5" aria-labelledby="blog-title">
    <!-- Blueprint Grid Background -->
    <div class="absolute inset-0 bg-[radial-gradient(circle,rgba(59,130,246,0.08)_1px,transparent_1px)] [background-size:32px_32px] opacity-40"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-bg-dark/50 to-bg-dark"></div>
    
    <div class="container relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="hero-badge inline-block text-[10px] font-black uppercase tracking-[0.25em] text-brand-accent bg-brand-primary/10 px-4 py-2 rounded-full border border-brand-primary/20 mb-6">{t('blog.eyebrow')}</div>
      <h1 id="blog-title" class="text-4xl md:text-5xl lg:text-7xl font-black tracking-tight text-white mb-6">{t('blog.title')}</h1>
      <p class="text-xl text-slate-400 max-w-2xl mx-auto mb-8 leading-relaxed">
        {t('blog.subtitle')}
      </p>
      <div class="flex items-center justify-center gap-4 text-xs font-mono text-slate-500 uppercase tracking-widest bg-white/5 w-fit mx-auto px-4 py-2 rounded-full border border-white/5 backdrop-blur-sm">
        <span class="w-2 h-2 rounded-full bg-brand-primary animate-pulse"></span>
        {page.total} {t('blog.articles_published')}
      </div>
    </div>
  </section>

  <section class="blog-listing-section relative" aria-labelledby="blog-articles-heading">
    <div class="container max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-24 mt-20">
      <h2 class="sr-only" id="blog-articles-heading">Articles</h2>
      <div class="blog-grid grid gap-8 md:grid-cols-2 lg:grid-cols-3 relative z-20">
        {page.data.map((post) => (
          <a href={`/${locale}/blog/${post.id.split('/').slice(1).join('/').replace(/\.(md|mdx)$/, '')}`} class="blog-card group block h-full focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary/70 focus-visible:ring-offset-2 focus-visible:ring-offset-bg-dark rounded-3xl" id={`article-${post.id.split('/').slice(1).join('/').replace(/\.(md|mdx)$/, '')}`}>
            <article class="blog-card-body relative p-6 rounded-3xl bg-bg-surface border border-white/10 hover:border-brand-primary/40 transition-all duration-500 flex flex-col h-full hover:shadow-[0_0_40px_rgba(59,130,246,0.15)] hover:-translate-y-2 overflow-hidden shadow-xl">
              <!-- Background Glow on Hover -->
              <div class="absolute -inset-10 bg-brand-primary/10 opacity-0 group-hover:opacity-100 transition-opacity blur-3xl pointer-events-none duration-700"></div>
              
              <!-- Image -->
              <div class="blog-card-image w-full h-48 bg-bg-dark rounded-2xl mb-6 relative overflow-hidden group-hover:shadow-lg transition-all duration-500 border border-white/5">
                {post.data.image ? (
                  <>
                    <img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
                    <div class="absolute inset-0 bg-gradient-to-t from-bg-dark via-transparent to-transparent opacity-80"></div>
                  </>
                ) : (
                  <>
                    <div class="absolute inset-0 bg-[linear-gradient(45deg,rgba(255,255,255,0.02)_25%,transparent_25%,transparent_75%,rgba(255,255,255,0.02)_75%,rgba(255,255,255,0.02)),linear-gradient(45deg,rgba(255,255,255,0.02)_25%,transparent_25%,transparent_75%,rgba(255,255,255,0.02)_75%,rgba(255,255,255,0.02))] [background-size:20px_20px] [background-position:0_0,10px_10px]"></div>
                    <div class="absolute inset-0 bg-gradient-to-tr from-brand-primary/20 to-brand-accent/20 mix-blend-overlay group-hover:opacity-100 opacity-50 transition-opacity duration-500"></div>
                    <div class="absolute inset-0 flex items-center justify-center opacity-30 group-hover:scale-110 transition-transform duration-700">
                      <svg class="w-16 h-16 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                    </div>
                  </>
                )}
              </div>
              
              <div class="relative z-10 flex flex-col h-full px-2">
                <div class="blog-card-meta flex items-center flex-wrap gap-2 mb-4 text-[11px] font-mono font-medium text-slate-400">
                  <span class="blog-card-tag text-brand-primary font-bold uppercase tracking-wider">{post.data.category || 'Article'}</span>
                  <span class="text-slate-600 font-bold opacity-60">•</span>
                  <time datetime={post.data.date.toISOString()}>
                    {post.data.date.toLocaleDateString(locale, { month: 'short', day: 'numeric', year: 'numeric' })}
                  </time>
                  <span class="text-slate-600 font-bold opacity-60">•</span>
                  <span>5 {t('blog.min_read')}</span>
                </div>
                
                <h3 class="text-2xl font-bold text-white mb-3 leading-snug group-hover:text-brand-primary transition-colors duration-300">
                  {post.data.title}
                </h3>
                
                <p class="text-slate-400 text-sm leading-relaxed flex-grow mb-6 line-clamp-3">
                  {post.data.description}
                </p>
                
                <div class="pt-5 border-t border-white/5 mt-auto">
                  <span class="blog-card-link group/btn inline-flex items-center gap-2 text-xs font-bold text-white tracking-widest uppercase group-hover:text-brand-accent transition-colors">
                    {t('blog.read_more')} →
                  </span>
                </div>
              </div>
            </article>
          </a>
        ))}
      </div>

      {/* Pagination */}
      {(page.url.prev || page.url.next) && (
        <nav class="flex justify-between items-center mt-20 pt-10 border-t border-white/5">
          {page.url.prev ? (
            <a href={page.url.prev} class="px-6 py-3 border border-white/10 rounded-xl bg-bg-surface hover:bg-slate-800 text-xs font-bold uppercase tracking-widest text-slate-300 hover:text-white transition-all shadow-sm">&larr; {t('blog.newer')}</a>
          ) : <div class="w-24"></div>}
          
          <div class="flex items-center gap-2">
            <span class="text-[10px] uppercase font-bold text-slate-500 tracking-widest">{t('blog.part')}</span>
            <span class="px-4 py-1.5 rounded-lg bg-brand-primary/10 border border-brand-primary/20 text-brand-primary font-bold text-sm shadow-inner">{page.currentPage}</span>
            <span class="text-[10px] uppercase font-bold text-slate-500 tracking-widest">{t('blog.of')} {page.lastPage}</span>
          </div>
          
          {page.url.next ? (
            <a href={page.url.next} class="px-6 py-3 border border-white/10 rounded-xl bg-bg-surface hover:bg-slate-800 text-xs font-bold uppercase tracking-widest text-slate-300 hover:text-white transition-all shadow-sm">{t('blog.older')} &rarr;</a>
          ) : <div class="w-24"></div>}
        </nav>
      )}
    </div>
  </section>

  <!-- CTA section mapping to seo-content-section -->
  <section class="seo-content-section pb-24 relative">
    <div class="container max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="content-flow relative p-12 md:p-16 rounded-[2.5rem] bg-gradient-to-b from-brand-primary/10 to-transparent border border-brand-primary/20 overflow-hidden shadow-[0_0_80px_rgba(59,130,246,0.1)]">
         <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(59,130,246,0.2)_0%,transparent_70%)] pointer-events-none"></div>
         <div class="absolute top-0 right-0 p-8 opacity-10">
           <svg class="w-64 h-64 text-brand-primary transform rotate-12" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="0.5" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" /></svg>
         </div>
         <article class="content-block relative z-10 flex flex-col items-center">
           <h2 class="text-3xl md:text-5xl font-black text-white mb-6 tracking-tight">{t('home.cta.title')}</h2>
           <p class="text-lg md:text-xl text-slate-300 max-w-2xl mx-auto mb-10 leading-relaxed">{t('home.cta.desc')}</p>
           <a href="/editor/" class="btn-primary inline-flex items-center justify-center font-bold px-10 py-5 rounded-2xl bg-gradient-to-r from-brand-primary to-brand-accent text-white shadow-[0_4px_20px_rgba(59,130,246,0.4)] hover:shadow-[0_8px_30px_rgba(59,130,246,0.6)] hover:-translate-y-1 transition-all duration-300 text-sm uppercase tracking-widest ring-1 ring-white/20">
             {t('nav.editor')} →
           </a>
         </article>
      </div>
    </div>
  </section>
</BaseLayout>
