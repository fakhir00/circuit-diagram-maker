---
import KeywordToolPage from '../../components/pages/KeywordToolPage.astro';
import { locales, defaultLocale, useTranslations } from '../../theme/i18n';

export async function getStaticPaths() {
  return locales
    .filter((locale) => locale !== defaultLocale)
    .map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
const activeLocale = locale || defaultLocale;
const t = useTranslations(activeLocale);
---

<KeywordToolPage
  locale={activeLocale}
  heading={t('keyword.heading.truth_table_to_logic_circuit')}
  toolKey="truth-table-to-logic-circuit"
/>

