---
import { locales, defaultLocale } from '../../theme/i18n';
import EditorPage from '../../components/pages/EditorPage.astro';

export async function getStaticPaths() {
  return locales
    .filter((locale) => locale !== defaultLocale)
    .map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
---

<EditorPage locale={locale || defaultLocale} editorMode="pcb" />
