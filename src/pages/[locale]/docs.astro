---
import DocumentationPage from '../../components/pages/DocumentationPage.astro';
import { locales, defaultLocale } from '../../theme/i18n';

export async function getStaticPaths() {
  const otherLocales = locales.filter((l) => l !== defaultLocale);
  return otherLocales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
---

<DocumentationPage locale={locale || defaultLocale} />
