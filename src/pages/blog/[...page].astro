---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLocaleFromUrl, useTranslations } from '../../theme/i18n';

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getCollection('blog', ({ id }) => id.startsWith('en/'));
  
  posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  
  return paginate(posts, { pageSize: 12 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const locale = getLocaleFromUrl(Astro.url.pathname);
const t = useTranslations(locale);

// Blog Schema
const blogSchema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "Circuit Diagram Maker Blog",
  "description": "Tutorials, news and insights about circuit design and engineering.",
  "url": new URL(Astro.url.pathname, Astro.site || 'https://circuit-diagram.org'),
  "inLanguage": locale,
  "itemListElement": page.data.map((post, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "url": new URL(`/blog/${post.id.replace(/^en\//, '')}`, Astro.site || 'https://circuit-diagram.org'),
    "name": post.data.title
  }))
};
---

<BaseLayout title={`${t('nav.blog')} — ${t('brand.name')}`} description={t('blog.subtitle')}>
  <script type="application/ld+json" set:html={JSON.stringify(blogSchema)} />

  <section class="relative overflow-hidden bg-bg-dark pt-24 pb-16 border-b border-white/5">
    <!-- Blueprint Grid Background -->
    <div class="absolute inset-0 bg-[radial-gradient(circle,rgba(59,130,246,0.08)_1px,transparent_1px)] [background-size:32px_32px] opacity-40"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-bg-dark/50 to-bg-dark"></div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.35em] text-brand-accent mb-4">{t('blog.eyebrow')}</p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-black tracking-tight text-white mb-6">{t('blog.title')}</h1>
      <p class="text-xl text-slate-400 max-w-2xl mx-auto mb-8 leading-relaxed">
        {t('blog.subtitle')}
      </p>
      <div class="flex items-center justify-center gap-4 text-xs font-mono text-slate-500 uppercase tracking-widest bg-white/5 w-fit mx-auto px-4 py-2 rounded-full border border-white/5 backdrop-blur-sm">
        <span class="w-2 h-2 rounded-full bg-brand-primary animate-pulse"></span>
        {page.total} {t('blog.articles_published')}
      </div>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 py-20 sm:px-6 lg:px-8">
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {page.data.map((post) => (
        <a href={`/blog/${post.id.replace(/^en\//, '')}`} class="group block h-full focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary/70 focus-visible:ring-offset-2 focus-visible:ring-offset-bg-dark rounded-3xl">
          <article class="relative p-8 rounded-3xl bg-bg-panel border border-white/10 hover:border-brand-primary/40 transition-all duration-500 flex flex-col h-full hover:shadow-[0_0_40px_rgba(59,130,246,0.12)] hover:-translate-y-1 overflow-hidden">
            <!-- Background Glow on Hover -->
            <div class="absolute -inset-10 bg-brand-primary/5 opacity-0 group-hover:opacity-100 transition-opacity blur-3xl pointer-events-none"></div>
            
            <div class="relative z-10 flex flex-col h-full">
              <div class="flex items-center justify-between mb-5">
                <time datetime={post.data.date.toISOString()} class="text-xs font-bold text-slate-500 uppercase tracking-widest">
                  {post.data.date.toLocaleDateString(locale, { month: 'short', day: 'numeric', year: 'numeric' })}
                </time>
                <span class="text-[10px] font-black uppercase tracking-tighter px-2 py-1 bg-brand-primary/10 text-brand-primary rounded border border-brand-primary/20">
                  5 {t('blog.min_read')}
                </span>
              </div>
              
              <h2 class="text-2xl font-bold text-white mb-4 leading-snug group-hover:text-brand-primary transition-colors">
                {post.data.title}
              </h2>
              
              <p class="text-slate-400 text-sm leading-relaxed flex-grow mb-8 line-clamp-3">
                {post.data.description}
              </p>
              
              <div class="pt-6 border-t border-white/5 mt-auto">
                <span class="group/btn inline-flex items-center gap-2 text-sm font-bold text-white uppercase tracking-wider group-hover:text-brand-accent transition-colors">
                  {t('blog.read_more')} 
                  <svg class="w-4 h-4 transform group-hover/btn:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
                </span>
              </div>
            </div>
          </article>
        </a>
      ))}
    </div>

    {/* Pagination */}
    {(page.url.prev || page.url.next) && (
      <nav class="flex justify-between items-center mt-20 pt-10 border-t border-white/5">
        {page.url.prev ? (
          <a href={page.url.prev} class="px-6 py-2.5 border border-white/10 rounded-xl bg-bg-surface hover:bg-slate-800 text-xs font-bold uppercase tracking-widest text-slate-300 hover:text-white transition-all">&larr; {t('blog.newer')}</a>
        ) : <div class="w-24"></div>}
        
        <div class="flex items-center gap-2">
          <span class="text-[10px] uppercase font-bold text-slate-600 tracking-widest">{t('blog.part')}</span>
          <span class="px-3 py-1 rounded-md bg-brand-primary/10 border border-brand-primary/20 text-brand-primary font-bold text-sm">{page.currentPage}</span>
          <span class="text-[10px] uppercase font-bold text-slate-600 tracking-widest">{t('blog.of')} {page.lastPage}</span>
        </div>
        
        {page.url.next ? (
          <a href={page.url.next} class="px-6 py-2.5 border border-white/10 rounded-xl bg-bg-surface hover:bg-slate-800 text-xs font-bold uppercase tracking-widest text-slate-300 hover:text-white transition-all">{t('blog.older')} &rarr;</a>
        ) : <div class="w-24"></div>}
      </nav>
    )}
  </div>
</BaseLayout>
