---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLocalizedPath, useTranslations, getLocaleFromUrl } from '../theme/i18n';
import HowItWorks from '../components/HowItWorks.astro';
import FeatureMatrix from '../components/FeatureMatrix.astro';
import FAQ from '../components/FAQ.astro';

const locale = getLocaleFromUrl(Astro.url.pathname);
const t = useTranslations(locale);

const faqItems = t('faq');
const howItWorksSteps = [
  { 
    title: "Draft Your Circuit", 
    description: "Use the smart drag-and-drop library containing 40+ industry-standard symbols to start your design." 
  },
  { 
    title: "Auto-Route Wires", 
    description: "Our Manhattan routing engine ensures all connections stay perfectly orthogonal and snapped to the grid." 
  },
  { 
    title: "Export & Share", 
    description: "Download crystal clear SVG or high-DPI PNG files ready for technical reports or publications." 
  }
];

const matrixHeaders = ["Feature", "Circuit Diagram Maker", "Legacy Tools"];
const matrixRows = [
  ["Browser Based", "Yes", "No"],
  ["Smart Routing", "Yes", "Limited"],
  ["SVG Export", "Yes", "Yes"],
  ["High-DPI PNG", "Yes", "No"],
  ["Completely Free", "Yes", "No"]
];
---

<BaseLayout>
  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-bg-dark pt-24 pb-32">
    <div class="absolute inset-x-0 top-0 h-96 bg-gradient-to-b from-brand-primary/10 to-transparent"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <div class="text-center max-w-3xl mx-auto">
        <h1 class="text-5xl md:text-6xl font-extrabold tracking-tight mb-6 bg-gradient-to-br from-white to-slate-400 bg-clip-text text-transparent">
          {t('home.hero.title')}
        </h1>
        <p class="text-xl text-slate-400 mb-10 leading-relaxed">
          {t('home.hero.subtitle')}
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href={getLocalizedPath('/editor/', locale)} class="px-8 py-3 rounded-lg bg-brand-primary hover:bg-blue-500 text-white font-semibold transition-all shadow-[0_0_20px_rgba(59,130,246,0.3)] hover:shadow-[0_0_30px_rgba(59,130,246,0.5)] w-full sm:w-auto">
            {t('home.hero.cta')}
          </a>
          <a href={getLocalizedPath('/docs', locale)} class="px-8 py-3 rounded-lg bg-bg-surface border border-white/10 hover:border-white/20 text-white font-medium transition-all w-full sm:w-auto">
            {t('home.hero.secondary')}
          </a>
        </div>
      </div>
      
      <!-- Mockup Preview -->
      <div class="mt-20 relative mx-auto max-w-5xl">
        <div class="rounded-xl border border-white/10 bg-bg-panel shadow-2xl overflow-hidden aspect-[16/9] relative">
          <!-- Stylized editor preview -->
          <div class="absolute inset-0 bg-[url('/css/grid.svg')] opacity-20" style="background-size: 20px 20px;"></div>
          <div class="absolute inset-0 flex items-center justify-center">
             <div class="text-slate-500 flex flex-col items-center gap-4">
               <svg class="w-16 h-16 text-brand-primary opacity-80" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
               <span class="font-medium text-lg tracking-widest uppercase">CircuitForge Engine</span>
             </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <HowItWorks title={t('home.how_it_works.title')} steps={howItWorksSteps} />

  <!-- Features Matrix -->
  <FeatureMatrix title={t('home.data.title')} headers={matrixHeaders} rows={matrixRows} />

  <!-- FAQ Section -->
  <FAQ title={t('home.faq.title')} items={faqItems} />

</BaseLayout>
