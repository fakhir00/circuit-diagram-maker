---
import ToolLandingPage from '../components/pages/ToolLandingPage.astro';
import { getLocaleFromUrl, getLocalizedPath, useTranslations } from '../theme/i18n';

const locale = getLocaleFromUrl(Astro.url.pathname);
const t = useTranslations(locale);

const features = [
  { title: t('logic.features.1.title'), desc: t('logic.features.1.desc') },
  { title: t('logic.features.2.title'), desc: t('logic.features.2.desc') },
  { title: t('logic.features.3.title'), desc: t('logic.features.3.desc') }
];

const useCases = [
  t('logic.use_case.1'),
  t('logic.use_case.2'),
  t('logic.use_case.3')
];

const tableHeaders = [
  t('logic.table.header.1'),
  t('logic.table.header.2'),
  t('logic.table.header.3')
];

const tableRows = [
  [t('logic.table.row.1.col.1'), t('logic.table.row.1.col.2'), t('logic.table.row.1.col.3')],
  [t('logic.table.row.2.col.1'), t('logic.table.row.2.col.2'), t('logic.table.row.2.col.3')],
  [t('logic.table.row.3.col.1'), t('logic.table.row.3.col.2'), t('logic.table.row.3.col.3')]
];
---

<ToolLandingPage
  locale={locale}
  title={t('logic.title')}
  description={t('logic.description')}
  eyebrow={t('logic.eyebrow')}
  heroTitle={t('logic.hero.title')}
  heroDescription={t('logic.hero.description')}
  primaryCtaLabel={t('logic.cta.primary')}
  primaryCtaHref={getLocalizedPath('/logic-editor/', locale)}
  secondaryCtaLabel={t('logic.cta.secondary')}
  secondaryCtaHref={getLocalizedPath('/logic-editor/', locale)}
  featureTitle={t('logic.feature_title')}
  featureIntro={t('logic.feature_intro')}
  features={features}
  useCases={useCases}
  tableTitle={t('logic.table.title')}
  tableHeaders={tableHeaders}
  tableRows={tableRows}
  presetId="gates"
  t={t}
/>
