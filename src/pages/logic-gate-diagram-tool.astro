---
import ToolLandingPage from '../components/pages/ToolLandingPage.astro';
---

<ToolLandingPage
  title="Logic Gate Diagram Tool"
  description="Create clean digital logic diagrams with AND, OR, NOT, NAND, NOR, XOR, and XNOR symbols using our browser-based logic gate diagram tool."
  eyebrow="Digital Logic"
  heroTitle="Logic Gate Diagram Tool for Fast, Clear Digital Schematics"
  heroDescription="Design logic gate diagrams online with standard symbols, clean routing, and export-ready layouts for classes, documentation, and embedded system planning."
  primaryCtaLabel="Open Logic Diagram Editor"
  primaryCtaHref="/editor/"
  secondaryCtaLabel="Browse Components"
  secondaryCtaHref="/components/"
  presetId="gates"
  featureTitle="Build logic diagrams without fighting the layout"
  featureIntro="Use the editor to place digital symbols, structure signal flow from left to right, and document combinational or sequential logic in a format that is easy to review."
  features={[
    {
      title: 'Standard gate symbols',
      desc: 'Place AND, OR, NOT, NAND, NOR, XOR, and XNOR symbols using schematic-friendly shapes that stay readable in reports and slides.'
    },
    {
      title: 'Clean signal routing',
      desc: 'Keep gate inputs and outputs organized with orthogonal wires that reduce ambiguity in digital logic diagrams.'
    },
    {
      title: 'Teaching and documentation ready',
      desc: 'Export logic gate diagrams as SVG or PNG for coursework, lab submissions, tutorials, and design notes.'
    }
  ]}
  useCases={[
    'Boolean expression diagrams for classes and assignments',
    'Embedded control logic planning before firmware implementation',
    'Digital electronics teaching materials and exam prep',
    'Quick reviews of gate-level concepts for students and makers'
  ]}
  tableTitle="Logic diagram workflow reference"
  tableHeaders={['Step', 'What to do', 'Why it matters']}
  tableRows={[
    ['Define inputs', 'Place switches, labels, or source signals first', 'This establishes the logic conditions clearly'],
    ['Add gates', 'Arrange gates in the order they process the inputs', 'Readers can follow the combinational logic path'],
    ['Label outputs', 'Name result nodes and final outputs', 'Makes the circuit easier to test and explain'],
    ['Review flow', 'Check that logic moves left to right', 'Improves readability and reduces confusion']
  ]}
/>
