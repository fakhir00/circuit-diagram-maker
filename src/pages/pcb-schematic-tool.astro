---
import ToolLandingPage from '../components/pages/ToolLandingPage.astro';

const features = [
  {
    title: 'Separate PCB schematic canvas',
    desc: 'Open a focused workspace for schematic capture before layout, with PCB-oriented parts, nets, and documentation flow.'
  },
  {
    title: 'Layout-friendly planning',
    desc: 'Organize symbols and connectivity in a way that is easier to translate into board layout, review, and manufacturing preparation.'
  },
  {
    title: 'Professional export formats',
    desc: 'Create polished schematic references for fabrication packages, design reviews, and engineering documentation.'
  }
];

const useCases = [
  'Pre-layout schematic drafting for custom PCB projects',
  'Team reviews before PCB routing and manufacturing handoff',
  'Documentation for embedded systems and production boards'
];

const tableHeaders = ['Capability', 'What You Can Do', 'Best For'];

const tableRows = [
  ['PCB symbols', 'Work with a filtered set of schematic elements relevant to board design', 'Custom board planning'],
  ['Workflow separation', 'Keep PCB drafting isolated from general circuit or Arduino work', 'Dedicated engineering pipelines'],
  ['Output formats', 'Export board-prep schematics as SVG, PNG, or JSON', 'Review, archive, and iteration']
];
---

<ToolLandingPage
  title="PCB Schematic Tool"
  description="Draft professional board schematics with a dedicated PCB schematic tool built for separate canvas workflows, schematic planning, and export-ready output."
  eyebrow="PCB Drafting Workspace"
  heroTitle="PCB Schematic Tool for Cleaner Board-Level Planning"
  heroDescription="Use a separate PCB-focused editor to capture schematics, organize nets, and prepare clear documentation before board layout and production."
  primaryCtaLabel="Open PCB Editor"
  primaryCtaHref="/pcb-editor/"
  secondaryCtaLabel="Read Docs"
  secondaryCtaHref="/docs/"
  featureTitle="Designed for board-level schematic work"
  featureIntro="This tool gives PCB projects their own landing page and their own editor flow, helping you keep schematic capture isolated, organized, and easier to review."
  features={features}
  useCases={useCases}
  tableTitle="Why use the PCB schematic tool?"
  tableHeaders={tableHeaders}
  tableRows={tableRows}
  presetId="pcb_tool"
/>
