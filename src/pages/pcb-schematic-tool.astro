---
import ToolLandingPage from '../components/pages/ToolLandingPage.astro';
import { getLocaleFromUrl, getLocalizedPath, useTranslations } from '../theme/i18n';

const locale = getLocaleFromUrl(Astro.url.pathname);
const t = useTranslations(locale);

const features = [
  { title: t('pcb.features.1.title'), desc: t('pcb.features.1.desc') },
  { title: t('pcb.features.2.title'), desc: t('pcb.features.2.desc') },
  { title: t('pcb.features.3.title'), desc: t('pcb.features.3.desc') }
];

const useCases = [
  t('pcb.use_case.1'),
  t('pcb.use_case.2'),
  t('pcb.use_case.3')
];

const tableHeaders = [
  t('pcb.table.header.1'),
  t('pcb.table.header.2'),
  t('pcb.table.header.3')
];

const tableRows = [
  [t('pcb.table.row.1.col.1'), t('pcb.table.row.1.col.2'), t('pcb.table.row.1.col.3')],
  [t('pcb.table.row.2.col.1'), t('pcb.table.row.2.col.2'), t('pcb.table.row.2.col.3')],
  [t('pcb.table.row.3.col.1'), t('pcb.table.row.3.col.2'), t('pcb.table.row.3.col.3')]
];
---

<ToolLandingPage
  locale={locale}
  title={t('pcb.title')}
  description={t('pcb.description')}
  eyebrow={t('pcb.eyebrow')}
  heroTitle={t('pcb.hero.title')}
  heroDescription={t('pcb.hero.description')}
  primaryCtaLabel={t('pcb.cta.primary')}
  primaryCtaHref={getLocalizedPath('/pcb-editor/', locale)}
  secondaryCtaLabel={t('pcb.cta.secondary')}
  secondaryCtaHref={getLocalizedPath('/pcb-editor/', locale)}
  featureTitle={t('pcb.feature_title')}
  featureIntro={t('pcb.feature_intro')}
  features={features}
  useCases={useCases}
  tableTitle={t('pcb.table.title')}
  tableHeaders={tableHeaders}
  tableRows={tableRows}
  presetId="pcb_tool"
  t={t}
/>
