---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLocaleFromUrl, useTranslations, getLocalizedPath } from '../theme/i18n';

const { locale } = Astro.props;
const t = useTranslations(locale);
const lastUpdated = "2026-04-01";
---

<BaseLayout title={t('legal.terms.meta.title')} description={t('legal.terms.meta.description')}>
  <section class="relative overflow-hidden border-b border-white/5 bg-bg-dark py-20">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(59,130,246,0.08),transparent_40%)]"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-sm font-semibold uppercase tracking-[0.35em] text-brand-accent mb-4">{t('legal.terms.hero.badge')}</p>
      <h1 class="text-4xl font-extrabold tracking-tight text-white">{t('legal.terms.hero.title')}</h1>
      <p class="mt-3 text-slate-400">{t('legal.terms.hero.updated')}: {lastUpdated}</p>
    </div>
  </section>

  <section class="py-16 bg-bg-panel">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose prose-invert prose-blue max-w-none text-slate-300 space-y-8">

        <div>
           <h2 class="text-2xl font-semibold text-white">{t('legal.terms.s1.title')}</h2>
           <p>{t('legal.terms.s1.p1')}</p>
        </div>

        <div>
          <h2 class="text-2xl font-semibold text-white">{t('legal.terms.s2.title')}</h2>
          <p>{t('legal.terms.s2.p1')}</p>
          <ul class="list-disc list-inside space-y-2 mt-3">
            <li>{t('legal.terms.s2.l1')}</li>
            <li>{t('legal.terms.s2.l2')}</li>
            <li>{t('legal.terms.s2.l3')}</li>
            <li>{t('legal.terms.s2.l4')}</li>
          </ul>
        </div>

        <div>
          <h2 class="text-2xl font-semibold text-white">{t('legal.terms.s3.title')}</h2>
          <p>{t('legal.terms.s3.p1')}</p>
          <ul class="list-disc list-inside space-y-2 mt-3">
            <li>{t('legal.terms.s3.l1')}</li>
            <li>{t('legal.terms.s3.l2')}</li>
            <li>{t('legal.terms.s3.l3')}</li>
            <li>{t('legal.terms.s3.l4')}</li>
          </ul>
        </div>

        <div>
          <h2 class="text-2xl font-semibold text-white">{t('legal.terms.s4.title')}</h2>
          <p>{t('legal.terms.s4.p1')}</p>
        </div>

        <div>
          <h2 class="text-2xl font-semibold text-white">{t('legal.terms.s5.title')}</h2>
          <p>{t('legal.terms.s5.p1')}</p>
        </div>

        <div>
          <h2 class="text-2xl font-semibold text-white">{t('legal.terms.s6.title')}</h2>
          <p>{t('legal.terms.s6.p1')}</p>
        </div>

        <div>
          <h2 class="text-2xl font-semibold text-white">{t('legal.terms.s7.title')}</h2>
          <p>{t('legal.terms.s7.p1')}</p>
        </div>

        <div>
          <h2 class="text-2xl font-semibold text-white">{t('legal.terms.s8.title')}</h2>
          <p>{t('legal.terms.s8.p1')} <a href="mailto:legal@circuit-diagram.org" class="text-brand-primary hover:text-brand-accent">legal@circuit-diagram.org</a> or {t('legal.terms.s8.p2')} <a href={getLocalizedPath('/contact-us/', locale)} class="text-brand-primary hover:text-brand-accent">{t('contact.hero.badge')}</a>.</p>
        </div>

      </div>
    </div>
      </div>
    </div>
  </section>
</BaseLayout>
