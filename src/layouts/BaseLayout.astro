---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLocaleFromUrl } from '../theme/i18n';
import '../styles/global.css';
import config from '../data/config.json';

interface Props {
  title?: string;
  description?: string;
  hideHeaderFooter?: boolean;
}

const { title, description, hideHeaderFooter = false } = Astro.props;
const pathname = Astro.url.pathname;
const locale = getLocaleFromUrl(pathname);
const dir = locale === 'ar' ? 'rtl' : 'ltr';

const finalTitle = title ? `${title} | ${config.site.name}` : `${config.site.name} — Free Online Schematic Editor`;
const finalDescription = description || config.site.description;
const canonicalURL = new URL(Astro.url.pathname, Astro.site || config.site.url);

// Build dynamic breadcrumbs
const segments = pathname.split('/').filter(Boolean);
const breadcrumbItems = [
  { name: 'Home', url: config.site.url + '/' }
];
const labelMap: Record<string,string> = {
  'editor': 'Circuit Diagram Editor',
  'about-us': 'About Us',
  'contact-us': 'Contact Us',
  'components': 'Component Library',
  'docs': 'Documentation',
  'blog': 'Blog',
  'terms': 'Terms of Service',
  'privacy': 'Privacy Policy',
  'sitemap': 'Sitemap',
};
let pathAccum = '';
for (const seg of segments) {
  if (['en','hi','es','ru','fr','de','it','pt','bn','ja','ko','ms','pl','id','ar','bg','tr','sv'].includes(seg)) continue;
  pathAccum += `/${seg}`;
  breadcrumbItems.push({
    name: labelMap[seg] || seg.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase()),
    url: config.site.url + pathAccum + '/'
  });
}

const breadcrumbSchema = breadcrumbItems.length > 1 ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbItems.map((item, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": item.name,
    "item": item.url
  }))
} : null;

// SoftwareApplication schema for homepage
const isHome = pathname === '/' || pathname === `/${locale}/`;
const softwareSchema = isHome ? {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Circuit Diagram Maker",
  "applicationCategory": "DesignApplication",
  "operatingSystem": "Web Browser",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "description": config.site.description,
  "url": config.site.url,
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.8",
    "ratingCount": "1240",
    "bestRating": "5"
  }
} : null;
---

<!DOCTYPE html>
<html lang={locale} dir={dir}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{finalTitle}</title>
  <meta name="description" content={finalDescription} />
  <meta name="keywords" content="circuit diagram maker, circuit diagram, schematic editor, wiring diagram, electronic schematic, circuit design tool, free circuit diagram, online schematic maker, circuit simulator, PCB schematic" />
  
  <link rel="canonical" href={canonicalURL} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="apple-touch-icon" href="/logo.svg" />
  
  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  
  <!-- Open Graph -->
  <meta property="og:title" content={finalTitle} />
  <meta property="og:description" content={finalDescription} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:site_name" content={config.site.name} />
  <meta property="og:locale" content={locale === 'en' ? 'en_US' : locale} />
  <meta property="og:type" content={pathname.includes('/blog/') ? 'article' : 'website'} />
  <meta property="og:image" content={new URL('/og-image.png', canonicalURL)} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={config.site.name} />
  
  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={finalTitle} />
  <meta name="twitter:description" content={finalDescription} />
  <meta name="twitter:image" content={new URL('/og-image.png', canonicalURL)} />
  
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
  <meta name="googlebot" content="index, follow" />
  
  <!-- JSON-LD Combined Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": `${config.site.url}/#organization`,
        "name": config.site.name,
        "url": config.site.url,
        "description": config.site.description,
        "logo": {
          "@type": "ImageObject",
          "url": `${config.site.url}/logo.svg`,
          "width": 128,
          "height": 128
        },
        "sameAs": Object.values(config.social || {})
      },
      {
        "@type": "WebSite",
        "@id": `${config.site.url}/#website`,
        "url": config.site.url,
        "name": config.site.name,
        "publisher": { "@id": `${config.site.url}/#organization` },
        "inLanguage": locale,
        "potentialAction": {
          "@type": "SearchAction",
          "target": `${config.site.url}/blog/?q={search_term_string}`,
          "query-input": "required name=search_term_string"
        }
      },
      pathname.includes('/about-us') && {
        "@type": "AboutPage",
        "@id": `${canonicalURL}#webpage`,
        "url": canonicalURL,
        "name": finalTitle
      },
      pathname.includes('/contact-us') && {
        "@type": "ContactPage",
        "@id": `${canonicalURL}#webpage`,
        "url": canonicalURL,
        "name": finalTitle
      }
    ].filter(Boolean)
  })} />
  
  {breadcrumbSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  )}
  
  {softwareSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(softwareSchema)} />
  )}

  <slot name="head" />
</head>
<body class="flex flex-col min-h-screen">
  {!hideHeaderFooter && <Header locale={locale} config={config} />}
  
  <main class="flex-grow">
    <slot />
  </main>

  {!hideHeaderFooter && <Footer locale={locale} config={config} />}
</body>
</html>
